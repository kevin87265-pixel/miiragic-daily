function showATab(t){
  document.querySelectorAll('.atab').forEach((e,i)=>e.classList.toggle('active',i===(t==='login'?0:1)));
  $('login-f').style.display=t==='login'?'block':'none';
  $('reg-f').style.display=t==='reg'?'block':'none';
}
function pickAv(el){document.querySelectorAll('.av-o').forEach(e=>e.classList.remove('sel'));el.classList.add('sel');selAv=el.dataset.v;}
function pickCls(el){document.querySelectorAll('.cls-o').forEach(e=>e.classList.remove('sel'));el.classList.add('sel');selCls=el.dataset.c;}
function pickGender(g){
  selGender=g;
  const male=$('g-male'),female=$('g-female');
  if(male){male.style.background=g==='male'?'rgba(112,184,255,.15)':'#111';male.style.border=g==='male'?'2px solid var(--blue)':'1px solid var(--border)';male.querySelector('div:last-child').style.color=g==='male'?'var(--blue)':'var(--muted)';}
  if(female){female.style.background=g==='female'?'rgba(255,107,157,.15)':'#111';female.style.border=g==='female'?'2px solid #ff6b9d':'1px solid var(--border)';female.querySelector('div:last-child').style.color=g==='female'?'#ff6b9d':'var(--muted)';}
}
async function doLogin(){
  const u=$('li-u').value.trim(),p=$('li-p').value;
  const err=$('li-e');err.textContent='';
  if(!u||!p){err.textContent='脙篓脗芦脗聥脙楼脗隆脗芦脙楼脗炉脗芦脙楼脗赂脗鲁脙篓脗聶脗聼脙楼脗聮脗聦脙楼脗炉脗聠脙搂脗垄脗录';return;}
  try{
    // 脙楼脗聟脗聢脙楼脗戮脗聻 Supabase 脙娄脗聥脗聣脙娄脗聹脗聙脙娄脗聳脗掳脙篓脗鲁脗聡脙娄脗聳脗聶脙炉脗录脗聢脙娄脗聹脗聣脙搂脗露脗虏脙篓脗路脗炉脙娄脗聶脗聜脙炉脗录脗聣脙炉脗录脗聦脙楼脗聠脗聧 fallback 脙娄脗聹脗卢脙楼脗聹脗掳
    ld(true);
    const data=(await sbPullHero(u))||LS.one('heroes','user_id',u);
    ld(false);
    if(!data){err.textContent='脙娄脗聣脗戮脙陇脗赂脗聧脙楼脗聢脗掳脙楼脗赂脗鲁脙篓脗聶脗聼脙拢脗聙脗聦'+u+'脙拢脗聙脗聧脙炉脗录脗聦脙篓脗芦脗聥脙漏脗禄脗聻脙陇脗赂脗聥脙娄脗聳脗鹿脙拢脗聙脗聦脙娄脗赂脗聟脙漏脗聶脗陇脙篓脗鲁脗聡脙娄脗聳脗聶脙拢脗聙脗聧脙楼脗戮脗聦脙漏脗聡脗聧脙篓脗漏脗娄';return;}
    const pw=hsh(p+u+'hd2025');
    if(data.password_hash!==pw){err.textContent='脙楼脗炉脗聠脙搂脗垄脗录脙漏脗聦脗炉脙篓脗陋脗陇脙炉脗录脗聢脙楼脗赂脗鲁脙篓脗聶脗聼脙炉脗录脗職'+u+'脙炉脗录脗聣';return;}
    if(data.approved===false&&p!==ADMIN_PW&&p!==ADMIN_SUPER_PW){
      err.style.color='var(--orange)';
      err.textContent='脙垄脗聫脗鲁 脙篓脗搂脗聮脙篓脗聣脗虏脙楼脗炉脗漏脙娄脗聽脗赂脙陇脗赂脗颅脙炉脗录脗聦脙篓脗芦脗聥脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙娄脗聽脗赂脙楼脗聡脗聠脙楼脗戮脗聦脙楼脗聠脗聧脙搂脗聶脗禄脙楼脗聟脗楼';return;
    }
    isAdmin=(p===ADMIN_PW||p===ADMIN_SUPER_PW);
    initH(JSON.parse(JSON.stringify(data)));
    showApp();
    if(isAdmin){
      // 脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙搂脗聶脗禄脙楼脗聟脗楼脙娄脗聶脗聜脙漏脗聽脗聠脙楼脗赂脗露脙娄脗聥脗聣脙娄脗聣脗聙脙娄脗聹脗聣脙篓脗聥脗卤脙漏脗聸脗聞脙楼脗聮脗聦 game_data
      sbPullAllHeroes().then(()=>{
        ['step_submissions','task_reviews','perf_records','perf_ms_reviews',
         'lottery_prizes','lottery_winners','lottery_config','notices'].forEach(t=>sbPullGameData(t));
      });
      $('admin-panel').style.display='block';switchAdmin('dashboard');populatePerfHeroSel();
    }
  }catch(e){
    ld(false);
    err.textContent='脙搂脗聶脗禄脙楼脗聟脗楼脙漏脗聦脗炉脙篓脗陋脗陇脙炉脗录脗職'+e.message;
    console.error('doLogin error',e);
  }
}
function doLogout(){
  hero=null;isAdmin=false;
  $('admin-panel').style.display='none';
  $('main').style.display='none';$('auth').style.display='flex';
}
async function doReg(){
  const u=$('rg-u').value.trim(),n=$('rg-n').value.trim(),p=$('rg-p').value;
  const err=$('rg-e');err.textContent='';
  if(!u||!n||!p){err.textContent='脙篓脗芦脗聥脙楼脗隆脗芦脙楼脗炉脗芦脙娄脗聣脗聙脙娄脗聹脗聣脙娄脗卢脗聞脙陇脗陆脗聧';return;}
  if(!/^[a-zA-Z0-9_]{3,20}$/.test(u)){err.textContent='脙楼脗赂脗鲁脙篓脗聶脗聼脙楼脗聫脗陋脙篓脗聝脗陆脙篓脗聥脗卤脙娄脗聲脗赂脙楼脗颅脗聴3-20脙楼脗颅脗聴';return;}
  if(p.length<6){err.textContent='脙楼脗炉脗聠脙搂脗垄脗录脙篓脗聡脗鲁脙楼脗掳脗聭6脙陇脗陆脗聧';return;}

  // 脙娄脗卤脗潞脙楼脗庐脗職脙楼脗炉脗娄脙漏脗職脗聸脙篓脗聛脗路脙娄脗楼脗颅脙炉脗录脗聢脙漏脗職脗篓脙娄脗漏脗聼脙篓脗聛脗路脙娄脗楼脗颅脙炉脗录脗職脙楼脗戮脗聻脙漏脗聺脗聻random脙陇脗赂脗颅脙漏脗職脗篓脙娄脗漏脗聼脙漏脗聛脗赂脙陇脗赂脗聙脙炉脗录脗聣
  const allCls=Object.keys(CLASS_DEF).filter(c=>c!=='random');
  const actualCls=selCls==='random'?allCls[Math.floor(Math.random()*allCls.length)]:selCls;
  const base=CLASS_DEF[actualCls];

  // 脙漏脗職脗篓脙娄脗漏脗聼脙娄脗聲脗赂脙楼脗聙脗录脙炉脗录脗職脙楼脗聬脗聞脙楼脗卤脗卢脙娄脗聙脗搂脙楼脗聹脗篓 base 脙聜脗卤20% 脙楼脗聟脗搂脙漏脗職脗篓脙娄脗漏脗聼
  const rnd=(v)=>Math.round(v*(0.8+Math.random()*0.4));
  const bHp=rnd(base.hp), bStr=rnd(base.str), bDef=rnd(base.def), bSpd=rnd(base.spd);
  const bLuk=base.luk||10;

  // 脙篓脗碌脗路脙楼脗搂脗聥脙漏脗聡脗聭脙楼脗鹿脗拢脙炉脗录脗職100-500脙炉脗录脗聦脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聙脗录脙篓脗露脗聤脙漏脗芦脗聵脙篓脗露脗聤脙楼脗陇脗職
  const baseCoins=100+Math.floor(Math.random()*401); // 100~500
  const lukBonus=Math.floor(bLuk/10)*20; // 脙娄脗炉脗聫10脙漏脗禄脗聻LUK+20脙掳脗聼脗陋脗聶
  const startCoins=baseCoins+lukBonus;

  // 脙漏脗職脗篓脙娄脗漏脗聼脙篓脗聛脗路脙娄脗楼脗颅脙漏脗隆脗聧脙楼脗陇脗聳脙篓脗麓脗聢脙楼脗聯脗聛
  const bonus_inv=[];
  if(selCls==='random'){
    const pool=[
      ...EQUIP_ITEMS.filter(it=>it.tier<=2&&!it.rarity),
      ...COSTUME_SHOP.filter(it=>it.reqLv<=2),
      ...PET_DEF.filter(p=>p.stars===1).map(p=>({
        id:'pet_'+p.id+'_start',petDefId:p.id,name:p.name,icon:p.icon,level:1,exp:0,slot:'pet',uid:'start_'+p.id
      }))
    ];
    const gift=pool[Math.floor(Math.random()*pool.length)];
    if(gift){
      // 脙篓脗拢脗聺脙楼脗聜脗聶/脙娄脗聶脗聜脙篓脗拢脗聺脙搂脗聸脗麓脙娄脗聨脗楼脙娄脗聰脗戮脙楼脗聟脗楼脙炉脗录脗聦脙楼脗炉脗碌脙搂脗聣脗漏脙楼脗路脗虏脙娄脗聹脗聣脙娄脗聽脗录脙楼脗录脗聫
      const item=gift.petDefId?gift:{...gift,uid:'start_eq_'+Date.now()};
      bonus_inv.push(item);
    }
  }

  const pw=hsh(p+u+'hd2025');
  const {data,error}=LS.ins('heroes',{
    user_id:u,username:n,password_hash:pw,avatar:selAv,
    hero_class:actualCls, // 脙楼脗炉脗娄脙漏脗職脗聸脙篓脗聛脗路脙娄脗楼脗颅
    hero_class_display:selCls==='random'?'random':actualCls, // 脙漏脗隆脗炉脙搂脗陇脗潞脙搂脗聰脗篓
    gender:selGender,
    level:1,exp:0,coins:startCoins,
    stat_hp:bHp,stat_str:bStr,stat_def:bDef,stat_spd:bSpd,
    base_hp:bHp,base_str:bStr,base_def:bDef,base_spd:bSpd,
    base_luk:bLuk,luk_bonus:0,
    streak:0,total_steps:0,
    week_days:[false,false,false,false,false,false,false],
    inventory:bonus_inv,equipped:{},
    tasks_done:[],dungeons_done:[],
    pity:{weapon:0,costume:0,pet:0,mixed:0},
    monk_att:{},total_perf:0,
    week_data:{week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0},
    approved:false,
    created_at:new Date().toISOString(),
  });
  if(error){err.textContent=error.code==='23505'?'脙娄脗颅脗陇脙楼脗赂脗鲁脙篓脗聶脗聼脙楼脗路脗虏脙楼脗颅脗聵脙楼脗聹脗篓':'脙楼脗禄脗潞脙搂脗芦脗聥脙楼脗陇脗卤脙娄脗聲脗聴';return;}
  err.style.color='var(--teal)';
  const giftMsg=selCls==='random'&&bonus_inv.length?' 脙掳脗聼脗聨脗聛 脙篓脗麓脗聢脙漏脗聙脗聛脙炉脗录脗職'+(bonus_inv[0].name||'脙搂脗楼脗聻脙搂脗搂脗聵脙漏脗聛脗聯脙楼脗聟脗路'):'';
  err.textContent='脙垄脗聹脗聟 脙篓脗搂脗聮脙篓脗聣脗虏脙拢脗聙脗聦'+n+'脙拢脗聙脗聧脙楼脗禄脗潞脙搂脗芦脗聥脙娄脗聢脗聬脙楼脗聤脗聼脙炉脗录脗聛脙篓脗碌脗路脙楼脗搂脗聥脙漏脗聡脗聭脙楼脗鹿脗拢脙炉脗录脗職'+startCoins+'脙掳脗聼脗陋脗聶'+giftMsg+'脙拢脗聝脗禄脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙楼脗炉脗漏脙娄脗聽脗赂脙楼脗戮脗聦脙楼脗聧脗鲁脙楼脗聫脗炉脙搂脗聶脗禄脙楼脗聟脗楼 脙掳脗聼脗聨脗聣';
  $('rg-u').value='';$('rg-n').value='';$('rg-p').value='';
}
function showApp(){
  $('auth').style.display='none';
  $('main').style.display='block';
  try{renderAll();}catch(e){console.warn('renderAll error',e);}
  // 脙搂脗聶脗禄脙楼脗聟脗楼脙楼脗聲脗聫脙楼脗聙脗聶
  setTimeout(()=>{
    if(!hero)return;
    const tasks=getDailyTasks();
    const undone=tasks.filter(t=>!(hero.tasks_done||[]).includes(t.id+':'+tod())).length;
    const checkedIn=hero.last_checkin===tod();
    if(!checkedIn) toast('脙掳脗聼脗聭脗聥 脙娄脗颅脗隆脙篓脗驴脗聨脙楼脗聸脗聻脙陇脗戮脗聠 '+hero.username+'脙炉脗录脗聛脙篓脗篓脗聵脙楼脗戮脗聴脙陇脗禄脗聤脙娄脗聴脗楼脙搂脗掳脗陆脙楼脗聢脗掳 +30脙掳脗聼脗陋脗聶','info');
    else if(undone>0) toast('脙掳脗聼脗聯脗聥 脙陇脗禄脗聤脙娄脗聴脗楼脙漏脗聜脗聞脙娄脗聹脗聣 '+undone+' 脙楼脗聙脗聥脙陇脗禄脗禄脙楼脗聥脗聶脙娄脗聹脗陋脙楼脗庐脗聦脙娄脗聢脗聬','warn');
    else toast('脙垄脗聹脗聟 脙陇脗禄脗聤脙娄脗聴脗楼脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗聟脗篓脙娄脗聲脗赂脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛脙搂脗鹿脗录脙搂脗潞脗聦脙陇脗驴脗聺脙娄脗聦脗聛 脙掳脗聼脗聰脗楼');
  },500);
}
function initH(d){
  hero=d;
  hero.inventory=hero.inventory||[];
  hero.equipped=hero.equipped||{};
  hero.tasks_done=hero.tasks_done||[];
  hero.dungeons_done=hero.dungeons_done||[];
  hero.week_days=hero.week_days||Array(7).fill(false);
  hero.pity=hero.pity||{weapon:0,costume:0,pet:0,mixed:0};
  hero.monk_att=hero.monk_att||{};
  hero.total_perf=hero.total_perf||0;
  hero.badges_earned=hero.badges_earned||[];
  hero.total_tasks_done=hero.total_tasks_done||0;
  hero.total_gacha=hero.total_gacha||0;
  if(!hero.week_data||hero.week_data.week!==wk()){
    hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
  }
  try{recalc(hero);}catch(e){
    console.warn('recalc error',e);
    // fallback: set stats from base values
    hero.stat_hp=hero.base_hp||70;
    hero.stat_str=hero.base_str||15;
    hero.stat_def=hero.base_def||10;
    hero.stat_spd=hero.base_spd||15;
  }
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 SAVE 脙垄脗聲脗聬脙垄脗聲脗聬
function save(){
  if(!hero)return;
  LS.upd('heroes','user_id',hero.user_id,{...hero});
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 RENDER ALL 脙垄脗聲脗聬脙垄脗聲脗聬
function _try(fn){try{fn();}catch(e){console.warn('render err:',fn.name||'?',e);}}
function renderAll(){
  _try(updCoins);_try(updHeroUI);_try(renderSVG);
  _try(renderWeekly);_try(renderTasks);_try(renderDungeons);
  _try(renderShopEquip);_try(renderShopCostume);_try(renderShopPet);
  _try(renderGachaBanner);_try(updPity);
  _try(renderPets);_try(renderPerf);_try(renderMember);_try(renderLottery);
  _try(checkStepSt);_try(updStamina);
  _try(applyDailyPetBonus);_try(applyMonthlyMemberCoins);_try(applyMemberDailyStam);
  _try(checkMidnightReset);
  _try(updTabBadges);_try(applyProphetDailyLuk);
}
function updCoins(){$('coin-disp').textContent=(hero?.coins||0)+' 脙掳脗聼脗陋脗聶';}
// 脙垄脗聲脗聬脙垄脗聲脗聬 TAB BADGES脙炉脗录脗聢脙陇脗禄脗禄脙楼脗聥脗聶脙搂脗麓脗聟脙漏脗禄脗聻脙炉脗录脗聣脙垄脗聲脗聬脙垄脗聲脗聬
function updTabBadges(){
  if(!hero)return;
  const tasks=getDailyTasks();
  const today=tod();
  const undone=tasks.filter(t=>{
    const key=t.id+':'+today;
    return !(hero.tasks_done||[]).includes(key);
  }).length;
  // 脙娄脗聣脗戮脙陇脗禄脗禄脙楼脗聥脗聶 tab脙炉脗录脗聢index 2脙炉脗录脗聣
  const tabs=document.querySelectorAll('.tab');
  const taskTab=tabs[2]; // 脙掳脗聼脗聯脗聥脙陇脗禄脗禄脙楼脗聥脗聶
  if(!taskTab)return;
  let badge=taskTab.querySelector('.tab-badge');
  if(undone>0){
    if(!badge){badge=document.createElement('div');badge.className='tab-badge';taskTab.appendChild(badge);}
    badge.textContent=undone>9?'9+':undone;
  } else {
    badge?.remove();
  }
}
function toggleLukInfo(){
  const el=$('luk-info');if(el)el.style.display=el.style.display==='none'?'block':'none';
}
function updHeroUI(){
  if(!hero)return;
  const needed=hero.level*600;
  const cls=CLASS_DEF[hero.hero_class||'warrior'];
  $('h-name').textContent=hero.username;
  $('h-title').textContent=getTitle(hero.level);
  $('h-cls').textContent=cls.icon+' '+cls.name+' Lv.'+hero.level+' 脙垄脗聙脗聰 '+cls.perk;
  $('h-expxt').textContent=hero.exp+'/'+needed;
  $('need-exp').textContent=needed;
  $('h-expbar').style.width=Math.min(100,(hero.exp/needed)*100)+'%';
  $('s-hp').textContent=hero.stat_hp;$('s-str').textContent=hero.stat_str;
  $('s-def').textContent=hero.stat_def;$('s-spd').textContent=hero.stat_spd;
  $('b-hp').style.width=Math.min(100,hero.stat_hp/1.8)+'%';
  $('b-str').style.width=Math.min(100,hero.stat_str*1.4)+'%';
  $('b-def').style.width=Math.min(100,hero.stat_def*2)+'%';
  $('b-spd').style.width=Math.min(100,hero.stat_spd*1.7)+'%';
  // 脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聙脗录
  const luk=hero.stat_luk||10;
  if($('s-luk'))$('s-luk').textContent=luk;
  if($('s-luk-pct'))$('s-luk-pct').textContent=hero.luk_pct||1;
  if($('b-luk'))$('b-luk').style.width=Math.min(100,luk)+'%';
  $('h-badges').innerHTML=getBadges(hero).map(b=>`<div class="badge ${b.c}">${b.l}</div>`).join('');
  updEquipUI();updInvUI();
}
function updEquipUI(){
  const slots={weapon:{icon:'脙垄脗職脗聰脙炉脗赂脗聫',label:'脙娄脗颅脗娄脙楼脗聶脗篓'},armor:{icon:'脙掳脗聼脗聸脗隆脙炉脗赂脗聫',label:'脙漏脗聵脗虏脙楼脗聟脗路'},acc:{icon:'脙掳脗聼脗聮脗聧',label:'脙漏脗拢脗戮脙楼脗聯脗聛'},boot:{icon:'脙掳脗聼脗聭脗聼',label:'脙漏脗聻脗聥脙漏脗聺脗麓'},head:{icon:'脙掳脗聼脗聭脗聮',label:'脙漏脗聽脗颅脙漏脗拢脗戮'},body:{icon:'脙掳脗聼脗搂脗楼',label:'脙篓脗隆脗拢脙篓脗拢脗聺'},back:{icon:'脙掳脗聼脗娄脗聥',label:'脙篓脗聝脗聦脙漏脗拢脗戮'},pet:{icon:'脙掳脗聼脗聬脗戮',label:'脙楼脗炉脗碌脙搂脗聣脗漏'}};
  Object.entries(slots).forEach(([s,def])=>{
    const el=$('sl-'+s);if(!el)return;
    const it=(hero.equipped||{})[s];
    const icon=it?(it.icon||it.petDefId?PET_DEF.find(p=>p.id===it.petDefId)?.icon||'脙掳脗聼脗聬脗戮':it.icon):def.icon;
    const lbl=it?(it.name||PET_DEF.find(p=>p.id===it.petDefId)?.name||def.label):def.label;
    el.innerHTML=`<div class="ei">${icon}</div><div class="el">${lbl}</div>`;
    el.classList.toggle('filled',!!it);
  });
}
function switchInv(t){
  invTab=t;
  document.querySelectorAll('.itab').forEach((e,i)=>e.classList.toggle('active',['equip','costume','pet'][i]===t));
  $('inv-equip').style.display=t==='equip'?'block':'none';
  $('inv-costume').style.display=t==='costume'?'block':'none';
  $('inv-pet').style.display=t==='pet'?'block':'none';
}
function updInvUI(){
  const inv=hero.inventory||[];
  const sm={hp:'HP',str:'ATK',def:'DEF',spd:'SPD'};
  const equips=inv.filter(x=>x.slot&&!['head','body','back'].includes(x.slot)&&!x.petDefId);
  const costumes=inv.filter(x=>['head','body','back'].includes(x.slot));
  const pets=inv.filter(x=>x.petDefId);
  const renderSellable=(items,cid)=>{
    const el=$(cid);
    if(!items.length){el.innerHTML='<div class="empty">脙楼脗掳脗職脙搂脗聞脗隆脙搂脗聣脗漏脙楼脗聯脗聛</div>';return;}
    el.innerHTML=items.map((it)=>{
      const ri=inv.indexOf(it);
      const eq=(hero.equipped||{})[it.slot];
      const isEq=eq&&(eq.uid||eq.id)===(it.uid||it.id);
      let dsc=sm[it.stat]?sm[it.stat]+'+'+it.val:'脙娄脗聶脗聜脙篓脗拢脗聺';
      const sellPrice=it.price?Math.floor(it.price/2):0;
      return `<div class="inv-item">
        <span style="font-size:17px">${it.icon}</span>
        <div style="flex:1"><div style="font-size:12px;font-weight:500">${it.name}</div>
          <div style="font-size:10px;color:var(--muted)">${dsc}${sellPrice?` 脙聜脗路 脙篓脗鲁脗拢脙炉脗录脗職${sellPrice}脙掳脗聼脗陋脗聶`:''}</div></div>
        <button onclick="equipItem(${ri})" style="background:transparent;border:1px solid ${isEq?'var(--green)':'var(--gold)'};color:${isEq?'var(--green)':'var(--gold)'};padding:3px 6px;border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit;margin-right:3px">${isEq?'脙楼脗路脗虏脙篓脗拢脗聺脙楼脗聜脗聶':'脙篓脗拢脗聺脙楼脗聜脗聶'}</button>
        ${sellPrice&&!isEq?`<button onclick="sellItem(${ri})" style="background:transparent;border:1px solid var(--red);color:var(--red);padding:3px 6px;border-radius:5px;cursor:pointer;font-size:9px;font-family:inherit">脙篓脗鲁脗拢</button>`:''}
      </div>`;
    }).join('');
  };
  const renderPetInv=(items,cid)=>{
    const el=$(cid);
    if(!items.length){el.innerHTML='<div class="empty">脙楼脗掳脗職脙搂脗聞脗隆脙楼脗炉脗碌脙搂脗聣脗漏</div>';return;}
    el.innerHTML=items.map((it)=>{
      const ri=inv.indexOf(it);
      const eq=(hero.equipped||{})[it.slot];
      const isEq=eq&&(eq.uid||eq.id)===(it.uid||it.id);
      const pd=PET_DEF.find(p=>p.id===it.petDefId);
      const dsc=pd?'Lv.'+it.level+' '+pd.name:'脙楼脗炉脗碌脙搂脗聣脗漏';
      return `<div class="inv-item">
        <span style="font-size:17px">${it.icon}</span>
        <div style="flex:1"><div style="font-size:12px;font-weight:500">${it.name}</div><div style="font-size:10px;color:var(--muted)">${dsc}</div></div>
        <button onclick="equipItem(${ri})" style="background:transparent;border:1px solid ${isEq?'var(--green)':'var(--gold)'};color:${isEq?'var(--green)':'var(--gold)'};padding:3px 7px;border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit">${isEq?'脙楼脗路脗虏脙篓脗拢脗聺脙楼脗聜脗聶':'脙篓脗拢脗聺脙楼脗聜脗聶'}</button>
      </div>`;
    }).join('');
  };
  renderSellable(equips,'inv-equip');
  renderSellable(costumes,'inv-costume');
  renderPetInv(pets,'inv-pet');
}
function sellItem(i){
  const it=(hero.inventory||[])[i];if(!it)return;
  const sellPrice=it.price?Math.floor(it.price/2):0;
  if(!sellPrice){toast('脙娄脗颅脗陇脙搂脗聣脗漏脙楼脗聯脗聛脙搂脗聞脗隆脙娄脗鲁脗聲脙楼脗聡脗潞脙楼脗聰脗庐','warn');return;}
  // 脙陇脗赂脗聧脙篓脗聝脗陆脙篓脗鲁脗拢脙楼脗路脗虏脙篓脗拢脗聺脙楼脗聜脗聶脙搂脗職脗聞
  const eq=(hero.equipped||{})[it.slot];
  if(eq&&(eq.uid||eq.id)===(it.uid||it.id)){toast('脙篓脗芦脗聥脙楼脗聟脗聢脙楼脗聧脗赂脙陇脗赂脗聥脙楼脗聠脗聧脙篓脗鲁脗拢脙楼脗聡脗潞','warn');return;}
  if(!confirm(`脙搂脗垄脗潞脙楼脗庐脗職脙陇脗禄脗楼 ${sellPrice}脙掳脗聼脗陋脗聶 脙篓脗鲁脗拢脙楼脗聡脗潞脙拢脗聙脗聦${it.name}脙拢脗聙脗聧脙炉脗录脗聼脙炉脗录脗聢脙楼脗聨脗聼脙楼脗聝脗鹿 ${it.price}脙掳脗聼脗陋脗聶脙炉脗录脗聣`))return;
  hero.inventory=(hero.inventory||[]).filter((_,idx)=>idx!==i);
  hero.coins=(hero.coins||0)+sellPrice;
  save();updCoins();updInvUI();
  toast('脙掳脗聼脗聮脗掳 脙篓脗鲁脗拢脙楼脗聡脗潞 '+it.name+' +'+sellPrice+'脙掳脗聼脗陋脗聶');
}
function equipItem(i){
  const it=(hero.inventory||[])[i];if(!it)return;
  const uid=it.uid||it.id;
  const cur=(hero.equipped||{})[it.slot];
  if(cur&&(cur.uid||cur.id)===uid){hero.equipped[it.slot]=null;toast('脙楼脗路脗虏脙楼脗聧脗赂脙陇脗赂脗聥 '+it.name);}
  else{if(!hero.equipped)hero.equipped={};hero.equipped[it.slot]=it;toast('脙篓脗拢脗聺脙楼脗聜脗聶脙陇脗潞脗聠 '+it.name+'脙炉脗录脗聛');}
  recalc(hero);updHeroUI();renderSVG();save();
}
function showLevelUp(lv){
  $('lvup-num').textContent=lv;
  $('lvup-title').textContent=getTitle(lv);
  $('lvup-bonus').textContent='HP+12脙拢脗聙脗聙ATK+6脙拢脗聙脗聙DEF+5脙拢脗聙脗聙SPD+7';
  const m=$('lvup-modal');m.classList.add('show');
  // 5脙搂脗搂脗聮脙楼脗戮脗聦脙篓脗聡脗陋脙楼脗聥脗聲脙漏脗聴脗聹脙漏脗聳脗聣
  clearTimeout(m._t);m._t=setTimeout(closeLevelUp,5000);
}
function closeLevelUp(){
  const m=$('lvup-modal');m.classList.remove('show');
  clearTimeout(m._t);
}
function tryUpgrade(){
  const n=hero.level*600;
  if(hero.exp>=n){
    hero.exp-=n;hero.level++;
    hero.base_hp+=12;hero.base_str+=6;hero.base_def+=5;hero.base_spd+=7;
    recalc(hero);updHeroUI();save();
    showLevelUp(hero.level);
    updTabBadges();
  }else toast('脙漏脗聜脗聞脙楼脗路脗庐 '+(n-hero.exp)+' EXP','warn');
}
function gainEC(exp,coins){
  const mult=getMemberCoinMult();
  hero.exp+=exp;hero.coins+=Math.round(coins*mult);
  const needExp=()=>300+(hero.level-1)*200;
  if(hero.exp>=needExp()&&hero.level<20){
    hero.exp-=needExp();hero.level++;
    hero.base_hp+=12;hero.base_str+=6;hero.base_def+=5;hero.base_spd+=7;
    recalc(hero);
    showLevelUp(hero.level);
    updTabBadges();
  }
  updCoins();updHeroUI();
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 CHECKIN 脙垄脗聲脗聬脙垄脗聲脗聬
function renderWeekly(){
  if(!hero)return;
  const days=['脙陇脗赂脗聙','脙陇脗潞脗聦','脙陇脗赂脗聣','脙楼脗聸脗聸','脙陇脗潞脗聰','脙楼脗聟脗颅','脙娄脗聴脗楼'];
  const ti=new Date().getDay();const idx=ti===0?6:ti-1;
  const wd=hero.week_days||Array(7).fill(false);
  $('wrow').innerHTML=days.map((d,i)=>{
    let c='dd';if(wd[i])c+=' done';else if(i===idx)c+=' today';
    return `<div class="${c}">${wd[i]?'脙垄脗聹脗聯':d}</div>`;
  }).join('');
  $('streak-n').textContent=hero.streak||0;
  const done=hero.last_checkin===tod();
  $('ci-btn').disabled=done;$('ci-btn').textContent=done?'脙垄脗聹脗聟 脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙搂脗掳脗陆脙楼脗聢脗掳':'脙垄脗聹脗聟 脙搂脗芦脗聥脙楼脗聧脗鲁脙搂脗掳脗陆脙楼脗聢脗掳 (+30脙掳脗聼脗陋脗聶 +20EXP)';
}
async function doCheckin(){
  if(!hero||hero.last_checkin===tod())return;
  hero.last_checkin=tod();hero.streak=(hero.streak||0)+1;
  const ti=new Date().getDay();const idx=ti===0?6:ti-1;
  const wd=[...hero.week_days];wd[idx]=true;hero.week_days=wd;
  const bonus=Math.floor(hero.streak/7)*10;
  let expB=20;if(hero.hero_class==='paladin')expB+=15;
  gainEC(expB,30+bonus);
  // checkin refills stamina to max
  const max=getStamMax(hero);
  saveStam(hero,max);
  updStamina();
  save();renderWeekly();
  toast('脙垄脗聹脗聟 脙漏脗聙脗拢脙搂脗潞脗聦'+hero.streak+'脙楼脗陇脗漏 +'+(30+bonus)+'脙掳脗聼脗陋脗聶 +'+expB+'EXP 脙垄脗職脗隆脙娄脗禄脗驴脙漏脗芦脗聰脙楼脗聤脗聸脙炉脗录脗聛');
  tryLukStam();
}
function prevImg(inp){const f=inp.files[0];if(!f)return;const r=new FileReader();r.onload=e=>{const i=$('step-prev');i.src=e.target.result;i.style.display='block';};r.readAsDataURL(f);}
function checkStepSt(){
  const done=hero?.steps_submitted_date===tod();
  $('step-btn').disabled=done;$('step-btn').textContent=done?'脙垄脗聹脗聟 脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙娄脗聫脗聬脙陇脗潞脗陇':'脙掳脗聼脗聯脗陇 脙漏脗聙脗聛脙楼脗聡脗潞脙楼脗炉脗漏脙娄脗聽脗赂';
  $('step-st').textContent=done?'脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙楼脗炉脗漏脙娄脗聽脗赂...':(hero?.steps_approved_date===tod()?'脙垄脗聹脗聟 脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙娄脗聽脗赂脙楼脗聡脗聠':'');
}
async function submitSteps(){
  if(!hero||hero.steps_submitted_date===tod()){toast('脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙娄脗聫脗聬脙陇脗潞脗陇');return;}
  const steps=parseInt($('step-inp').value)||0;
  const imgInp=$('step-img');
  if(steps<100){toast('脙娄脗颅脗楼脙娄脗聲脗赂脙陇脗赂脗聧脙娄脗颅脗拢脙搂脗垄脗潞');return;}
  if(!imgInp.files[0]){toast('脙篓脗芦脗聥脙陇脗赂脗聤脙楼脗聜脗鲁脙娄脗聢脗陋脙楼脗聹脗聳');return;}
  ld(true);
  const r=new FileReader();
  r.onload=e=>{
    LS.ins('step_submissions',{user_id:hero.user_id,username:hero.username,steps,image_data:e.target.result,status:'pending',submitted_date:tod(),created_at:new Date().toISOString()});
    hero.steps_submitted_date=tod();
    // update week steps
    if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
    hero.week_data.steps=(hero.week_data.steps||0)+steps;
    save();checkStepSt();ld(false);
    toast('脙掳脗聼脗聯脗陇 脙楼脗路脗虏脙漏脗聙脗聛脙楼脗聡脗潞脙炉脗录脗聛脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙楼脗炉脗漏脙娄脗聽脗赂');
  };
  r.readAsDataURL(imgInp.files[0]);
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 TASKS 脙垄脗聲脗聬脙垄脗聲脗聬
function renderTasks(){
  if(!hero)return;
  const done=hero.tasks_done||[];
  const wdone=hero.weekly_tasks_done||[];
  const wd=hero.week_data||{};
  const tasks=getDailyTasks();
  $('daily-tasks').innerHTML=tasks.map(t=>{
    const key=t.id+':'+tod();
    const isDone=done.includes(key);
    // 脙楼脗炉脗漏脙娄脗聽脗赂脙楼脗聻脗聥脙搂脗聥脗聙脙娄脗聟脗聥
    const isReview=t.type==='review';
    const isPending=isReview&&LS.g('task_reviews').some(r=>r.task_id===t.id&&r.user_id===hero.user_id&&r.date===tod()&&r.status==='pending');
    const isApproved=isReview&&LS.g('task_reviews').some(r=>r.task_id===t.id&&r.user_id===hero.user_id&&r.date===tod()&&r.status==='approved');
    // 脙漏脗聴脗聹脙楼脗聧脗隆脙楼脗聻脗聥脙漏脗聙脗虏脙楼脗潞脗娄
    const isDungeonTask=t.type==='dungeon_clear';
    const dungProg=isDungeonTask?(hero.today_dungeon_clear||0):0;
    const dungDone=isDungeonTask&&dungProg>=(t.target||3);
    // 脙漏脗隆脗炉脙搂脗陇脗潞脙娄脗篓脗聶脙搂脗卤脗陇
    let typeTag='';
    if(isReview) typeTag=`<span style="font-size:9px;padding:1px 5px;border-radius:4px;background:rgba(230,126,34,.2);color:var(--orange)">脙掳脗聼脗聯脗聥 脙楼脗炉脗漏脙娄脗聽脗赂脙楼脗聻脗聥</span>`;
    if(isDungeonTask) typeTag=`<span style="font-size:9px;padding:1px 5px;border-radius:4px;background:rgba(112,184,255,.2);color:var(--blue)">脙垄脗職脗聰脙炉脗赂脗聫 脙漏脗聙脗職脙漏脗聴脗聹脙楼脗聻脗聥</span>`;
    // 脙娄脗聨脗聣脙篓脗聬脗陆脙篓脗鲁脗聡脙篓脗篓脗聤
    const dropInfo=t.drop?`<span style="color:var(--teal);font-size:9px;margin-left:4px">脙掳脗聼脗聨脗聛 ${Math.round(t.drop.chance*100)}% ${t.drop.item.icon}${t.drop.item.name}</span>`:'';
    // 脙娄脗聦脗聣脙漏脗聢脗聲脙搂脗聥脗聙脙娄脗聟脗聥
    let btnTxt, btnDis=false;
    if(isDone||isApproved){btnTxt='脙垄脗聹脗聯';btnDis=true;}
    else if(isPending){btnTxt='脙垄脗聫脗鲁脙楼脗炉脗漏脙娄脗聽脗赂脙陇脗赂脗颅';btnDis=true;}
    else if(isDungeonTask){btnTxt=dungDone?'脙漏脗聽脗聵脙楼脗聫脗聳':`${dungProg}/${t.target||3}脙娄脗卢脗隆`;btnDis=!dungDone;}
    else if(isReview){btnTxt='脙掳脗聼脗聯脗陇脙漏脗聙脗聛脙楼脗炉脗漏';}
    else{btnTxt='脙楼脗庐脗聦脙娄脗聢脗聬';}
    const progBar=isDungeonTask?`<div class="task-prog"><div class="bar-bg" style="margin:2px 0"><div class="bar-fill b-blue" style="width:${Math.min(100,dungProg/(t.target||3)*100)}%"></div></div>${dungProg}/${t.target||3} 脙娄脗卢脗隆</div>`:'';
    return `<div class="titem">
      <div class="tico">${t.icon}</div>
      <div class="tinfo">
        <div class="tn">${t.name} ${typeTag}</div>
        <div class="td">${t.desc}</div>
        ${progBar}
        <div class="tr">+${t.coins}脙掳脗聼脗陋脗聶 +${t.exp}EXP${dropInfo}</div>
      </div>
      <button class="tbtn" onclick="doTask('${t.id}')" ${btnDis?'disabled':''}>${btnTxt}</button>
    </div>`;
  }).join('');
  $('weekly-tasks').innerHTML=WEEKLY_TASKS.map(t=>{
    const key=t.id+':'+wk();const isDone=wdone.includes(key);
    let prog=0,progTxt='';
    if(t.type==='daily_count'){prog=wd.daily_count||0;progTxt=prog+'/'+t.target+' 脙楼脗聙脗聥';}
    else if(t.type==='dungeon_count'){prog=wd.dungeon_count||0;progTxt=prog+'/'+t.target+' 脙娄脗卢脗隆';}
    else if(t.type==='steps'){prog=wd.steps||0;progTxt=(prog/1000).toFixed(1)+'/'+(t.target/1000)+'K脙娄脗颅脗楼';}
    else if(t.type==='streak'){prog=hero.streak||0;progTxt=prog+'/'+t.target+' 脙楼脗陇脗漏';}
    else if(t.type==='buy_count'){prog=wd.buy_count||0;progTxt=prog+'/'+t.target+' 脙陇脗禄脗露';}
    const pct=Math.min(100,(prog/t.target)*100);
    const canClaim=prog>=t.target&&!isDone;
    return `<div class="titem">
      <div class="tico">${t.icon}</div>
      <div class="tinfo"><div class="tn">${t.name}</div><div class="td">${t.desc}</div>
        <div class="task-prog"><div class="bar-bg" style="margin:3px 0"><div class="bar-fill b-teal" style="width:${pct}%"></div></div>${progTxt}</div>
        <div class="tr">+${t.coins}脙掳脗聼脗陋脗聶 +${t.exp}EXP</div></div>
      <button class="tbtn" onclick="claimWeekly('${t.id}')" ${!canClaim?'disabled':''}>${isDone?'脙垄脗聹脗聯':canClaim?'脙漏脗聽脗聵脙楼脗聫脗聳':'脙娄脗聹脗陋脙漏脗聛脗聰'}</button>
    </div>`;
  }).join('');
}
async function doTask(id){
  if(!hero)return;
  const key=id+':'+tod();
  const tasks=getDailyTasks();
  const t=tasks.find(x=>x.id===id);if(!t)return;

  // 脙楼脗炉脗漏脙娄脗聽脗赂脙楼脗聻脗聥脙陇脗禄脗禄脙楼脗聥脗聶
  if(t.type==='review'){
    const already=LS.g('task_reviews').some(r=>r.task_id===id&&r.user_id===hero.user_id&&r.date===tod());
    if(already){toast('脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙漏脗聙脗聛脙楼脗聡脗潞脙楼脗炉脗漏脙娄脗聽脗赂');return;}
    LS.ins('task_reviews',{id:'tr_'+Date.now(),user_id:hero.user_id,username:hero.username,avatar:hero.avatar,task_id:id,task_name:t.name,coins:t.coins,exp:t.exp,status:'pending',date:tod(),created_at:new Date().toISOString()});
    toast('脙掳脗聼脗聯脗陇 '+t.name+' 脙楼脗路脗虏脙漏脗聙脗聛脙楼脗聡脗潞脙炉脗录脗聦脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙搂脗垄脗潞脙篓脗陋脗聧');
    renderTasks();return;
  }

  // 脙漏脗聴脗聹脙楼脗聧脗隆脙漏脗聙脗職脙漏脗聴脗聹脙楼脗聻脗聥脙陇脗禄脗禄脙楼脗聥脗聶
  if(t.type==='dungeon_clear'){
    const prog=hero.today_dungeon_clear||0;
    if(prog<(t.target||3)){toast('脙垄脗職脗聰脙炉脗赂脗聫 脙漏脗聜脗聞脙漏脗聹脗聙脙漏脗聙脗職脙漏脗聴脗聹 '+((t.target||3)-prog)+' 脙娄脗卢脗隆');return;}
    if((hero.tasks_done||[]).includes(key)){toast('脙陇脗禄脗聤脙娄脗聴脗楼脙楼脗路脗虏脙漏脗聽脗聵脙楼脗聫脗聳');return;}
    hero.tasks_done=[...(hero.tasks_done||[]),key];
    if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
    hero.week_data.daily_count=(hero.week_data.daily_count||0)+1;
    gainEC(t.exp,t.coins);save();renderTasks();
    toast('脙垄脗職脗聰脙炉脗赂脗聫 脙漏脗聴脗聹脙楼脗聧脗隆脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛+'+t.coins+'脙掳脗聼脗陋脗聶 +'+t.exp+'EXP');
    return;
  }

  // 脙楼脗聟脗卢脙楼脗聭脗聤脙楼脗聻脗聥脙陇脗禄脗禄脙楼脗聥脗聶脙炉脗录脗聢脙篓脗路脗鲁脙篓脗陆脗聣脙楼脗聟脗卢脙楼脗聭脗聤脙娄脗卢脗聞脙炉脗录脗聣
  if(t.type==='notice'){
    gTab('notice');
    toast('脙掳脗聼脗聯脗垄 脙篓脗芦脗聥脙篓脗聡脗鲁脙楼脗聟脗卢脙楼脗聭脗聤脙娄脗卢脗聞脙漏脗聳脗卤脙篓脗庐脗聙脙楼脗聟脗卢脙楼脗聭脗聤脙陇脗赂脗娄脙娄脗篓脗聶脙篓脗篓脗聵脙楼脗路脗虏脙篓脗庐脗聙','info');
    return;
  }

  if((hero.tasks_done||[]).includes(key))return;
  hero.tasks_done=[...(hero.tasks_done||[]),key];
  hero.total_tasks_done=(hero.total_tasks_done||0)+1;
  if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
  hero.week_data.daily_count=(hero.week_data.daily_count||0)+1;
  // wolf lv10+ +2 stamina
  const pet=(hero.equipped||{}).pet;
  let stamBonus=0;
  if(pet&&!pet.isEvolved&&pet.petDefId==='p8'&&(pet.level||1)>=10)stamBonus=2;
  if(pet&&pet.isEvolved&&pet.evolvedFrom==='p8')stamBonus=2;
  if(stamBonus>0)gainStam(stamBonus);
  gainEC(t.exp,t.coins);
  // 脙娄脗聨脗聣脙篓脗聬脗陆脙楼脗聢脗陇脙楼脗庐脗職
  let dropMsg='';
  if(t.drop&&Math.random()<t.drop.chance){
    const dropItem={...t.drop.item,uid:'drop_'+Date.now()+'_'+id};
    hero.inventory=[...(hero.inventory||[]),dropItem];
    dropMsg=' 脙掳脗聼脗聨脗聛 '+dropItem.icon+dropItem.name+'脙炉脗录脗聛';
  }
  save();renderTasks();updInvUI();updTabBadges();
  toast('脙垄脗聹脗聟 '+t.name+' +'+t.coins+'脙掳脗聼脗陋脗聶 +'+t.exp+'EXP'+dropMsg+(stamBonus>0?' 脙垄脗職脗隆+'+stamBonus:''));
  tryLukStam();
}
async function claimWeekly(id){
  if(!hero)return;
  const key=id+':'+wk();
  if((hero.weekly_tasks_done||[]).includes(key))return;
  const t=WEEKLY_TASKS.find(x=>x.id===id);if(!t)return;
  hero.weekly_tasks_done=[...(hero.weekly_tasks_done||[]),key];
  gainEC(t.exp,t.coins);save();renderTasks();
  toast('脙掳脗聼脗聫脗聠 脙漏脗聙脗卤脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛+'+t.coins+'脙掳脗聼脗陋脗聶 +'+t.exp+'EXP');
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 DUNGEON 脙垄脗聲脗聬脙垄脗聲脗聬
function renderDungeons(){
  if(!hero)return;
  const done=hero.dungeons_done||[];
  const diffN=['','脙娄脗聳脗掳脙娄脗聣脗聥','脙娄脗聶脗庐脙漏脗聙脗職','脙楼脗聸脗掳脙漏脗聸脗拢','脙篓脗聫脗聛脙篓脗聥脗卤','脙楼脗聜脗鲁脙篓脗陋脗陋'];
  const keyN={str:'ATK脙楼脗聻脗聥',def:'DEF脙楼脗聻脗聥',spd:'SPD脙楼脗聻脗聥',hp:'HP脙楼脗聻脗聥'};
  const now=Date.now();
  $('dung-list').innerHTML=DUNGEONS.map(d=>{
    const isDone=done.includes(d.id);
    const canEnter=hero.level>=d.reqLv;
    const wr=calcWR(d,hero);const wrPct=Math.round(wr*100);
    const wrCol=wrPct>=65?'var(--green)':wrPct>=40?'var(--gold)':wrPct>=25?'var(--purple)':'var(--red)';
    const pen=calcPenalty(d,hero);
    const failKey='fail_cd_'+d.id;
    const cdEnd=(hero[failKey]||0);
    const onCd=cdEnd>now;
    const cdMin=onCd?Math.ceil((cdEnd-now)/60000):0;
    const canFight=canEnter&&(!isDone||d.repeat)&&!onCd;
    const stamCost=d.stamCost||([0,2,3,4,5,6][+d.diff]||3);
    const repeatTag=d.repeat?'<span style="font-size:9px;color:var(--teal)">脙垄脗聶脗禄脙炉脗赂脗聫脙楼脗聫脗炉脙漏脗聡脗聧脙篓脗陇脗聡</span>':'';
    // 脙漏脗芦脗聵脙漏脗聡脗聭脙楼脗鹿脗拢脙漏脗聴脗聹脙楼脗聧脗隆脙搂脗聣脗鹿脙娄脗庐脗聤脙漏脗隆脗炉脙搂脗陇脗潞
    const goldTag=d.goldRun?'<span style="font-size:9px;font-weight:700;color:#ffd700;background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.4);border-radius:5px;padding:1px 6px">脙掳脗聼脗聮脗掳 脙漏脗芦脗聵脙漏脗聡脗聭脙楼脗鹿脗拢</span>':'';
    const rewardTxt=d.goldRun?`+${d.coins}脙掳脗聼脗陋脗聶 <span style="font-size:9px;color:var(--muted)">脙搂脗聞脗隆EXP</span>`:`+${d.coins}脙掳脗聼脗陋脗聶 +${d.exp}EXP`;
    const borderStyle=d.goldRun?'border:1px solid rgba(255,215,0,.4);background:linear-gradient(135deg,#2e2810,#1a1410);':'';
    return `<div class="ditem d${d.diff}" style="${borderStyle}">
      <div class="dmeta">
        <span class="dbadge db${d.diff}">${diffN[d.diff]}</span>
        <span class="dbadge" style="background:#111;border:1px solid #333;color:var(--muted);font-size:9px">${keyN[d.key]}</span>
        ${repeatTag}${goldTag}
      </div>
      <h3 style="${d.goldRun?'color:#ffd700':''}">${d.name}</h3><div class="dsub">${d.desc}</div>
      <div class="req-row" style="display:flex;gap:5px;margin-bottom:7px;flex-wrap:wrap">
        <div style="font-size:10px;padding:2px 7px;background:#111;border-radius:6px;color:${canEnter?'var(--green)':'var(--red)'}">Lv.${d.reqLv}+ ${canEnter?'脙垄脗聹脗聯':'脙垄脗聹脗聴'}</div>
        <div style="font-size:10px;padding:2px 7px;background:#111;border-radius:6px;color:var(--red)">脙楼脗陇脗卤脙娄脗聲脗聴 -${pen}脙掳脗聼脗陋脗聶</div>
      </div>
      <div class="wr-wrap">
        <span class="wr-lbl">脙楼脗聥脗聺脙搂脗聨脗聡</span>
        <div class="wr-bar"><div class="wr-fill" style="width:${wrPct}%;background:${wrCol}"></div></div>
        <span class="wr-lbl" style="color:${wrCol};font-weight:700">${wrPct}%</span>
      </div>
      <div class="dfooter">
        <button class="fight-btn" style="${d.goldRun?'border-color:#ffd700;color:#ffd700':''}" onclick="fightDung('${d.id}')" ${!canFight?'disabled':''}>${isDone&&!d.repeat?'脙垄脗聹脗聟 脙楼脗路脗虏脙漏脗聙脗職脙漏脗聴脗聹':'脙垄脗職脗聰脙炉脗赂脗聫 脙楼脗聡脗潞脙娄脗聢脗掳 -'+stamCost+'脙垄脗職脗隆'}</button>
        <div class="dreward">${rewardTxt}</div>
      </div>
      ${onCd?`<div class="cooldown-txt">脙垄脗聺脗聞脙炉脗赂脗聫 脙漏脗聙脗拢脙娄脗聲脗聴脙楼脗聠脗路脙楼脗聧脗禄脙陇脗赂脗颅脙炉脗录脗聦脙楼脗聣脗漏 ${cdMin} 脙楼脗聢脗聠脙漏脗聬脗聵</div>`:''}
      <div class="blog" id="bl-${d.id}"></div>
    </div>`;
  }).join('');
}
async function fightDung(id){
  if(!hero)return;
  const d=DUNGEONS.find(x=>x.id===id);if(!d)return;
  const done=hero.dungeons_done||[];
  if(done.includes(id)&&!d.repeat)return;
  // stamina check 脙垄脗聙脗聰 cost by difficulty
  const stamCost=[0,2,3,4,5,6][+d.diff]||3;
  const curStam=getStamNow(hero);
  if(curStam<stamCost){toast('脙垄脗職脗隆 脙漏脗芦脗聰脙楼脗聤脗聸脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙脙篓脗娄脗聛 '+stamCost+' 脙漏脗禄脗聻脙炉脗录脗聦脙搂脗聸脗庐脙楼脗聣脗聧 '+Math.floor(curStam)+' 脙漏脗禄脗聻');return;}
  consumeStam(stamCost);
  const wr=calcWR(d,hero);
  const win=Math.random()<wr;
  const blog=$('bl-'+id);
  const keyN={str:'脙娄脗聰脗禄脙娄脗聯脗聤',def:'脙漏脗聵脗虏脙搂脗娄脗娄',spd:'脙漏脗聙脗聼脙楼脗潞脗娄',hp:'脙搂脗聰脗聼脙楼脗聭脗陆'};
  const key=keyN[d.key];
  // week dungeon count
  if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
  hero.week_data.dungeon_count=(hero.week_data.dungeon_count||0)+1;
  if(win){
    if(!done.includes(id))hero.dungeons_done=[...done,id];
    // 脙陇脗禄脗聤脙娄脗聴脗楼脙漏脗聙脗職脙漏脗聴脗聹脙篓脗篓脗聢脙娄脗聲脗赂脙炉脗录脗聢脙搂脗碌脗娄脙陇脗禄脗禄脙楼脗聥脗聶d4脙搂脗聰脗篓脙炉脗录脗聣
    if(!hero.today_dungeon_clear_date||hero.today_dungeon_clear_date!==tod()){hero.today_dungeon_clear=0;hero.today_dungeon_clear_date=tod();}
    hero.today_dungeon_clear=(hero.today_dungeon_clear||0)+1;
    // reset fail count
    hero['fail_cd_'+id]=0;
    hero['fail_cnt_'+id]=0;
    const bonus=hero.hero_class==='ranger'?1.15:1;
    // 脙漏脗芦脗聵脙漏脗聡脗聭脙楼脗鹿脗拢脙漏脗聴脗聹脙楼脗聧脗隆脙炉脗录脗職EXP=0
    const expGain=d.goldRun?0:Math.round(d.exp*bonus);
    gainEC(expGain,Math.round(d.coins*bonus));
    if(blog){blog.textContent=`脙掳脗聼脗聫脗聠 脙楼脗聥脗聺脙楼脗聢脗漏脙炉脗录脗聛${key}脙楼脗聙脗录脙搂脗聶脗录脙娄脗聫脗庐脙漏脗聴脗聹脙漏脗聧脗碌脙陇脗陆脗聹脙搂脗聰脗篓脙炉脗录脗聦脙漏脗聙脗職脙漏脗聴脗聹 ${d.name}脙炉脗录脗聛`;blog.className='blog show';}
    save();renderDungeons();
    toast('脙掳脗聼脗聫脗聠 脙漏脗聙脗職脙漏脗聴脗聹脙炉脗录脗聛+'+Math.round(d.coins*bonus)+'脙掳脗聼脗陋脗聶');
    tryLukStam();
  } else {
    const pen=calcPenalty(d,hero);
    hero.coins=Math.max(0,(hero.coins||0)-pen);
    // fail counter for cooldown
    hero['fail_cnt_'+id]=(hero['fail_cnt_'+id]||0)+1;
    if(hero.hero_class==='monk'){
      if(!hero.monk_att)hero.monk_att={};
      hero.monk_att[id]=(hero.monk_att[id]||0)+1;
    }
    let cdMsg='';
    if(hero['fail_cnt_'+id]>=3){
      hero['fail_cd_'+id]=Date.now()+24*60*60*1000;
      hero['fail_cnt_'+id]=0;
      cdMsg='脙垄脗職脗聽脙炉脗赂脗聫 脙漏脗聙脗拢脙娄脗聲脗聴3脙娄脗卢脗隆脙炉脗录脗聛脙漏脗聙脗虏脙楼脗聟脗楼24脙楼脗掳脗聫脙娄脗聶脗聜脙楼脗聠脗路脙楼脗聧脗禄脙拢脗聙脗聜';
    }
    if(blog){
      blog.textContent=`脙掳脗聼脗聮脗聙 脙楼脗陇脗卤脙娄脗聲脗聴脙炉脗录脗聛${key}脙楼脗聙脗录脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聦脙娄脗聬脗聧脙楼脗陇脗卤 ${pen}脙掳脗聼脗陋脗聶脙拢脗聙脗聜${cdMsg}`;
      blog.className='blog show fail';
    }
    save();updCoins();renderDungeons();
    toast('脙掳脗聼脗聮脗聙 脙楼脗陇脗卤脙娄脗聲脗聴脙炉脗录脗聦脙娄脗聣脗拢脙漏脗聶脗陇 '+pen+'脙掳脗聼脗陋脗聶');
  }
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 SHOP 脙垄脗聲脗聬脙垄脗聲脗聬
function switchShop(t){
  shopTab=t;
  document.querySelectorAll('.stab').forEach((e,i)=>e.classList.toggle('active',['equip','costume','pet','luck'][i]===t));
  $('sh-equip').style.display=t==='equip'?'block':'none';
  $('sh-costume').style.display=t==='costume'?'block':'none';
  $('sh-pet').style.display=t==='pet'?'block':'none';
  $('sh-luck').style.display=t==='luck'?'block':'none';
  if(t==='luck')renderShopLuck();
}
function renderShopEquip(){
  const inv=hero?.inventory||[];
  const lv=hero?.level||1;
  const tN={1:'脙楼脗聼脗潞脙搂脗陇脗聨',2:'脙漏脗聙脗虏脙漏脗職脗聨',3:'脙搂脗虏脗戮脙篓脗聣脗炉',4:'脙搂脗篓脗聙脙娄脗聹脗聣',5:'脙楼脗聜脗鲁脙篓脗陋脗陋'};
  const sN={weapon:'脙垄脗職脗聰脙炉脗赂脗聫 脙娄脗颅脗娄脙楼脗聶脗篓',armor:'脙掳脗聼脗聸脗隆脙炉脗赂脗聫 脙漏脗聵脗虏脙楼脗聟脗路',acc:'脙掳脗聼脗聮脗聧 脙漏脗拢脗戮脙楼脗聯脗聛',boot:'脙掳脗聼脗聭脗聼 脙漏脗聻脗聥脙漏脗聺脗麓'};
  const slots=['weapon','armor','acc','boot'];
  let html='';
  slots.forEach(slot=>{
    const items=EQUIP_ITEMS.filter(it=>it.slot===slot&&(!it.rarity||it.rarity<4));
    if(!items.length)return;
    html+=`<div style="font-size:11px;color:var(--muted);margin:8px 0 5px;border-bottom:1px solid var(--border);padding-bottom:3px">${sN[slot]}</div><div class="shop-g">`;
    html+=items.sort((a,b)=>(a.price||0)-(b.price||0)).map(it=>{
      const owned=inv.some(x=>x.id===it.id&&!x.uid);
      const locked=(it.reqLv||1)>lv;
      const stamTag=it.stam_up?`<span style="color:var(--teal);font-size:9px">脙垄脗職脗隆+${it.stam_up}</span>`:'';
      const tierTag=it.tier?`<span style="font-size:8px;padding:1px 4px;border-radius:4px;background:rgba(201,162,39,.15);color:var(--muted)">${tN[it.tier]||''}</span>`:'';
      return `<div class="sitem${locked?' locked-item':''}">
        <div class="sico">${it.icon}</div>
        <div class="sn">${it.name} ${tierTag}</div>
        <div class="sd">${it.desc} ${stamTag}${locked?`<div style="color:var(--red);font-size:9px;margin-top:2px">脙掳脗聼脗聰脗聮 脙漏脗聹脗聙Lv.${it.reqLv}</div>`:''}</div>
        <div class="sp gp">${it.price.toLocaleString()}脙掳脗聼脗陋脗聶</div>
        <button class="bbtn" onclick="buyEquip('${it.id}')" ${owned||locked?'disabled':''}>${owned?'脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣':locked?'脙娄脗聹脗陋脙篓脗搂脗拢脙漏脗聨脗聳':'脙篓脗鲁脗录脙篓脗虏脗路'}</button>
      </div>`;
    }).join('');
    html+='</div>';
  });
  $('sh-eq-g').innerHTML=html;
}
function renderShopCostume(){
  const inv=hero?.inventory||[];
  const lv=hero?.level||1;
  const BASE_BONUS={head:'SPD+8',body:'DEF+10',back:'EXP+5%脙拢脗聝脗禄脙漏脗聡脗聭脙楼脗鹿脗拢+5%'};
  const SPECIAL={'脙搂脗職脗聡脙楼脗聠脗聽':'ATK+5脙拢脗聝脗禄DEF+5','脙楼脗庐脗聡脙楼脗庐脗聶脙娄脗聢脗掳脙篓脗垄脗聧':'SPD+15脙拢脗聝脗禄DEF+15','脙搂脗楼脗聻脙楼脗聼脗聼脙娄脗聤脗芦脙漏脗垄脗篓':'SPD+20脙拢脗聝脗禄脙漏脗聡脗聭脙楼脗鹿脗拢+10%','脙搂脗楼脗聻脙漏脗戮脗聧脙娄脗聢脗掳脙搂脗聰脗虏':'ATK+12脙拢脗聝脗禄DEF+12','脙搂脗聝脗聢脙搂脗聞脗掳脙娄脗聢脗掳脙篓脗垄脗聧':'ATK+10','脙娄脗聹脗聢脙篓脗聫脗炉脙篓脗垄脗聧':'SPD+12脙拢脗聝脗禄脙漏脗聡脗聭脙楼脗鹿脗拢+6%','脙篓脗聺脗麓脙篓脗聺脗露脙搂脗驴脗聟脙篓脗聠脗聙':'HP+20脙拢脗聝脗禄EXP+6%','脙楼脗陇脗漏脙陇脗陆脗驴脙搂脗驴脗聟脙篓脗聠脗聙':'HP+30脙拢脗聝脗禄EXP+10%','脙娄脗聝脗隆脙漏脗颅脗聰脙搂脗驴脗聟脙篓脗聠脗聙':'ATK+8脙拢脗聝脗禄SPD+6','脙娄脗聵脗聼脙楼脗聟脗聣脙搂脗聣脗鹿脙娄脗聲脗聢':'SPD+15脙拢脗聝脗禄脙漏脗聡脗聭脙楼脗鹿脗拢+10%','脙篓脗聶脗聸脙搂脗漏脗潞脙娄脗聳脗聴脙搂脗炉脗路':'SPD+18脙拢脗聝脗禄脙漏脗聡脗聭脙楼脗鹿脗拢+12%','脙漏脗聭脗陆脙搂脗聼脗鲁脙漏脗聺脗垄脙搂脗聰脗虏':'DEF+15脙拢脗聝脗禄EXP+12%','脙娄脗聵脗聼脙搂脗楼脗聻脙楼脗聠脗聽':'SPD+14脙拢脗聝脗禄EXP+12%'};
  const slotOrder=['head','body','back'];
  const slotN={head:'脙掳脗聼脗聭脗聮 脙漏脗聽脗颅脙漏脗拢脗戮',body:'脙掳脗聼脗搂脗楼 脙篓脗隆脗拢脙篓脗拢脗聺',back:'脙掳脗聼脗娄脗聥 脙篓脗聝脗聦脙漏脗拢脗戮'};
  let html='';
  slotOrder.forEach(slot=>{
    const items=COSTUME_SHOP.filter(it=>it.slot===slot).sort((a,b)=>(a.price||0)-(b.price||0));
    html+=`<div style="font-size:11px;color:var(--muted);margin:8px 0 5px;border-bottom:1px solid var(--border);padding-bottom:3px">${slotN[slot]}</div><div class="shop-g">`;
    html+=items.map(it=>{
      const owned=inv.some(x=>x.id===it.id&&!x.uid);
      const locked=(it.reqLv||1)>lv;
      const baseB=BASE_BONUS[slot]||'';
      const spB=SPECIAL[it.name]||'';
      return `<div class="sitem cos${locked?' locked-item':''}">
        <div class="sico" style="filter:drop-shadow(0 0 5px ${it.color}88);${locked?'opacity:.45':''}">${it.icon}</div>
        <div class="sn">${it.name}</div>
        <div class="sd">${it.desc}
          <div style="color:var(--teal);font-size:9px">${baseB}${spB?' 脙聜脗路 '+spB:''}</div>
          ${locked?`<div style="color:var(--red);font-size:9px">脙掳脗聼脗聰脗聮 脙漏脗聹脗聙Lv.${it.reqLv||1}</div>`:''}
        </div>
        <div class="sp pp">${it.price.toLocaleString()}脙掳脗聼脗陋脗聶</div>
        <button class="bbtn pb" onclick="buyCos('${it.id}')" ${owned||locked?'disabled':''}>${owned?'脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣':locked?'脙娄脗聹脗陋脙篓脗搂脗拢脙漏脗聨脗聳':'脙篓脗鲁脗录脙篓脗虏脗路'}</button>
      </div>`;
    }).join('');
    html+='</div>';
  });
  $('sh-cos-g').innerHTML=html;
}
function renderShopPet(){
  const inv=hero?.inventory||[];
  const lv=hero?.level||1;
  const rarN={1:'脙垄脗颅脗聬 1脙娄脗聵脗聼',2:'脙垄脗颅脗聬脙垄脗颅脗聬 2脙娄脗聵脗聼'};
  const groups={1:[],2:[]};
  SHOP_PETS.forEach(sp=>{const pd=PET_DEF.find(p=>p.id===sp.id);if(pd)groups[pd.stars]?.push({sp,pd});});
  let html='';
  [1,2].forEach(star=>{
    const items=(groups[star]||[]).sort((a,b)=>(a.sp.price||0)-(b.sp.price||0));
    if(!items.length)return;
    html+=`<div style="font-size:11px;color:var(--muted);margin:8px 0 5px;border-bottom:1px solid var(--border);padding-bottom:3px">${rarN[star]}</div><div class="shop-g">`;
    html+=items.map(({sp,pd})=>{
      const owned=inv.some(x=>x.petDefId===sp.id);
      const locked=(sp.reqLv||1)>lv;
      const rarCol={1:'var(--blue)',2:'var(--purple)'}[pd.stars]||'var(--muted)';
      return `<div class="sitem pet-item${locked?' locked-item':''}">
        <div class="sico" style="${locked?'opacity:.45':''}">${pd.icon}</div>
        <div class="sn" style="color:${rarCol}">${pd.name}</div>
        <div class="sd">${pd.desc}${locked?`<div style="color:var(--red);font-size:9px">脙掳脗聼脗聰脗聮 脙漏脗聹脗聙Lv.${sp.reqLv||1}</div>`:''}</div>
        <div class="sp tp">${sp.price.toLocaleString()}脙掳脗聼脗陋脗聶</div>
        <button class="bbtn tb" onclick="buyPet('${sp.id}')" ${owned||locked?'disabled':''}>${owned?'脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣':locked?'脙娄脗聹脗陋脙篓脗搂脗拢脙漏脗聨脗聳':'脙篓脗鲁脗录脙篓脗虏脗路'}</button>
      </div>`;
    }).join('');
    html+='</div>';
  });
  $('sh-pet-g').innerHTML=html;
}
async function buyEquip(id){
  const it=EQUIP_ITEMS.find(x=>x.id===id);if(!it)return;
  if((hero.inventory||[]).some(x=>x.id===id&&!x.uid)){toast('脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣');return;}
  if(hero.coins<it.price){toast('脙漏脗聡脗聭脙楼脗鹿脗拢脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙 '+it.price+'脙掳脗聼脗陋脗聶');return;}
  hero.coins-=it.price;hero.inventory=[...(hero.inventory||[]),{...it}];
  if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
  hero.week_data.buy_count=(hero.week_data.buy_count||0)+1;
  save();renderShopEquip();updCoins();updInvUI();
  toast('脙掳脗聼脗聸脗聮 脙篓脗鲁脗录脙篓脗虏脗路 '+it.name);
}
async function buyCos(id){
  const it=COSTUME_SHOP.find(x=>x.id===id);if(!it)return;
  if((hero.inventory||[]).some(x=>x.id===id&&!x.uid)){toast('脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣');return;}
  if(hero.coins<it.price){toast('脙漏脗聡脗聭脙楼脗鹿脗拢脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙 '+it.price+'脙掳脗聼脗陋脗聶');return;}
  hero.coins-=it.price;hero.inventory=[...(hero.inventory||[]),{...it,type:'costume'}];
  if(!hero.week_data)hero.week_data={week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0};
  hero.week_data.buy_count=(hero.week_data.buy_count||0)+1;
  save();renderShopCostume();updCoins();updInvUI();
  toast('脙掳脗聼脗聭脗聮 脙篓脗鲁脗录脙篓脗虏脗路 '+it.name+'脙炉脗录脗聛脙楼脗聣脗聧脙楼脗戮脗聙脙篓脗聥脗卤脙漏脗聸脗聞脙漏脗聽脗聛脙篓脗拢脗聺脙楼脗聜脗聶');
}
async function buyPet(id){
  const pd=PET_DEF.find(p=>p.id===id);const sp=SHOP_PETS.find(p=>p.id===id);
  if(!pd||!sp)return;
  if((hero.inventory||[]).some(x=>x.petDefId===id)){toast('脙楼脗路脗虏脙娄脗聯脗聛脙娄脗聹脗聣脙娄脗颅脗陇脙楼脗炉脗碌脙搂脗聣脗漏');return;}
  if(hero.coins<sp.price){toast('脙漏脗聡脗聭脙楼脗鹿脗拢脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙 '+sp.price+'脙掳脗聼脗陋脗聶');return;}
  hero.coins-=sp.price;
  const petItem={id:'pet_'+id+'_'+Date.now(),petDefId:id,name:pd.name,icon:pd.icon,level:1,exp:0,slot:'pet',uid:'pet_'+Date.now()};
  hero.inventory=[...(hero.inventory||[]),petItem];
  save();renderShopPet();updCoins();updInvUI();renderPets();
  toast('脙掳脗聼脗聬脗戮 脙篓脗鲁脗录脙篓脗虏脗路 '+pd.name+'脙炉脗录脗聛');
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 GACHA 脙垄脗聲脗聬脙垄脗聲脗聬
function switchPool(p){
  curPool=p;
  document.querySelectorAll('.ptab').forEach((e,i)=>e.classList.toggle('active',['weapon','costume','pet','mixed'][i]===p));
  renderGachaBanner();updPity();
}
function renderGachaBanner(){
  const pool=GACHA_POOLS[curPool];if(!pool)return;
  const r=pool.rates;
  const sc={4:'#ff6b9d',3:'#f0d060',2:'var(--purple)',1:'var(--blue)'};
  const sl={4:'脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼 脙篓脗露脗聟脙搂脗篓脗聙脙娄脗聹脗聣',3:'脙垄脗颅脗聬脙垄脗颅脗聬脙垄脗颅脗聬 脙楼脗聜脗鲁脙篓脗陋脗陋',2:'脙垄脗颅脗聬脙垄脗颅脗聬 脙搂脗篓脗聙脙娄脗聹脗聣',1:'脙垄脗颅脗聬 脙娄脗聶脗庐脙漏脗聙脗職'};
  const byR={4:[],3:[],2:[],1:[]};
  pool.pool.forEach(it=>{if(byR[it.r])byR[it.r].push(it);});
  let tbl='';
  [4,3,2,1].forEach(rar=>{
    const its=byR[rar];if(!its.length)return;
    const pct=((r[rar]||0)*100)+'%';
    tbl+=`<div class="rate-section">
      <div class="rate-sec-head">
        <span style="font-size:11px;font-weight:700;color:${sc[rar]}">${sl[rar]}</span>
        <span style="font-size:10px;padding:1px 7px;border-radius:7px;background:rgba(0,0,0,.3);border:1px solid ${sc[rar]}55;color:${sc[rar]}">${pct}</span>
      </div>
      <div class="rate-items-wrap">${its.map(it=>`<div class="rcard" style="border:1px solid ${sc[rar]}33${rar===4?';background:rgba(255,107,157,.08)':''}"><span>${it.icon}</span><span style="color:var(--text)">${it.name}</span></div>`).join('')}</div>
    </div>`;
  });
  $('gbanner').innerHTML=`<div class="gbanner ${pool.cls}" style="text-align:left">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <h2 style="color:${pool.color}">${pool.name}</h2>
      <span style="font-size:9px;color:var(--muted)">90脙娄脗聤脗陆脙陇脗驴脗聺脙楼脗潞脗聲脙垄脗颅脗聬脙垄脗颅脗聬脙垄脗颅脗聬 脙聜脗路 180脙娄脗聤脗陆脙陇脗驴脗聺脙楼脗潞脗聲脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼</span>
    </div>${tbl}</div>`;
}
function updPity(){
  const k=curPool;const cnt=(hero?.pity||{})[k]||0;
  $('pity-cnt').textContent=cnt+'/180';
  $('pity-bar').style.width=Math.min(100,cnt/180*100)+'%';
}
async function doGacha(count){
  if(!hero)return;
  const cost=count===1?100:900;
  if(hero.coins<cost){toast('脙漏脗聡脗聭脙楼脗鹿脗拢脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙 '+cost+'脙掳脗聼脗陋脗聶');return;}
  hero.coins-=cost;
  const pool=GACHA_POOLS[curPool];if(!pool)return;
  if(!hero.pity)hero.pity={weapon:0,costume:0,pet:0,mixed:0};
  const results=[];
  const existNames=new Set((hero.inventory||[]).map(x=>x.name));
  for(let i=0;i<count;i++){
    hero.pity[curPool]=(hero.pity[curPool]||0)+1;
    const rnd=Math.random();
    const isG10=count===10&&i===count-1&&!results.some(x=>x.r>=2);
    const isPity=hero.pity[curPool]>=90;  // 90脙娄脗聤脗陆脙陇脗驴脗聺脙楼脗潞脗聲脙楼脗聜脗鲁脙篓脗陋脗陋
    const isPity4=hero.pity[curPool]>=180; // 180脙娄脗聤脗陆脙陇脗驴脗聺脙楼脗潞脗聲脙篓脗露脗聟脙搂脗篓脗聙脙娄脗聹脗聣
    let rar;
    if(isPity4||rnd<(pool.rates[4]||0.01)){rar=4;hero.pity[curPool]=0;}
    else if(isPity||rnd<(pool.rates[4]||0.01)+(pool.rates[3]||0.04)){rar=3;if(isPity)hero.pity[curPool]=0;}
    else if(isG10||rnd<(pool.rates[4]||0.01)+(pool.rates[3]||0.04)+(pool.rates[2]||0.15))rar=2;
    else rar=1;
    const cands=pool.pool.filter(x=>x.r===rar);
    const picked={...cands[Math.floor(Math.random()*cands.length)],uid:'g'+Date.now()+'_'+i};
    // convert pet pool item
    if(picked.petId){
      const pd=PET_DEF.find(p=>p.id===picked.petId);
      if(pd){
        picked.petDefId=picked.petId;
        picked.name=pd.name;picked.icon=pd.icon;picked.slot='pet';picked.level=1;picked.exp=0;
      }
    }
    picked._isNew=!existNames.has(picked.name);
    results.push(picked);
    hero.inventory=[...(hero.inventory||[]),picked];
  }
  $('res-grid').innerHTML=results.map(r=>{
    const cls=r.r===4?'s4':r.r===3?'s3':r.r===2?'s2':'s1';
    return `<div class="rcard2 ${cls}${r._isNew?' snew':''}"><div class="ri">${r.icon}</div><div class="rn">${r.name}</div><div style="font-size:8px;margin-top:1px">${r.r===4?'脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼脙掳脗聼脗聦脗聼':'脙垄脗颅脗聬'.repeat(r.r)}</div></div>`;
  }).join('');
  $('gacha-res').style.display='block';
  save();updCoins();updPity();updInvUI();renderPets();
  const s4=results.filter(x=>x.r===4);
  const s3=results.filter(x=>x.r===3);
  if(s4.length)toast('脙掳脗聼脗聦脗聼 脙篓脗露脗聟脙搂脗篓脗聙脙娄脗聹脗聣脙炉脗录脗聛'+s4.map(x=>x.name).join('脙拢脗聙脗聛')+'脙炉脗录脗聛脙炉脗录脗聛');
  else if(s3.length)toast('脙垄脗聹脗篓 脙楼脗聜脗鲁脙篓脗陋脗陋脙炉脗录脗聛'+s3.map(x=>x.name).join('脙拢脗聙脗聛'));
  else toast('脙垄脗聹脗篓 脙娄脗聤脗陆脙楼脗聧脗隆脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛');
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 PET 脙垄脗聲脗聬脙垄脗聲脗聬
function getPetSkillsUnlocked(pet, pd){
  const lv=pet.level||1;
  const skills=pd.skills||[];
  return skills.filter(s=>lv>=s.lv);
}
function renderPets(){
  if(!hero)return;
  const inv=hero.inventory||[];
  const pets=inv.filter(x=>x.petDefId);
  const el=$('pet-list');
  if(!pets.length){el.innerHTML='<div class="no-pet">脙楼脗掳脗職脙搂脗聞脗隆脙楼脗炉脗碌脙搂脗聣脗漏<br>脙楼脗聣脗聧脙楼脗戮脗聙脙楼脗聲脗聠脙楼脗潞脗聴脙篓脗鲁脗录脙篓脗虏脗路脙娄脗聢脗聳脙娄脗聤脗陆脙楼脗聧脗隆脙搂脗聧脗虏脙楼脗戮脗聴</div>';return;}
  el.innerHTML=pets.map((pet)=>{
    const ri=inv.indexOf(pet);
    const isEvolved=pet.isEvolved;
    const pd=isEvolved?PET_EVOLVED[pet.evoId]:PET_DEF.find(p=>p.id===pet.petDefId);
    if(!pd)return'';
    const basedef=PET_DEF.find(p=>p.id===pet.petDefId);
    const lv=pet.level||1;
    const maxLv=isEvolved?(PET_EVOLVED[pet.evoId]?.maxLv||20):(basedef?.maxLv||15);
    const needExp=Math.round((lv*60)*(isEvolved?1.8:1));
    const petExp=pet.exp||0;
    const pct=Math.min(100,(petExp/needExp)*100);
    const isEq=(hero.equipped||{}).pet&&((hero.equipped.pet.uid||hero.equipped.pet.id)===(pet.uid||pet.id));
    const bonus=getPetBonus(pet);
    const bonusTxt=Object.entries(bonus).map(([k,v])=>({hp:'HP',str:'ATK',def:'DEF',spd:'SPD'}[k]+'+'+v)).join('脙拢脗聙脗聛');
    const stars=isEvolved?(pd.stars||3):(basedef?.stars||1);
    const starStr='脙垄脗颅脗聬'.repeat(Math.min(stars,4));
    const rarCol=stars>=4?'#ff6b9d':stars>=3?'#f0d060':stars>=2?'var(--purple)':'var(--blue)';
    const cardCls='pet-card'+(isEvolved?stars>=4?' evolved-r3':' evolved-r2':'');
    const glowStyle=isEvolved&&pd.glowColor?`box-shadow:0 0 15px ${pd.glowColor};`:'';

    // skills unlocked
    const skills=isEvolved?(pd.skills||[]):(getPetSkillsUnlocked(pet,basedef||{}));
    const skillHtml=skills.map(s=>`<div class="pet-skill s${s.tier}"><div class="sk-name">${s.name}</div><div class="sk-desc">${s.desc}</div></div>`).join('');

    // milestones
    const msHtml=basedef?.milestones?`<div class="lv-milestone">${basedef.milestones.map(ms=>{
      const sCls=ms.lv>=15?'s3':ms.lv>=10?'s2':'';
      return `<div class="lv-ms ${lv>=ms.lv?'reached':''} ${sCls}"><div class="ms-lv">Lv.${ms.lv}</div><div class="ms-reward" style="color:${lv>=ms.lv?'var(--teal)':'var(--muted)'}">${ms.txt}</div></div>`;
    }).join('')}</div>`:'';

    // evolve button 脙垄脗聙脗聰 need 2 same name pets, base at max lv
    const sameNamePets=inv.filter(x=>x.petDefId===pet.petDefId&&!x.isEvolved);
    const canEvolve=!isEvolved&&lv>=maxLv&&sameNamePets.length>=2;
    const evolveHtml=!isEvolved?`
      <button class="evolve-btn" onclick="evolvePet('${pet.uid||pet.id}')" ${!canEvolve?'disabled':''}>
        ${canEvolve?'脙垄脗聹脗篓 脙漏脗聙脗虏脙楼脗聦脗聳脙炉脗录脗聛脙炉脗录脗聢脙娄脗露脗聢脙篓脗聙脗聴2脙漏脗職脗禄脙炉脗录脗聣':'脙漏脗聙脗虏脙楼脗聦脗聳脙漏脗聹脗聙脙篓脗娄脗聛脙炉脗录脗職脙楼脗聬脗聦脙楼脗聬脗聧脙聝脗聴2 + Lv.'+maxLv+' ('+sameNamePets.length+'/2)'}
      </button>
      <div class="merge-hint">${sameNamePets.length>=2?'脙垄脗聹脗聟 脙楼脗路脗虏脙娄脗聹脗聣'+sameNamePets.length+'脙漏脗職脗禄脙楼脗聫脗炉脙漏脗聙脗虏脙楼脗聦脗聳':'脙漏脗聜脗聞脙漏脗聹脗聙 '+(2-sameNamePets.length)+' 脙漏脗職脗禄脙楼脗聬脗聦脙楼脗聬脗聧脙楼脗炉脗碌脙搂脗聣脗漏'}</div>`:'<div style="text-align:center;font-size:11px;color:var(--gold);margin-top:6px">脙垄脗聹脗篓 脙楼脗路脗虏脙漏脗聙脗虏脙楼脗聦脗聳 脙垄脗聙脗聰 脙搂脗碌脗聜脙娄脗楼脗碌脙楼脗陆脗垄脙娄脗聟脗聥</div>';

    return `<div class="${cardCls}" style="${glowStyle}">
      <div class="pet-top">
        <div class="pet-ava" style="border-color:${rarCol};font-size:${isEvolved?'22':'28'}px">${pet.icon||pd.icon}</div>
        <div class="pet-info">
          <h4 style="color:${rarCol}">${pet.name||pd.name} ${starStr}</h4>
          <div class="ptype">${pd.desc||''}</div>
          <span class="pet-lv-badge" style="background:${rarCol};color:#111">Lv.${lv}/${maxLv}</span>
          <div class="pet-bonus" style="margin-top:4px">${isEq?'脙垄脗聹脗聟 脙陇脗赂脗聤脙漏脗聶脗拢脙陇脗赂脗颅 脙垄脗聙脗聰 ':''}<span style="color:var(--teal)">${bonusTxt}</span></div>
        </div>
      </div>
      <div class="pet-exp-wrap" style="margin-top:8px">
        <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:3px"><span>EXP</span><span>${petExp}/${needExp}</span></div>
        <div class="bar-bg"><div class="bar-fill ${isEvolved?'b-gold':'b-teal'}" style="width:${pct}%"></div></div>
      </div>
      ${msHtml}
      ${skillHtml}
      <div style="display:flex;gap:6px;margin-top:8px">
        <button class="pet-feed-btn" onclick="feedPet(${ri})" style="flex:1">脙掳脗聼脗聧脗聳 脙漏脗陇脗碌脙漏脗拢脗聼 (-${isEvolved?pd.feedCost||60:(basedef?.feedCost||30)}脙掳脗聼脗陋脗聶 +EXP)</button>
        <button onclick="equipItem(${ri})" style="flex:0.6;padding:8px;background:transparent;border:1px solid ${isEq?'var(--green)':rarCol};color:${isEq?'var(--green)':rarCol};border-radius:7px;cursor:pointer;font-size:11px;font-family:inherit;font-weight:700">${isEq?'脙楼脗聧脗赂脙陇脗赂脗聥':'脙陇脗赂脗聤脙漏脗聶脗拢'}</button>
      </div>
      ${evolveHtml}
    </div>`;
  }).join('');
}

async function feedPet(i){
  const pet=(hero.inventory||[])[i];if(!pet||!pet.petDefId)return;
  const isEvo=pet.isEvolved;
  const basedef=PET_DEF.find(p=>p.id===pet.petDefId);
  const lv=pet.level||1;
  // 脙篓脗虏脗禄脙搂脗聰脗篓脙漏脗職脗篓脙搂脗颅脗聣脙搂脗麓脗職脙娄脗聫脗聬脙楼脗聧脗聡脙炉脗录脗職base 脙聝脗聴 (1 + lv*0.25)脙炉脗录脗聦脙漏脗聙脗虏脙楼脗聦脗聳脙漏脗芦脗聰脙楼脗聠脗聧脙聝脗聴2
  const baseFeed=isEvo?(basedef?.feedCost||30)*2:(basedef?.feedCost||30);
  const cost=Math.round(baseFeed*(1+lv*0.25));
  if(hero.coins<cost){toast('脙漏脗聡脗聭脙楼脗鹿脗拢脙陇脗赂脗聧脙篓脗露脗鲁脙炉脗录脗聛脙漏脗聹脗聙 '+cost+'脙掳脗聼脗陋脗聶');return;}
  hero.coins-=cost;
  const maxLv=isEvo?(PET_EVOLVED[pet.evoId]?.maxLv||20):(basedef?.maxLv||15);
  const needExp=Math.round((lv*80)*(isEvo?2:1));
  pet.exp=(pet.exp||0)+(isEvo?50:35);
  if(pet.exp>=needExp&&lv<maxLv){
    pet.exp-=needExp;pet.level=lv+1;
    const newLv=pet.level;
    const skillUnlocked=(basedef?.skills||[]).find(s=>s.lv===newLv);
    if(skillUnlocked)toast('脙掳脗聼脗聦脗聼 '+pet.name+' Lv.'+newLv+'脙炉脗录脗聛脙篓脗搂脗拢脙漏脗聨脗聳脙炉脗录脗職'+skillUnlocked.name);
    else toast('脙掳脗聼脗聨脗聣 '+pet.name+' 脙楼脗聧脗聡脙楼脗聢脗掳 Lv.'+newLv+'脙炉脗录脗聛');
  }else toast('脙掳脗聼脗聧脗聳 脙漏脗陇脗碌脙漏脗拢脗聼 '+pet.name+'脙炉脗录脗聢脙篓脗聤脗卤脙篓脗虏脗禄 '+cost+'脙掳脗聼脗陋脗聶脙炉脗录脗聣');
  recalc(hero);save();updCoins();updHeroUI();renderPets();renderSVG();
}

function evolvePet(uid){
  const inv=hero.inventory||[];
  const pet=inv.find(x=>(x.uid||x.id)===uid);
  if(!pet||pet.isEvolved)return;
  const pd=PET_DEF.find(p=>p.id===pet.petDefId);if(!pd)return;
  const sameNamePets=inv.filter(x=>x.petDefId===pet.petDefId&&!x.isEvolved);
  if(sameNamePets.length<2){toast('脙漏脗聹脗聙脙篓脗娄脗聛2脙漏脗職脗禄脙楼脗聬脗聦脙楼脗聬脗聧脙楼脗炉脗碌脙搂脗聣脗漏脙娄脗聣脗聧脙篓脗聝脗陆脙漏脗聙脗虏脙楼脗聦脗聳');return;}
  if((pet.level||1)<(pd.maxLv||15)){toast('脙漏脗聹脗聙脙篓脗娄脗聛脙漏脗聛脗聰脙楼脗聢脗掳脙娄脗聹脗聙脙漏脗芦脗聵脙搂脗颅脗聣脙搂脗麓脗職脙娄脗聣脗聧脙篓脗聝脗陆脙漏脗聙脗虏脙楼脗聦脗聳脙炉脗录脗聢Lv.'+pd.maxLv+'脙炉脗录脗聣');return;}
  const evoId=pd.evo;
  const evoData=PET_EVOLVED[evoId];
  if(!evoData){toast('脙娄脗颅脗陇脙楼脗炉脗碌脙搂脗聣脗漏脙搂脗聞脗隆脙漏脗聙脗虏脙楼脗聦脗聳脙楼脗陆脗垄脙娄脗聟脗聥');return;}
  // consume the 2 pets, keep as evolved
  const petIdx=inv.indexOf(pet);
  const other=sameNamePets.find(x=>x!==pet);
  const otherIdx=inv.indexOf(other);
  // remove the other one
  hero.inventory=inv.filter((_,i)=>i!==otherIdx);
  // evolve the main one
  const evolved=hero.inventory.find(x=>(x.uid||x.id)===uid);
  evolved.isEvolved=true;
  evolved.evoId=evoId;
  evolved.evolvedFrom=pet.petDefId;
  evolved.name=evoData.name;
  evolved.icon=evoData.icon;
  evolved.level=1;
  evolved.exp=0;
  // if this pet was equipped, update equipped ref
  if((hero.equipped||{}).pet&&((hero.equipped.pet.uid||hero.equipped.pet.id)===uid)){
    hero.equipped.pet=evolved;
  }
  recalc(hero);save();updHeroUI();renderPets();renderSVG();
  toast('脙垄脗聹脗篓 脙漏脗聙脗虏脙楼脗聦脗聳脙娄脗聢脗聬脙楼脗聤脗聼脙炉脗录脗聛'+evoData.name+' 脙篓脗陋脗聲脙搂脗聰脗聼脙炉脗录脗聛');
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 PERFORMANCE 脙垄脗聲脗聬脙垄脗聲脗聬
function renderPerf(){
  if(!hero)return;
  const records=LS.qry('perf_records',{user_id:hero.user_id},null,100).filter(r=>r.month===mo());
  const totalAmt=records.reduce((s,r)=>s+(r.amount||0),0);
  const coinsEarned=Math.floor(totalAmt/100);
  $('perf-amt').textContent='NT$'+(totalAmt).toLocaleString();
  $('perf-coins').textContent=coinsEarned+'脙掳脗聼脗陋脗聶';
  let msReached=0;
  PERF_MILESTONES.forEach(ms=>{if(totalAmt>=ms.amt)msReached++;});
  $('perf-ms').textContent=msReached+'/'+PERF_MILESTONES.length;
  const goal=100000;
  $('perf-prog-txt').textContent=(totalAmt/1000).toFixed(1)+'K / NT$100,000';
  $('perf-prog-bar').style.width=Math.min(100,(totalAmt/goal)*100)+'%';
  // milestone row with claim buttons
  const msReviews=LS.g('perf_ms_reviews').filter(r=>r.user_id===hero.user_id&&r.month===mo());
  $('ms-row').innerHTML=PERF_MILESTONES.map((ms,idx)=>{
    const reached=totalAmt>=ms.amt;
    const hasExtra=!!ms.extraReward;
    const reviewKey='ms_'+idx+'_'+mo();
    const reviewed=msReviews.find(r=>r.ms_idx===idx);
    let claimBtn='';
    if(reached&&hasExtra){
      if(reviewed?.status==='approved') claimBtn=`<div style="font-size:9px;color:var(--green)">脙垄脗聹脗聟 脙楼脗路脗虏脙漏脗聽脗聵脙楼脗聫脗聳</div>`;
      else if(reviewed?.status==='pending') claimBtn=`<div style="font-size:9px;color:var(--orange)">脙垄脗聫脗鲁 脙楼脗炉脗漏脙娄脗聽脗赂脙陇脗赂脗颅</div>`;
      else claimBtn=`<button onclick="claimPerfMs(${idx})" style="font-size:9px;padding:2px 6px;background:var(--gold);color:#111;border:none;border-radius:4px;cursor:pointer;font-family:inherit;font-weight:700;margin-top:3px">脙掳脗聼脗聨脗聛 脙搂脗聰脗鲁脙篓脗芦脗聥脙漏脗隆脗聧脙楼脗陇脗聳脙搂脗聧脗聨脙楼脗聥脗碌</button>`;
    }
    return `<div class="milestone ${reached?'reached':''}">
      <div class="ms-amt">${ms.label}</div>
      <div class="ms-rew">+${ms.coins}脙掳脗聼脗陋脗聶</div>
      ${hasExtra?`<div style="font-size:8px;color:var(--orange)">+脙漏脗隆脗聧脙楼脗陇脗聳脙搂脗聧脗聨脙楼脗聥脗碌</div>`:''}
      ${reached?'<div style="font-size:9px;color:var(--green)">脙垄脗聹脗聯</div>':''}
      ${claimBtn}
    </div>`;
  }).join('');
  // history
  const allRecords=LS.qry('perf_records',{user_id:hero.user_id},null,50).sort((a,b)=>b.created_at>a.created_at?1:-1);
  $('perf-history').innerHTML=allRecords.length?allRecords.slice(0,10).map(r=>
    `<div class="history-item">
      <div><div style="font-size:12px;font-weight:500">${r.month}</div><div style="font-size:10px;color:var(--muted)">${r.note||'脙娄脗楼脗颅脙搂脗赂脗戮脙篓脗录脗赂脙楼脗聟脗楼'}</div></div>
      <div style="text-align:right"><div style="color:var(--gold);font-weight:700">NT$${(r.amount||0).toLocaleString()}</div><div style="font-size:10px;color:var(--teal)">+${Math.floor((r.amount||0)/100)}脙掳脗聼脗陋脗聶</div></div>
    </div>`).join('')
  :'<div class="empty">脙楼脗掳脗職脙搂脗聞脗隆脙娄脗楼脗颅脙搂脗赂脗戮脙搂脗麓脗聙脙漏脗聦脗聞</div>';
}
function claimPerfMs(idx){
  const ms=PERF_MILESTONES[idx];if(!ms?.extraReward)return;
  const already=LS.g('perf_ms_reviews').find(r=>r.user_id===hero.user_id&&r.ms_idx===idx&&r.month===mo());
  if(already){toast('脙楼脗路脗虏脙搂脗聰脗鲁脙篓脗芦脗聥脙漏脗聛脗聨');return;}
  LS.ins('perf_ms_reviews',{id:'pmr_'+Date.now(),user_id:hero.user_id,username:hero.username,avatar:hero.avatar,ms_idx:idx,ms_label:ms.label,extra:ms.extraReward,month:mo(),status:'pending',created_at:new Date().toISOString()});
  toast('脙掳脗聼脗聯脗陇 脙漏脗聡脗聦脙搂脗篓脗聥脙搂脗垄脗聭脙漏脗隆脗聧脙楼脗陇脗聳脙搂脗聧脗聨脙楼脗聥脗碌脙搂脗聰脗鲁脙篓脗芦脗聥脙楼脗路脗虏脙漏脗聙脗聛脙楼脗聡脗潞脙炉脗录脗聛脙搂脗颅脗聣脙楼脗戮脗聟脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙搂脗垄脗潞脙篓脗陋脗聧');
  renderPerf();
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 LB 脙垄脗聲脗聬脙垄脗聲脗聬
function switchLb(col){
  lbCol=col;
  document.querySelectorAll('.lbtab').forEach((e,i)=>e.classList.toggle('active',['total_steps','coins','level','total_perf'][i]===col));
  loadLb();
}
function loadLb(){
  if(!hero)return;
  const data=LS.qry('heroes',{},lbCol,50);
  if(!data.length){$('lb-list').innerHTML='<div class="empty">脙娄脗職脗芦脙搂脗聞脗隆脙篓脗鲁脗聡脙娄脗聳脗聶</div>';return;}

  // 脙娄脗聹脗聙脙楼脗陇脗搂脙楼脗聙脗录脙炉脗录脗聢脙搂脗聰脗篓脙娄脗聳脗录脙漏脗聙脗虏脙楼脗潞脗娄脙娄脗垄脗聺脙炉脗录脗聣
  const maxVal=data.reduce((m,r)=>{
    const v=lbCol==='total_steps'?(r.total_steps||0):lbCol==='coins'?(r.coins||0):lbCol==='level'?(r.level||1):(r.total_perf||0);
    return Math.max(m,v);
  },1);

  const valF=(row)=>{
    if(lbCol==='total_steps')return(row.total_steps||0).toLocaleString()+'脙娄脗颅脗楼';
    if(lbCol==='coins')return(row.coins||0).toLocaleString()+'脙掳脗聼脗陋脗聶';
    if(lbCol==='level')return'Lv.'+(row.level||1);
    if(lbCol==='total_perf')return'NT$'+(row.total_perf||0).toLocaleString();
    return'-';
  };
  const numF=(row)=>{
    if(lbCol==='total_steps')return row.total_steps||0;
    if(lbCol==='coins')return row.coins||0;
    if(lbCol==='level')return row.level||1;
    if(lbCol==='total_perf')return row.total_perf||0;
    return 0;
  };

  const top5=data.slice(0,5);
  const selfInTop5=top5.some(r=>r.user_id===hero.user_id);
  const displayRows=selfInTop5?top5:[...top5,data.find(r=>r.user_id===hero.user_id)].filter(Boolean);
  const selfRank=data.findIndex(r=>r.user_id===hero.user_id)+1;
  const rankColors=['#f0d060','#c0c0c0','#cd7f32'];

  const rowHtml=displayRows.map((row)=>{
    const rank=data.indexOf(row)+1;
    const ric=rank===1?'脙掳脗聼脗楼脗聡':rank===2?'脙掳脗聼脗楼脗聢':rank===3?'脙掳脗聼脗楼脗聣':rank;
    const rc=rank<=3?'r'+rank:'';
    const isMe=row.user_id===hero.user_id;
    const cls=CLASS_DEF[row.hero_class||'warrior'];
    const memTag=getMemberTag(row.member_tier);
    const isDiamond=row.member_tier==='diamond';
    const pct=Math.min(100,Math.round(numF(row)/maxVal*100));
    const barColor=rank<=3?rankColors[rank-1]:'var(--gold)';
    // 脙楼脗聢脗聠脙漏脗職脗聰脙搂脗路脗職脙炉脗录脗職脙漏脗聺脗聻 top5 脙陇脗赂脗聰脙陇脗赂脗聧脙楼脗聹脗篓脙楼脗聣脗聧脙漏脗聺脗垄
    const sep=!selfInTop5&&row.user_id===hero.user_id&&rank>5?
      `<div style="text-align:center;font-size:10px;color:var(--muted);padding:4px 0">脙拢脗聝脗禄脙拢脗聝脗禄脙拢脗聝脗禄</div>`:'';
    return sep+`<div class="lb-row${isMe?' lb-me':''}${isDiamond?' lb-diamond':''} ${rank<=3?'r'+rank+'-row':''}">
      <div class="lbrank ${rc}" style="font-size:${rank<=3?'16':'13'}px">${ric}</div>
      <div class="lbava" style="font-size:${isDiamond?'20':'17'}px">${row.avatar||'脙掳脗聼脗搂脗聶'}</div>
      <div class="lbinfo">
        <div class="ln">${row.username}${memTag}${isMe?' <span style="font-size:9px;color:var(--gold);font-weight:700"> 脙垄脗聠脗聬 脙陇脗陆脗聽</span>':''}</div>
        <div class="ls">${cls.icon} Lv.${row.level||1} 脙聜脗路 脙漏脗聙脗拢脙搂脗掳脗陆${row.streak||0}脙楼脗陇脗漏</div>
        <div class="lb-stat-bar"><div class="lb-stat-fill" style="width:${pct}%;background:${barColor}"></div></div>
      </div>
      <div class="lbval">${valF(row)}</div>
    </div>`;
  }).join('');

  // 脙楼脗潞脗聲脙漏脗聝脗篓脙拢脗聙脗聦脙娄脗聢脗聭脙搂脗職脗聞脙娄脗聨脗聮脙楼脗聬脗聧脙拢脗聙脗聧脙楼脗聸脗潞脙楼脗庐脗職脙娄脗聭脗聵脙篓脗娄脗聛
  const myRow=data.find(r=>r.user_id===hero.user_id);
  const selfSummary=myRow?`
    <div style="margin-top:10px;padding:9px 12px;background:rgba(201,162,39,.08);border:1px solid rgba(201,162,39,.3);border-radius:10px;display:flex;align-items:center;gap:10px">
      <div style="font-size:11px;color:var(--muted)">脙娄脗聢脗聭脙搂脗職脗聞脙娄脗聨脗聮脙楼脗聬脗聧</div>
      <div style="font-size:18px;font-weight:700;color:var(--gold2)">#${selfRank}</div>
      <div style="flex:1;font-size:11px;color:var(--text)">${myRow.username}</div>
      <div style="font-size:13px;font-weight:700;color:var(--gold2)">${valF(myRow)}</div>
    </div>`:'';

  $('lb-list').innerHTML=rowHtml+selfSummary;
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 ADMIN 脙垄脗聲脗聬脙垄脗聲脗聬
async function loadPending(){
  const data=LS.qry('step_submissions',{status:'pending'}).sort((a,b)=>a.created_at>b.created_at?1:-1);
  if(!data.length){$('pending-list').innerHTML='<div class="empty">脙搂脗聞脗隆脙楼脗戮脗聟脙楼脗炉脗漏脙娄脗聽脗赂 脙垄脗聹脗聟</div>';return;}
  $('pending-list').innerHTML=data.map(s=>`
    <div class="pitem" id="sub-${s.id}">
      <div style="display:flex;justify-content:space-between;margin-bottom:5px">
        <div style="font-size:12px;font-weight:500">${s.username}</div>
        <div style="font-size:13px;color:var(--gold);font-weight:700">${(s.steps||0).toLocaleString()} 脙娄脗颅脗楼</div>
      </div>
      <div style="font-size:10px;color:var(--muted);margin-bottom:5px">${s.submitted_date}</div>
      ${s.image_data?`<img src="${s.image_data}" style="width:100%;border-radius:6px;margin-bottom:6px;max-height:130px;object-fit:cover">`:'<div style="color:var(--red);font-size:11px;margin-bottom:6px">脙娄脗聹脗陋脙漏脗聶脗聞脙娄脗聢脗陋脙楼脗聹脗聳</div>'}
      <div class="pbtns">
        <button class="abtn-ok" onclick="approveStep('${s.id}','${s.user_id}',${s.steps})">脙垄脗聹脗聟 脙娄脗聽脗赂脙楼脗聡脗聠</button>
        <button class="abtn-no" onclick="rejectStep('${s.id}')">脙垄脗聺脗聦 脙娄脗聥脗聮脙搂脗碌脗聲</button>
      </div>
    </div>`).join('');
}
async function approveStep(sid,uid,steps){
  let coins=0;
  if(steps>=3000)coins+=10;if(steps>=6000)coins+=10;
  if(steps>=10000)coins+=15;if(steps>=15000)coins+=15;
  const h=LS.one('heroes','user_id',uid);
  if(h){
    let e=(h.exp||0)+Math.round(coins*0.8),lv=h.level||1;
    let bh=h.base_hp,bs=h.base_str,bd=h.base_def,bsp=h.base_spd;
    if(e>=lv*600){e-=lv*600;lv++;bh+=12;bs+=6;bd+=5;bsp+=7;}
    LS.upd('heroes','user_id',uid,{coins:(h.coins||0)+coins,total_steps:(h.total_steps||0)+steps,exp:e,level:lv,base_hp:bh,base_str:bs,base_def:bd,base_spd:bsp,steps_approved_date:tod()});
    if(hero&&hero.user_id===uid){hero.coins+=coins;hero.total_steps=(hero.total_steps||0)+steps;updCoins();}
  }
  const rows=LS.g('step_submissions');const ri=rows.findIndex(r=>r.id===sid);
  if(ri>=0){rows[ri].status='approved';LS.s('step_submissions',rows);}
  $('sub-'+sid)?.remove();toast('脙垄脗聹脗聟 脙娄脗聽脗赂脙楼脗聡脗聠 +'+coins+'脙掳脗聼脗陋脗聶');
}
function rejectStep(sid){
  const rows=LS.g('step_submissions');const ri=rows.findIndex(r=>r.id===sid);
  if(ri>=0){rows[ri].status='rejected';LS.s('step_submissions',rows);}
  $('sub-'+sid)?.remove();toast('脙垄脗聺脗聦 脙楼脗路脗虏脙娄脗聥脗聮脙搂脗碌脗聲');
}
function populatePerfHeroSel(){
  const heroes=LS.g('heroes');
  $('perf-hero-sel').innerHTML='<option value="">脙漏脗聛脗赂脙娄脗聯脗聡脙篓脗聥脗卤脙漏脗聸脗聞</option>'+
    heroes.map(h=>`<option value="${h.user_id}">${h.username} (${h.user_id})</option>`).join('');
}
function submitPerf(){
  const uid=$('perf-hero-sel').value;
  const amt=parseInt($('perf-amt-inp').value)||0;
  const month=$('perf-month-inp').value;
  if(!uid||amt<=0||!month){toast('脙篓脗芦脗聥脙楼脗隆脗芦脙楼脗炉脗芦脙楼脗庐脗聦脙娄脗聲脗麓');return;}
  const coins=Math.floor(Math.min(amt,500000)/100);
  const h=LS.one('heroes','user_id',uid);
  if(h){
    LS.upd('heroes','user_id',uid,{coins:(h.coins||0)+coins,total_perf:(h.total_perf||0)+amt});
  }
  LS.ins('perf_records',{user_id:uid,amount:amt,month,coins,note:'脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙篓脗录脗赂脙楼脗聟脗楼',created_at:new Date().toISOString()});
  if(hero&&hero.user_id===uid){hero.coins+=coins;hero.total_perf=(hero.total_perf||0)+amt;updCoins();renderPerf();}
  toast('脙掳脗聼脗聯脗聤 脙娄脗楼脗颅脙搂脗赂脗戮脙篓脗录脗赂脙楼脗聟脗楼脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛脙搂脗聶脗录脙娄脗聰脗戮 +'+coins+'脙掳脗聼脗陋脗聶');
  $('perf-amt-inp').value='';
}
// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬
// 脙掳脗聼脗聨脗掳 LOTTERY SYSTEM 脙垄脗聙脗聰 脙娄脗聹脗聢脙楼脗潞脗聲脙搂脗碌脗卤脙陇脗赂脗聙脙漏脗聳脗聥脙搂脗聧脗聨脙搂脗聣脗聢
// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬

function getLotteryTicketsFromTier(tierId){
  return {none:1,bronze:2,silver:3,gold:4,diamond:5}[tierId]||1;
}

function calcMonthTickets(h){
  const base=getLotteryTicketsFromTier(h?.member_tier||'none');
  const m=mo();
  const perfRecs=LS.g('perf_records').filter(r=>r.user_id===h.user_id&&r.month===m);
  const totalPerf=perfRecs.reduce((s,r)=>s+(r.amount||0),0);
  const perfBonus=totalPerf>=10000?1:0;
  // 脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗庐脗聦脙娄脗聢脗聬脙搂脗職脗聞脙娄脗炉脗聫脙娄脗聴脗楼脙陇脗禄脗禄脙楼脗聥脗聶脙娄脗聲脗赂
  const doneKeys=(h.tasks_done||[]).filter(k=>k.includes(m));
  const taskBonus=doneKeys.length>=20?1:0;
  return {base,perfBonus,taskBonus,total:base+perfBonus+taskBonus};
}

function getMonthPrizes(m){
  return LS.g('lottery_prizes').filter(r=>r.month===(m||mo()));
}

function getMonthWinners(m){
  return LS.g('lottery_winners').filter(r=>r.month===(m||mo()));
}

// 脙楼脗聙脗聮脙篓脗篓脗聢脙娄脗聶脗聜脙楼脗聢脗掳脙娄脗聹脗聢脙楼脗潞脗聲
function getMonthEndCountdown(){
  const now=new Date();
  const end=new Date(now.getFullYear(),now.getMonth()+1,0,23,59,59);
  const diff=end-now;
  if(diff<=0) return '脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗路脗虏脙搂脗碌脗聬脙娄脗聺脗聼';
  const d=Math.floor(diff/86400000);
  const h=Math.floor((diff%86400000)/3600000);
  return `脙篓脗路脗聺脙娄脗聹脗聢脙楼脗潞脗聲脙漏脗聳脗聥脙搂脗聧脗聨脙漏脗聜脗聞脙娄脗聹脗聣 ${d} 脙楼脗陇脗漏 ${h} 脙楼脗掳脗聫脙娄脗聶脗聜`;
}

function renderLottery(){
  if(!hero)return;
  const m=mo();
  const prizes=getMonthPrizes(m);
  const winners=getMonthWinners(m);
  const {base,perfBonus,taskBonus,total}=calcMonthTickets(hero);
  const tierName=MEMBER_TIERS[hero.member_tier||'none']?.name||'脙陇脗赂脗聙脙篓脗聢脗卢脙搂脗聰脗篓脙娄脗聢脗露';
  const isDrawn=winners.length>0;

  // banner
  const config=LS.g('lottery_config').find(r=>r.month===m)||{};
  const title=$('lottery-month-title');
  const sponsor=$('lottery-sponsor-name');
  const countdown=$('lot-countdown');
  if(title) title.textContent=config.title||m+' 脙娄脗聹脗聢脙娄脗聤脗陆脙搂脗聧脗聨脙娄脗麓脗禄脙楼脗聥脗聲';
  if(sponsor) sponsor.textContent=config.sponsor?'脙篓脗麓脗聤脙楼脗聤脗漏脙楼脗聲脗聠脙炉脗录脗職'+config.sponsor:'';
  if(countdown) countdown.textContent=isDrawn?'脙掳脗聼脗聨脗聤 脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗路脗虏脙漏脗聳脗聥脙搂脗聧脗聨脙炉脗录脗聛':getMonthEndCountdown();

  // tickets
  const badge=$('ticket-total-badge');
  if(badge){badge.textContent=total+' 脙楼脗录脗碌';badge.style.color=total>0?'var(--gold2)':'var(--muted)';}
  const bd=$('ticket-breakdown');
  if(bd) bd.innerHTML=`
    <div class="ticket-src-row"><span class="src-label">${tierName} 脙搂脗颅脗聣脙搂脗麓脗職脙楼脗聼脗潞脙搂脗陇脗聨</span><span class="src-val">脙聝脗聴 ${base} 脙楼脗录脗碌</span></div>
    ${perfBonus?'<div class="ticket-src-row"><span class="src-label">脙掳脗聼脗聯脗聤 脙娄脗楼脗颅脙搂脗赂脗戮脙漏脗聛脗聰 NT$10,000</span><span class="src-val">+1 脙楼脗录脗碌</span></div>':'<div class="ticket-src-row"><span class="src-label">脙掳脗聼脗聯脗聤 脙娄脗楼脗颅脙搂脗赂脗戮脙漏脗聛脗聰 NT$10,000脙炉脗录脗聢脙娄脗聹脗陋脙漏脗聛脗聰脙炉脗录脗聣</span><span class="src-val" style="color:var(--muted)">+0</span></div>'}
    ${taskBonus?'<div class="ticket-src-row"><span class="src-label">脙垄脗聹脗聟 脙楼脗庐脗聦脙娄脗聢脗聬 20 脙楼脗聙脗聥脙娄脗炉脗聫脙娄脗聴脗楼脙陇脗禄脗禄脙楼脗聥脗聶</span><span class="src-val">+1 脙楼脗录脗碌</span></div>':'<div class="ticket-src-row"><span class="src-label">脙垄脗聹脗聟 脙楼脗庐脗聦脙娄脗聢脗聬 20 脙楼脗聙脗聥脙陇脗禄脗禄脙楼脗聥脗聶脙炉脗录脗聢脙漏脗聙脗虏脙楼脗潞脗娄 '+(hero.tasks_done||[]).filter(k=>k.includes(m)).length+'/20脙炉脗录脗聣</span><span class="src-val" style="color:var(--muted)">+0</span></div>'}
    <div class="ticket-src-row" style="border-top:1px solid var(--border);margin-top:5px;padding-top:6px;font-weight:700">
      <span style="color:var(--text)">脙娄脗聹脗卢脙娄脗聹脗聢脙搂脗赂脗陆脙篓脗篓脗聢</span><span class="src-val" style="font-size:15px">${total} 脙楼脗录脗碌脙掳脗聼脗聨脗聼脙炉脗赂脗聫</span>
    </div>`;

  // prizes
  const pl=$('prize-list');
  if(pl){
    if(!prizes.length){
      pl.innerHTML='<div class="empty">脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗掳脗職脙娄脗聹脗陋脙篓脗篓脗颅脙楼脗庐脗職脙搂脗聧脗聨脙楼脗聯脗聛脙炉脗录脗聦脙娄脗聲脗卢脙篓脗芦脗聥脙娄脗聹脗聼脙楼脗戮脗聟</div>';
    } else {
      pl.innerHTML=prizes.map(p=>{
        const wonCount=winners.filter(w=>w.prize_id===p.id).length;
        const iWon=winners.some(w=>w.prize_id===p.id&&w.user_id===hero.user_id);
        const allGone=wonCount>=(p.qty||1);
        return `<div class="prize-item${iWon?' won':''}">
          <div class="prize-ico">${p.icon||'脙掳脗聼脗聨脗聛'}</div>
          <div class="prize-info">
            <div class="prize-name">${p.name}</div>
            <div class="prize-sponsor">${config.sponsor||'脙篓脗麓脗聤脙楼脗聤脗漏脙楼脗聲脗聠脙娄脗聫脗聬脙陇脗戮脗聸'}</div>
            <div class="prize-qty">脙娄脗聲脗赂脙漏脗聡脗聫脙炉脗录脗職${p.qty||1} 脙陇脗禄脗陆 ${isDrawn?(allGone?'脙聜脗路 <span style="color:var(--red)">脙楼脗路脗虏脙楼脗聟脗篓脙娄脗聲脗赂脙娄脗聤脗陆脙楼脗聡脗潞</span>':'脙聜脗路 <span style="color:var(--green)">脙楼脗聣脗漏 '+(p.qty-wonCount)+' 脙陇脗禄脗陆</span>'):'脙聜脗路 <span style="color:var(--muted)">脙搂脗颅脗聣脙楼脗戮脗聟脙漏脗聳脗聥脙搂脗聧脗聨</span>'}</div>
          </div>
          ${iWon?'<div class="prize-won-badge">脙掳脗聼脗聨脗聤 脙陇脗赂脗颅脙搂脗聧脗聨</div>':''}
        </div>`;
      }).join('');
    }
  }

  // winners
  renderPublicWinners();
  renderMyLotteryHistory();
}

function renderPublicWinners(){
  const m=mo();
  const winners=getMonthWinners(m);
  const el=$('winner-list');if(!el)return;
  if(!winners.length){
    el.innerHTML='<div class="empty">脙垄脗聫脗鲁 脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗掳脗職脙娄脗聹脗陋脙漏脗聳脗聥脙搂脗聧脗聨脙炉脗录脗聦脙娄脗聹脗聢脙楼脗潞脗聲脙楼脗聟脗卢脙楼脗赂脗聝脙搂脗碌脗聬脙娄脗聻脗聹</div>';
    return;
  }
  // group by prize
  const prizes=getMonthPrizes(m);
  const config=LS.g('lottery_config').find(r=>r.month===m)||{};
  el.innerHTML=`<div style="font-size:11px;color:var(--muted);margin-bottom:10px">脙漏脗聳脗聥脙搂脗聧脗聨脙娄脗聶脗聜脙漏脗聳脗聯脙炉脗录脗職${winners[0]?.drawn_at?.slice(0,10)||m}</div>`+
    prizes.map(p=>{
      const pw=winners.filter(w=>w.prize_id===p.id);
      if(!pw.length) return '';
      return `<div style="margin-bottom:12px">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
          <span style="font-size:20px">${p.icon||'脙掳脗聼脗聨脗聛'}</span>
          <span style="font-size:13px;font-weight:700;color:var(--gold2)">${p.name}</span>
          <span style="font-size:10px;color:var(--muted)">${config.sponsor||''}</span>
        </div>
        ${pw.map(w=>{
          const isMe=w.user_id===hero.user_id;
          return `<div class="winner-row${isMe?' lb-me':''}">
            <div class="winner-ava">${w.avatar||'脙掳脗聼脗搂脗聶'}</div>
            <div class="winner-name">${w.username}${isMe?' <span style="font-size:10px;color:var(--gold)">(脙陇脗陆脗聽脙炉脗录脗聛)</span>':''}</div>
            <div class="winner-prize">脙掳脗聼脗聨脗聤 脙陇脗赂脗颅脙搂脗聧脗聨</div>
          </div>`;
        }).join('')}
      </div>`;
    }).join('');
}

function renderMyLotteryHistory(){
  const el=$('my-draw-history');if(!el)return;
  // 脙娄脗颅脗路脙楼脗聫脗虏脙娄脗聹脗聢脙陇脗禄脗陆
  const allWinners=LS.g('lottery_winners').filter(r=>r.user_id===hero.user_id)
    .sort((a,b)=>b.month>a.month?1:-1);
  const allMonths=[...new Set(LS.g('lottery_config').map(r=>r.month))].sort().reverse().slice(0,6);
  if(!allMonths.length){el.innerHTML='<div class="empty">脙楼脗掳脗職脙搂脗聞脗隆脙娄脗颅脗路脙楼脗聫脗虏脙篓脗篓脗聵脙漏脗聦脗聞</div>';return;}
  el.innerHTML=allMonths.map(m=>{
    const {total}=calcMonthTickets({...hero,member_tier:hero.member_tier});
    const won=allWinners.filter(w=>w.month===m);
    const drawn=getMonthWinners(m).length>0;
    const config=LS.g('lottery_config').find(r=>r.month===m)||{};
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(201,162,39,.1)">
      <div>
        <div style="font-size:12px;font-weight:500">${config.title||m+' 脙娄脗聹脗聢'}</div>
        <div style="font-size:10px;color:var(--muted)">${config.sponsor||''}</div>
      </div>
      <div style="text-align:right">
        ${won.length?won.map(w=>`<div style="font-size:11px;color:var(--gold)">脙掳脗聼脗聨脗聤 ${w.prize_name}</div>`).join(''):''}
        <div style="font-size:10px;color:var(--muted)">${drawn?(won.length?'':'脙娄脗聹脗陋脙陇脗赂脗颅脙搂脗聧脗聨'):'脙娄脗聹脗陋脙漏脗聳脗聥脙搂脗聧脗聨'}</div>
      </div>
    </div>`;
  }).join('');
}

// 脙垄脗聰脗聙脙垄脗聰脗聙 ADMIN functions 脙垄脗聰脗聙脙垄脗聰脗聙
function addPrizeInput(){
  const container=$('prize-inputs');if(!container)return;
  const rows=container.querySelectorAll('.prize-input-row');
  if(rows.length>=5){toast('脙娄脗聹脗聙脙楼脗陇脗職5脙陇脗禄脗露脙搂脗聧脗聨脙楼脗聯脗聛');return;}
  const idx=rows.length;
  const div=document.createElement('div');
  div.className='prize-input-row';
  div.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">
    <div style="font-size:11px;color:var(--gold)">脙搂脗聧脗聨脙楼脗聯脗聛 ${idx+1}</div>
    <button onclick="this.closest('.prize-input-row').remove()" style="background:transparent;border:none;color:var(--red);cursor:pointer;font-size:12px;font-family:inherit">脙垄脗聹脗聲 脙搂脗搂脗禄脙漏脗聶脗陇</button>
  </div>
  <div class="fg"><label>脙搂脗聧脗聨脙楼脗聯脗聛脙楼脗聬脗聧脙搂脗篓脗卤</label><input type="text" class="pi-name" placeholder="脙陇脗戮脗聥脙炉脗录脗職脙楼脗聟脗篓脙楼脗庐脗露脙搂脗娄脗庐脙楼脗聯脗聛脙楼脗聧脗隆 NT$200"></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    <div class="fg"><label>Emoji</label><input type="text" class="pi-ico" placeholder="脙掳脗聼脗聨脗聛" style="font-size:20px"></div>
    <div class="fg"><label>脙娄脗聲脗赂脙漏脗聡脗聫脙炉脗录脗聢脙陇脗禄脗陆脙炉脗录脗聣</label><input type="number" class="pi-qty" min="1" value="1"></div>
  </div>`;
  container.appendChild(div);
}

function saveLotteryPrizes(){
  const month=$('lot-month')?.value||mo();
  const title=$('lot-title')?.value?.trim()||month+' 脙娄脗聹脗聢脙娄脗聤脗陆脙搂脗聧脗聨脙娄脗麓脗禄脙楼脗聥脗聲';
  const sponsor=$('lot-sponsor')?.value?.trim()||'';
  const cfgs=LS.g('lottery_config').filter(r=>r.month!==month);
  cfgs.push({month,title,sponsor});LS.s('lottery_config',cfgs);
  const rows=document.querySelectorAll('.prize-input-row');
  const prizes=[];
  rows.forEach((row,i)=>{
    const name=row.querySelector('.pi-name')?.value?.trim();
    const icon=row.querySelector('.pi-ico')?.value?.trim()||'脙掳脗聼脗聨脗聛';
    const qty=parseInt(row.querySelector('.pi-qty')?.value)||1;
    if(name) prizes.push({id:'prize_'+month+'_'+i,month,name,icon,qty,sponsor,created_at:new Date().toISOString()});
  });
  if(!prizes.length){toast('脙篓脗芦脗聥脙篓脗聡脗鲁脙楼脗掳脗聭脙篓脗录脗赂脙楼脗聟脗楼脙陇脗赂脗聙脙陇脗禄脗露脙搂脗聧脗聨脙楼脗聯脗聛');return;}
  const old=LS.g('lottery_prizes').filter(r=>r.month!==month);
  LS.s('lottery_prizes',[...old,...prizes]);
  toast('脙掳脗聼脗聮脗戮 脙楼脗聞脗虏脙楼脗颅脗聵脙娄脗聢脗聬脙楼脗聤脗聼脙炉脗录脗聛脙娄脗聹脗卢脙娄脗聹脗聢脙篓脗篓脗颅脙楼脗庐脗職 '+prizes.length+' 脙陇脗禄脗露脙搂脗聧脗聨脙楼脗聯脗聛脙炉脗录脗聦脙篓脗麓脗聤脙楼脗聤脗漏脙楼脗聲脗聠脙炉脗录脗職'+sponsor);
  _try(renderLottery);
  loadAdminLottery();
}

function previewParticipants(){
  const m=$('draw-month')?.value||mo();
  const el=$('participants-preview');if(!el)return;
  const heroes=LS.g('heroes');
  let rows=[];
  heroes.forEach(h=>{
    const tk=calcMonthTickets(h);
    if(tk.total>0) rows.push({username:h.username,avatar:h.avatar,tickets:tk.total,tier:h.member_tier||'none'});
  });
  rows.sort((a,b)=>b.tickets-a.tickets);
  if(!rows.length){el.innerHTML='<div style="font-size:11px;color:var(--muted)">脙楼脗掳脗職脙搂脗聞脗隆脙楼脗聫脗聝脙篓脗聢脗聡脙篓脗聙脗聟</div>';return;}
  const total=rows.reduce((s,r)=>s+r.tickets,0);
  el.innerHTML=`<div style="background:#111;border-radius:8px;padding:9px 10px;font-size:11px">
    <div style="color:var(--gold);font-weight:700;margin-bottom:7px">脙楼脗聫脗聝脙篓脗聢脗聡脙漏脗聽脗聬脙篓脗娄脗陆脙炉脗录脗職${rows.length} 脙陇脗潞脗潞脙拢脗聝脗禄脙楼脗聟脗卤 ${total} 脙楼脗录脗碌脙搂脗楼脗篓</div>
    ${rows.map(r=>{
      const pct=Math.round(r.tickets/total*100);
      const tierC={none:'var(--muted)',bronze:'#cd7f32',silver:'#c0c0c0',gold:'#f0d060',diamond:'#d4a0ff'}[r.tier];
      return `<div style="display:flex;align-items:center;gap:7px;padding:3px 0;border-bottom:1px solid rgba(201,162,39,.08)">
        <span>${r.avatar||'脙掳脗聼脗搂脗聶'}</span>
        <span style="flex:1;color:var(--text)">${r.username}</span>
        <span style="color:${tierC};font-size:10px">${MEMBER_TIERS[r.tier]?.icon||''}</span>
        <span style="color:var(--gold2);font-weight:700">${r.tickets}脙搂脗楼脗篓</span>
        <span style="color:var(--muted);font-size:9px">${pct}%</span>
      </div>`;
    }).join('')}
  </div>`;
}

function adminRunDraw(){
  const m=$('draw-month')?.value||mo();
  const prizes=getMonthPrizes(m);
  if(!prizes.length){toast('脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗掳脗職脙娄脗聹脗陋脙篓脗篓脗颅脙楼脗庐脗職脙搂脗聧脗聨脙楼脗聯脗聛');return;}
  const existWinners=getMonthWinners(m);
  if(existWinners.length>0&&!confirm('脙娄脗聹脗卢脙娄脗聹脗聢脙楼脗路脗虏脙娄脗聹脗聣脙漏脗聳脗聥脙搂脗聧脗聨脙搂脗碌脗聬脙娄脗聻脗聹脙炉脗录脗聦脙搂脗垄脗潞脙楼脗庐脗職脙篓脗娄脗聛脙篓脗拢脗聹脙楼脗聟脗聟脙漏脗聳脗聥脙搂脗聧脗聨脙炉脗录脗聼')){return;}
  if(!confirm('脙搂脗垄脗潞脙楼脗庐脗職脙楼脗聼脗路脙篓脗隆脗聦 '+m+' 脙娄脗聹脗聢脙漏脗聳脗聥脙搂脗聧脗聨脙炉脗录脗聼脙娄脗颅脗陇脙娄脗聯脗聧脙陇脗陆脗聹脙陇脗赂脗聧脙楼脗聫脗炉脙娄脗聮脗陇脙漏脗聤脗路脙炉脗录脗聛')) return;

  const heroes=LS.g('heroes');
  let newWinners=[];

  prizes.forEach(p=>{
    const alreadyWon=existWinners.filter(w=>w.prize_id===p.id).length;
    const need=(p.qty||1)-alreadyWon;
    if(need<=0){toast(p.name+' 脙楼脗路脗虏脙漏脗聳脗聥脙搂脗聧脗聨脙楼脗庐脗聦脙搂脗聲脗垄');return;}

    // 脙楼脗禄脗潞脙搂脗芦脗聥脙楼脗聤脗聽脙娄脗卢脗聤脙娄脗聤脗陆脙搂脗聧脗聨脙娄脗卤脗聽脙炉脗录脗聢脙搂脗楼脗篓脙娄脗聲脗赂脙楼脗陇脗職=脙楼脗陇脗職脙楼脗聙脗聥脙楼脗聬脗聧脙楼脗颅脗聴脙漏脗聙脗虏脙娄脗卤脗聽脙炉脗录脗聣
    const pool=[];
    heroes.forEach(h=>{
      const tk=calcMonthTickets(h);
      if(tk.total<=0) return;
      if(existWinners.some(w=>w.prize_id===p.id&&w.user_id===h.user_id)) return; // 脙楼脗聬脗聦脙陇脗潞脗潞脙楼脗聬脗聦脙搂脗聧脗聨脙楼脗聯脗聛脙陇脗赂脗聧脙漏脗聡脗聧脙篓脗陇脗聡脙陇脗赂脗颅
      for(let i=0;i<tk.total;i++) pool.push(h);
    });
    if(!pool.length){toast(p.name+'脙炉脗录脗職脙搂脗聞脗隆脙搂脗卢脗娄脙楼脗聬脗聢脙篓脗鲁脗聡脙娄脗聽脗录脙篓脗聙脗聟');return;}

    // 脙娄脗聤脗陆脙楼脗聡脗潞 need 脙楼脗聙脗聥脙陇脗赂脗聧脙漏脗聡脗聧脙篓脗陇脗聡脙楼脗戮脗聴脙搂脗聧脗聨脙篓脗聙脗聟
    const picked=new Set();
    let attempts=0;
    while(picked.size<Math.min(need,heroes.length)&&attempts<pool.length*3){
      attempts++;
      const h=pool[Math.floor(Math.random()*pool.length)];
      if(picked.has(h.user_id)) continue;
      picked.add(h.user_id);
      const winner={
        id:'win_'+Date.now()+'_'+h.user_id+'_'+Math.random().toString(36).slice(2),
        user_id:h.user_id,username:h.username,avatar:h.avatar,
        prize_id:p.id,prize_name:p.name,prize_icon:p.icon,
        month:m,drawn_at:new Date().toISOString(),admin_draw:true,
      };
      newWinners.push(winner);
      LS.ins('lottery_winners',winner);
    }
  });

  toast('脙掳脗聼脗聨脗掳 脙漏脗聳脗聥脙搂脗聧脗聨脙楼脗庐脗聦脙娄脗聢脗聬脙炉脗录脗聛脙楼脗聟脗卤 '+newWinners.length+' 脙陇脗陆脗聧脙楼脗戮脗聴脙搂脗聧脗聨脙篓脗聙脗聟脙炉脗录脗聦脙搂脗碌脗聬脙娄脗聻脗聹脙楼脗路脗虏脙楼脗聟脗卢脙漏脗聳脗聥');
  loadAdminLottery();
  _try(renderLottery);
}

// 脙垄脗聲脗聬脙垄脗聲脗聬 TASK ADMIN FUNCTIONS 脙垄脗聲脗聬脙垄脗聲脗聬
function loadAdminTaskList(){
  const tasks=getDailyTasks();
  const el=$('admin-task-list');if(!el)return;
  el.innerHTML=tasks.map(t=>`
    <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid rgba(201,162,39,.1)">
      <span style="font-size:18px">${t.icon}</span>
      <div style="flex:1">
        <div style="font-size:12px;font-weight:500">${t.name}${t.type==='review'?'<span style="font-size:9px;color:var(--teal);margin-left:5px">脙掳脗聼脗聰脗聧脙楼脗炉脗漏脙娄脗聽脗赂脙楼脗聻脗聥</span>':''}</div>
        <div style="font-size:10px;color:var(--muted)">${t.desc||''} 脙聜脗路 +${t.coins}脙掳脗聼脗陋脗聶 +${t.exp}EXP</div>
      </div>
      <button onclick="adminShowTaskForm('${t.id}')" style="background:transparent;border:1px solid var(--gold);color:var(--gold);padding:3px 8px;border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit">脙搂脗路脗篓脙篓脗录脗炉</button>
      ${!t.id.startsWith('d')?' ':''}
      <button onclick="adminDeleteTask('${t.id}')" style="background:transparent;border:1px solid var(--red);color:var(--red);padding:3px 8px;border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit">脙楼脗聢脗陋脙漏脗聶脗陇</button>
    </div>`).join('');
}
function adminShowTaskForm(id){
  const form=$('admin-task-form');if(!form)return;
  form.style.display='block';
  if(id){
    const tasks=getDailyTasks();
    const t=tasks.find(x=>x.id===id);if(!t)return;
    $('atf-name').value=t.name||'';
    $('atf-icon').value=t.icon||'脙掳脗聼脗聯脗聥';
    $('atf-type').value=t.type||'normal';
    $('atf-desc').value=t.desc||'';
    $('atf-coins').value=t.coins||20;
    $('atf-exp').value=t.exp||15;
    $('atf-edit-id').value=id;
  } else {
    $('atf-name').value='';$('atf-icon').value='脙掳脗聼脗聯脗聥';$('atf-type').value='normal';
    $('atf-desc').value='';$('atf-coins').value=20;$('atf-exp').value=15;
    $('atf-edit-id').value='';
  }
}
function adminSaveTask(){
  const name=$('atf-name').value.trim();
  if(!name){toast('脙篓脗芦脗聥脙篓脗录脗赂脙楼脗聟脗楼脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗聬脗聧脙搂脗篓脗卤');return;}
  const tasks=[...getDailyTasks()];
  const editId=$('atf-edit-id').value;
  const newTask={
    id:editId||('ct_'+Date.now()),
    icon:$('atf-icon').value||'脙掳脗聼脗聯脗聥',
    name:name,
    desc:$('atf-desc').value||'',
    type:$('atf-type').value||'normal',
    coins:parseInt($('atf-coins').value)||20,
    exp:parseInt($('atf-exp').value)||15,
  };
  if(editId){
    const idx=tasks.findIndex(x=>x.id===editId);
    if(idx>=0)tasks[idx]=newTask; else tasks.push(newTask);
  } else tasks.push(newTask);
  LS.s('custom_daily_tasks',tasks);
  $('admin-task-form').style.display='none';
  loadAdminTaskList();_try(renderTasks);
  toast('脙掳脗聼脗聮脗戮 脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗路脗虏脙楼脗聞脗虏脙楼脗颅脗聵');
}
function adminDeleteTask(id){
  if(!confirm('脙搂脗垄脗潞脙楼脗庐脗職脙楼脗聢脗陋脙漏脗聶脗陇脙娄脗颅脗陇脙陇脗禄脗禄脙楼脗聥脗聶脙炉脗录脗聼'))return;
  const tasks=getDailyTasks().filter(x=>x.id!==id);
  LS.s('custom_daily_tasks',tasks);
  loadAdminTaskList();_try(renderTasks);
  toast('脙掳脗聼脗聴脗聭脙炉脗赂脗聫 脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗路脗虏脙楼脗聢脗陋脙漏脗聶脗陇');
}
function adminResetTasks(){
  if(!confirm('脙娄脗聛脗垄脙楼脗戮脗漏脙搂脗聜脗潞脙漏脗聽脗聬脙篓脗篓脗颅脙陇脗禄脗禄脙楼脗聥脗聶脙娄脗赂脗聟脙楼脗聳脗庐脙炉脗录脗聼脙篓脗聡脗陋脙篓脗篓脗聜脙陇脗禄脗禄脙楼脗聥脗聶脙楼脗掳脗聡脙楼脗聟脗篓脙漏脗聝脗篓脙娄脗赂脗聟脙漏脗聶脗陇脙拢脗聙脗聜'))return;
  LS.s('custom_daily_tasks',[]);
  loadAdminTaskList();_try(renderTasks);
  toast('脙垄脗聹脗聟 脙楼脗路脗虏脙娄脗聛脗垄脙楼脗戮脗漏脙漏脗聽脗聬脙篓脗篓脗颅脙陇脗禄脗禄脙楼脗聥脗聶');
}
function loadTaskReviews(){
  const reviews=LS.g('task_reviews').filter(r=>r.status==='pending')
    .sort((a,b)=>b.created_at>a.created_at?1:-1);
  const el=$('task-review-list');if(!el)return;
  if(!reviews.length){el.innerHTML='<div class="empty">脙搂脗聞脗隆脙楼脗戮脗聟脙楼脗炉脗漏脙娄脗聽脗赂</div>';return;}
  el.innerHTML=reviews.map(r=>`
    <div class="pitem" id="tr-${r.id}">
      <div style="display:flex;justify-content:space-between;margin-bottom:5px">
        <div style="font-size:12px;font-weight:500">${r.username}</div>
        <div style="font-size:11px;color:var(--teal)">${r.task_name}</div>
      </div>
      <div style="font-size:10px;color:var(--muted);margin-bottom:7px">${r.date}</div>
      <div class="pbtns">
        <button class="abtn-ok" onclick="approveTaskReview('${r.id}','${r.user_id}',${r.coins},${r.exp})">脙垄脗聹脗聟 脙搂脗垄脗潞脙篓脗陋脗聧</button>
        <button class="abtn-no" onclick="rejectTaskReview('${r.id}')">脙垄脗聺脗聦 脙娄脗聥脗聮脙搂脗碌脗聲</button>
      </div>
    </div>`).join('');
}
function approveTaskReview(rid,uid,coins,exp){
  const reviews=LS.g('task_reviews');
  const r=reviews.find(x=>x.id===rid);if(!r)return;
  r.status='approved';LS.s('task_reviews',reviews);
  // give coins+exp to hero
  const h=LS.one('heroes','user_id',uid);
  if(h){
    let e=(h.exp||0)+exp,lv=h.level||1;
    let bh=h.base_hp,bs=h.base_str,bd=h.base_def,bsp=h.base_spd;
    if(e>=lv*600){e-=lv*600;lv++;bh+=12;bs+=6;bd+=5;bsp+=7;}
    // also mark task done
    const key=r.task_id+':'+r.date;
    const done=[...(h.tasks_done||[])];
    if(!done.includes(key))done.push(key);
    LS.upd('heroes','user_id',uid,{coins:(h.coins||0)+coins,exp:e,level:lv,base_hp:bh,base_str:bs,base_def:bd,base_spd:bsp,tasks_done:done,total_tasks_done:(h.total_tasks_done||0)+1});
    if(hero&&hero.user_id===uid){hero.coins+=coins;gainEC(exp,0);_try(renderTasks);}
  }
  $('tr-'+rid)?.remove();
  toast('脙垄脗聹脗聟 脙楼脗路脗虏脙搂脗垄脗潞脙篓脗陋脗聧 +'+coins+'脙掳脗聼脗陋脗聶 +'+exp+'EXP');
}
function rejectTaskReview(rid){
  const reviews=LS.g('task_reviews');
  const r=reviews.find(x=>x.id===rid);if(r)r.status='rejected';
  LS.s('task_reviews',reviews);
  $('tr-'+rid)?.remove();toast('脙垄脗聺脗聦 脙楼脗路脗虏脙娄脗聥脗聮脙搂脗碌脗聲');
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 END TASK ADMIN 脙垄脗聲脗聬脙垄脗聲脗聬
function loadAdminLottery(){
  const m=$('draw-month')?.value||mo();
  previewParticipants();
  const winners=getMonthWinners(m);
  const el=$('admin-winner-list');if(!el)return;
  if(!winners.length){el.innerHTML='<div class="empty">脙楼脗掳脗職脙娄脗聹脗陋脙漏脗聳脗聥脙搂脗聧脗聨</div>';return;}
  const prizes=getMonthPrizes(m);
  el.innerHTML=prizes.map(p=>{
    const pw=winners.filter(w=>w.prize_id===p.id);
    if(!pw.length) return `<div style="font-size:11px;color:var(--muted);padding:6px 0">${p.icon||'脙掳脗聼脗聨脗聛'} ${p.name}脙炉脗录脗職脙楼脗掳脗職脙娄脗聹脗陋脙漏脗聳脗聥脙搂脗聧脗聨</div>`;
    return `<div style="margin-bottom:10px">
      <div style="font-size:12px;font-weight:700;color:var(--gold);margin-bottom:5px">${p.icon||'脙掳脗聼脗聨脗聛'} ${p.name}</div>
      ${pw.map(w=>`<div class="winner-row">
        <div class="winner-ava">${w.avatar||'脙掳脗聼脗搂脗聶'}</div>
        <div style="flex:1">
          <div style="font-size:12px;font-weight:500">${w.username}</div>
          <div style="font-size:10px;color:var(--muted)">${w.user_id} 脙聜脗路 ${w.drawn_at?.slice(0,16)||''}</div>
        </div>
        <div style="font-size:10px;color:var(--teal)">脙掳脗聼脗聨脗聤 脙楼脗戮脗聴脙搂脗聧脗聨</div>
      </div>`).join('')}
    </div>`;
  }).join('');
}

