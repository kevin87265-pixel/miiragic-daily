function getTodayDrop(taskIdx){
  const d=new Date();
  const seed=d.getFullYear()*10000+((d.getMonth()+1)*100)+d.getDate();
  return DROP_POOL[(seed+taskIdx*7)%DROP_POOL.length];
}
