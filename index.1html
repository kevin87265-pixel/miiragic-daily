function getEarnedBadges(h){
  const earned=[];
  const inv=h.inventory||[];
  const duneDone=(h.dungeons_done||[]).length;
  const taskDone=h.total_tasks_done||0;
  const steps=h.total_steps||0;
  const totalPerf=h.total_perf||0;
  const visitCount=h.visit_count||0;
  const hofaCount=h.hofa_count||0;
  const evoCount=(inv.filter(x=>x.isEvolved)||[]).length;
  const cosCount=(inv.filter(x=>x.type==='costume'||['head','body','back'].includes(x.slot))).length;
  if(h.streak>=3)  earned.push('streak3');
  if(h.streak>=7)  earned.push('streak7');
  if(h.streak>=14) earned.push('streak14');
  if(h.streak>=30) earned.push('streak30');
  if(h.streak>=60) earned.push('streak60');
  if(h.streak>=90) earned.push('streak90');
  if(steps>=50000)  earned.push('steps5w');
  if(steps>=100000) earned.push('steps10w');
  if(steps>=300000) earned.push('steps30w');
  if(steps>=500000) earned.push('steps50w');
  if((h.level||1)>=5)  earned.push('lv5');
  if((h.level||1)>=10) earned.push('lv10');
  if((h.level||1)>=15) earned.push('lv15');
  if((h.level||1)>=20) earned.push('lv20');
  if(duneDone>=5)  earned.push('dung5');
  if(duneDone>=10) earned.push('dung10');
  if(duneDone>=20) earned.push('dung20');
  if(duneDone>=24) earned.push('dung_all');
  if(taskDone>=50)  earned.push('task50');
  if(taskDone>=100) earned.push('task100');
  if(taskDone>=300) earned.push('task300');
  if(taskDone>=500) earned.push('task500');
  if(cosCount>=1) earned.push('costume');
  if(cosCount>=3) earned.push('costume3');
  if(inv.some(x=>x.petDefId)) earned.push('pet');
  if(evoCount>=1) earned.push('pet_evo');
  if(evoCount>=3) earned.push('pet_evo3');
  if(visitCount>=1)  earned.push('visit');
  if(visitCount>=10) earned.push('visit10');
  if(hofaCount>=1) earned.push('hofa');
  if(hofaCount>=3) earned.push('hofa3');
  if(totalPerf>=10000)  earned.push('perf1');
  if(totalPerf>=50000)  earned.push('perf3');
  if(totalPerf>=100000) earned.push('perf5');
  return earned;
}
// 脙篓脗篓脗聢脙搂脗庐脗聴脙楼脗戮脗陆脙搂脗芦脗聽脙楼脗卤脗卢脙娄脗聙脗搂脙楼脗聤脗聽脙娄脗聢脗聬脙炉脗录脗聢脙搂脗碌脗卤脙陇脗赂脗聙脙楼脗聹脗篓recalc脙楼脗戮脗聦脙楼脗楼脗聴脙搂脗聰脗篓脙炉脗录脗聣
function getBadgeBonuses(h){
  const earned=getEarnedBadges(h);
  const bonuses={str:0,def:0,spd:0,hp:0,coins_pct:0,exp_pct:0};
  earned.forEach(id=>{
    const def=BADGE_DEFS.find(b=>b.id===id);
    if(!def)return;
    Object.entries(def.bonus||{}).forEach(([k,v])=>{
      if(bonuses[k]!==undefined)bonuses[k]+=v;
    });
  });
  return bonuses;
}
function getBadges(h){
  const earned=getEarnedBadges(h);
  return earned.map(id=>{
    const def=BADGE_DEFS.find(b=>b.id===id);
    if(!def)return null;
    return {l:def.icon+' '+def.label,c:def.c};
  }).filter(Boolean);
}
function calcWR(d,h){
  let wr=d.baseWin;
  wr+=((h.level||1)-d.reqLv)*0.035;
  const km={str:'stat_str',def:'stat_def',spd:'stat_spd',hp:'stat_hp'};
  wr+=Math.max(0,(h[km[d.key]]||0)-20)*0.0025;
  if(h.hero_class==='warrior'&&d.key==='def')wr+=0.06;
  if(h.hero_class==='mage'&&d.key==='str')wr+=0.07;
  if(h.hero_class==='archer'&&d.key==='spd')wr+=0.07;
  if(h.hero_class==='berserker')wr+=(Math.random()*0.16-0.06);
  if(h.hero_class==='monk'){const a=(h.monk_att||{})[d.id]||0;wr+=Math.min(a*0.05,0.22);}
  if(h.hero_class==='gambler')wr+=((h.luk_pct||1)*0.01)+Math.random()*0.1-0.02; // 脙篓脗鲁脗颅脙楼脗戮脗聮脙炉脗录脗職脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聤脗聽脙娄脗聢脗聬+脙漏脗職脗篓脙娄脗漏脗聼脙娄脗鲁脗垄脙楼脗聥脗聲
  if(h.hero_class==='prophet')wr+=(h.luk_pct||1)*0.008; // 脙楼脗聟脗聢脙搂脗聼脗楼脙炉脗录脗職脙搂脗漏脗漏脙楼脗庐脗職脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聤脗聽脙娄脗聢脗聬
  // 脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聙脗录脙漏脗聙脗職脙搂脗聰脗篓脙楼脗聤脗聽脙娄脗聢脗聬
  wr+=(h.luk_pct||1)*0.01;
  return Math.min(0.90,Math.max(0.04,wr));
}
// 脙楼脗鹿脗赂脙漏脗聛脗聥脙漏脗芦脗聰脙楼脗聤脗聸脙楼脗聸脗聻脙篓脗娄脗聠脙炉脗录脗聢脙娄脗聣脗聙脙娄脗聹脗聣脙篓脗隆脗聦脙楼脗聥脗聲脙楼脗戮脗聦脙楼脗聭脗录脙楼脗聫脗芦脙炉脗录脗聣
function tryLukStam(){
  if(!hero)return;
  const luk=hero.stat_luk||10;
  // 脙篓脗鲁脗颅脙楼脗戮脗聮脙漏脗隆脗聧脙楼脗陇脗聳+5%脙娄脗漏脗聼脙搂脗聨脗聡
  const rate=(luk/100)*0.3+(hero.hero_class==='gambler'?0.05:0);
  if(Math.random()<rate){
    gainStam(1);
    toast('脙掳脗聼脗聧脗聙 脙楼脗鹿脗赂脙漏脗聛脗聥脙炉脗录脗聛脙楼脗聸脗聻脙篓脗娄脗聠1脙漏脗禄脗聻脙漏脗芦脗聰脙楼脗聤脗聸');
  }
}
function calcPenalty(d,h){
  const base=d.penalty;
  const defMult=Math.max(0.3,1-(h.stat_def||10)*0.008);
  const hpMult=Math.max(0.5,1.3-(h.stat_hp||60)/150);
  return Math.max(1,Math.round(base*defMult*hpMult));
}
// 脙垄脗聲脗聬脙垄脗聲脗聬 CHARACTER DISPLAY (CSS-based, iOS compatible) 脙垄脗聲脗聬脙垄脗聲脗聬
function buildSVG(h){
  const eq=h.equipped||{};
  const cos_head=eq.head,cos_body=eq.body,cos_back=eq.back;
  const weaponItem=eq.weapon;
  const isFemale=(h.gender==='female');
  const clsColors={warrior:'#3a5a8a',mage:'#6a3a9a',archer:'#3a7a4a',assassin:'#2a2a3a',paladin:'#7a6a2a',berserker:'#8a3a2a',monk:'#7a6a3a',ranger:'#3a6a4a'};
  const bodyCol=clsColors[h.hero_class||'warrior'];
  // 脙搂脗聰脗路脙楼脗楼脗鲁脙楼脗陇脗聳脙篓脗搂脗聙脙楼脗路脗庐脙搂脗聲脗掳
  const skinCol=isFemale?'#f2d4bb':'#e8c99a';
  const hairCol=isFemale?'#3a1a2a':'#5a3a2a'; // 脙楼脗楼脗鲁脙炉脗录脗職脙娄脗路脗卤脙娄脗拢脗聲/脙漏脗禄脗聭脙炉脗录脗聦脙搂脗聰脗路脙炉脗录脗職脙娄脗拢脗聲
  const hairStyle=isFemale
    ?`<div style="width:52px;height:16px;background:${hairCol};border-radius:26px 26px 0 0;position:relative;top:6px;z-index:2;margin:0 auto"></div>
       <div style="position:absolute;top:4px;left:-8px;width:10px;height:42px;background:${hairCol};border-radius:5px;z-index:2"></div>
       <div style="position:absolute;top:4px;right:-8px;width:10px;height:42px;background:${hairCol};border-radius:5px;z-index:2"></div>`
    :`<div style="width:50px;height:14px;background:${hairCol};border-radius:25px 25px 0 0;position:relative;top:6px;z-index:2;margin:0 auto"></div>
       <div style="position:absolute;top:6px;left:-4px;width:10px;height:28px;background:${hairCol};border-radius:5px;z-index:2"></div>
       <div style="position:absolute;top:6px;right:-4px;width:10px;height:28px;background:${hairCol};border-radius:5px;z-index:2"></div>`;
  const faceSize=isFemale?'46':'48';
  const eyeStyle=isFemale
    ?`<div style="display:flex;gap:9px;margin-top:-6px">
        <div style="width:5px;height:6px;background:#2a1a1a;border-radius:50%;border-bottom:1px solid #ff9eb5"></div>
        <div style="width:5px;height:6px;background:#2a1a1a;border-radius:50%;border-bottom:1px solid #ff9eb5"></div>
      </div>
      <div style="position:absolute;bottom:9px;width:12px;height:4px;border-bottom:2px solid #cc8888;border-radius:0 0 8px 8px"></div>`
    :`<div style="display:flex;gap:10px;margin-top:-4px">
        <div style="width:5px;height:5px;background:#3a2a1a;border-radius:50%"></div>
        <div style="width:5px;height:5px;background:#3a2a1a;border-radius:50%"></div>
      </div>
      <div style="position:absolute;bottom:10px;width:14px;height:5px;border-bottom:2px solid #9a7060;border-radius:0 0 8px 8px"></div>`;
  const bodyShape=isFemale
    ?`<div style="position:relative;z-index:3;width:40px;height:38px;background:${bodyCol};border-radius:6px 6px 10px 10px">`
    :`<div style="position:relative;z-index:3;width:44px;height:40px;background:${bodyCol};border-radius:6px">`;
  const legStyle=isFemale
    ?`<div style="position:absolute;top:118px;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:4px">
        <div style="width:14px;height:26px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="width:16px;height:7px;background:#8a6060;border-radius:3px;margin-left:-1px"></div>
        </div>
        <div style="width:14px;height:26px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="width:16px;height:7px;background:#8a6060;border-radius:3px;margin-left:-1px"></div>
        </div>
      </div>`
    :`<div style="position:absolute;top:122px;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:4px">
        <div style="width:16px;height:24px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="width:18px;height:8px;background:#4a3a2a;border-radius:3px;margin-left:-1px"></div>
        </div>
        <div style="width:16px;height:24px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="width:18px;height:8px;background:#4a3a2a;border-radius:3px;margin-left:-1px"></div>
        </div>
      </div>`;

  // wings behind
  let backEl='';
  if(cos_back){
    const wc=cos_back.color||'#70b8ff';
    backEl=`<div style="position:absolute;top:22px;left:0;right:0;display:flex;justify-content:space-between;pointer-events:none;z-index:0">
      <div style="width:22px;height:44px;border-radius:50% 0 0 50%;background:${wc};opacity:.85;transform:rotate(-15deg);transform-origin:right center"></div>
      <div style="width:22px;height:44px;border-radius:0 50% 50% 0;background:${wc};opacity:.85;transform:rotate(15deg);transform-origin:left center"></div>
    </div>`;
  }

  // cape
  let capeEl='';
  if(cos_body){
    const cc=cos_body.color||'#f0d060';
    capeEl=`<div style="position:absolute;top:52px;left:8px;right:8px;bottom:20px;background:${cc};opacity:.75;border-radius:4px 4px 8px 8px;z-index:1"></div>`;
  }

  // head costume
  let headEl='';
  if(cos_head){
    const hc=cos_head.color||'#f0d060';
    const hico=cos_head.icon||'脙掳脗聼脗聭脗聭';
    headEl=`<div style="position:absolute;top:-6px;left:50%;transform:translateX(-50%);font-size:18px;z-index:5;filter:drop-shadow(0 0 4px ${hc})">${hico}</div>`;
  }

  // weapon
  let weapEl='';
  if(weaponItem){
    weapEl=`<div style="position:absolute;bottom:30px;right:2px;font-size:16px;z-index:5;transform:rotate(30deg)">${weaponItem.icon}</div>`;
  }

  // pet on char
  const petSlot=eq.pet;
  const petIco=petSlot?(PET_DEF.find(p=>p.id===petSlot.petDefId)?.icon||petSlot.icon||'脙掳脗聼脗聬脗戮'):'';

  return `<div style="position:relative;width:120px;height:150px;overflow:hidden">
    ${backEl}
    ${capeEl}
    <!-- head area -->
    <div style="position:absolute;top:14px;left:50%;transform:translateX(-50%);z-index:3;width:54px">
      ${headEl}
      <!-- hair top -->
      <div style="width:50px;height:14px;background:#5a3a2a;border-radius:25px 25px 0 0;position:relative;top:6px;z-index:2;margin:0 auto"></div>
      <!-- face -->
      <div style="width:48px;height:48px;background:#e8c99a;border-radius:50%;border:2px solid #c9a090;position:relative;z-index:3;display:flex;align-items:center;justify-content:center;margin:0 auto">
        <!-- eyes -->
        <div style="display:flex;gap:10px;margin-top:-4px">
          <div style="width:5px;height:5px;background:#3a2a1a;border-radius:50%"></div>
          <div style="width:5px;height:5px;background:#3a2a1a;border-radius:50%"></div>
        </div>
        <!-- mouth -->
        <div style="position:absolute;bottom:10px;width:14px;height:5px;border-bottom:2px solid #9a7060;border-radius:0 0 8px 8px"></div>
      </div>
      <!-- hair sides -->
      <div style="position:absolute;top:6px;left:-2px;width:10px;height:28px;background:#5a3a2a;border-radius:5px;z-index:2"></div>
      <div style="position:absolute;top:6px;right:-2px;width:10px;height:28px;background:#5a3a2a;border-radius:5px;z-index:2"></div>
    </div>
    <!-- body -->
    <div style="position:absolute;top:84px;left:50%;transform:translateX(-50%);z-index:3;width:44px;height:40px;background:${bodyCol};border-radius:6px">
      ${weapEl}
      <div style="position:absolute;left:-12px;top:4px;width:12px;height:28px;background:${bodyCol};border-radius:6px"></div>
      <div style="position:absolute;right:-12px;top:4px;width:12px;height:28px;background:${bodyCol};border-radius:6px"></div>
      <div style="position:absolute;left:-14px;bottom:0;width:10px;height:10px;background:#e8c99a;border-radius:50%"></div>
      <div style="position:absolute;right:-14px;bottom:0;width:10px;height:10px;background:#e8c99a;border-radius:50%"></div>
    </div>
    <!-- legs -->
    <div style="position:absolute;top:124px;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:4px">
      <div style="width:16px;height:22px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
        <div style="width:18px;height:8px;background:#4a3a2a;border-radius:3px;margin-left:-1px"></div>
      </div>
      <div style="width:16px;height:22px;background:${bodyCol};border-radius:4px;display:flex;flex-direction:column;justify-content:flex-end">
        <div style="width:18px;height:8px;background:#4a3a2a;border-radius:3px;margin-left:-1px"></div>
      </div>
    </div>
    <!-- lv badge -->
    <div style="position:absolute;bottom:3px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.7);border-radius:8px;padding:1px 8px;font-size:9px;color:#f0d060;font-weight:700;z-index:10;white-space:nowrap">Lv.${h.level||1}</div>
    <!-- pet badge -->
    ${petIco?`<div style="position:absolute;bottom:20px;right:4px;font-size:17px;z-index:10;filter:drop-shadow(0 1px 3px rgba(0,0,0,.9))">${petIco}</div>`:''}
  </div>`;
}


function renderSVG(){
  if(!hero)return;
  const canvas=$('char-canvas');
  if(canvas) canvas.innerHTML=buildSVG(hero);
}
