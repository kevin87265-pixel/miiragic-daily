const $=id=>document.getElementById(id);
function toast(m,type){
  const e=$('toast');
  // 脙搂脗搂脗禄脙漏脗聶脗陇脙娄脗聣脗聙脙娄脗聹脗聣脙漏脗隆脗聻脙楼脗聻脗聥 class
  e.classList.remove('show','t-fail','t-warn','t-info','t-level');
  // 脙篓脗聡脗陋脙楼脗聥脗聲脙楼脗聢脗陇脙娄脗聳脗路脙漏脗隆脗聻脙楼脗聻脗聥
  if(!type){
    if(/脙垄脗聺脗聦|脙楼脗陇脗卤脙娄脗聲脗聴|脙漏脗聦脗炉脙篓脗陋脗陇|脙娄脗聥脗聮脙搂脗碌脗聲|脙陇脗赂脗聧脙篓脗露脗鲁|脙漏脗聦脗炉脙篓脗陋脗陇/.test(m)) type='fail';
    else if(/脙垄脗職脗聽脙炉脗赂脗聫|脙篓脗颅脗娄脙楼脗聭脗聤|脙楼脗聠脗路脙楼脗聧脗禄|脙楼脗戮脗聟脙楼脗炉脗漏/.test(m)) type='warn';
    else if(/脙掳脗聼脗聨脗聣 脙楼脗聧脗聡脙楼脗聢脗掳|LEVEL|Lv\./.test(m)&&/脙楼脗聧脗聡脙楼脗聢脗掳/.test(m)) type='level';
  }
  if(type) e.classList.add('t-'+type);
  // 脙楼脗聹脗聳脙搂脗陇脗潞脙楼脗聣脗聧脙搂脗露脗麓
  const icons={fail:'',warn:'',info:'脙垄脗聞脗鹿脙炉脗赂脗聫 ',level:'脙掳脗聼脗聦脗聼 '};
  e.textContent=(icons[type]||'')+m;
  void e.offsetWidth; // reflow
  e.classList.add('show');
  clearTimeout(e._t);
  e._t=setTimeout(()=>e.classList.remove('show'),type==='level'?3200:2600);
}
function ld(v){let o=$('lov-el');if(v){if(!o){o=document.createElement('div');o.id='lov-el';o.className='lov';o.innerHTML='<div class="spin"></div>';document.body.appendChild(o);}}else o?.remove();}
function hsh(s){let h=0;for(let i=0;i<s.length;i++){h=((h<<5)-h)+s.charCodeAt(i);h|=0;}return Math.abs(h).toString(16);}
function tod(){return new Date().toISOString().slice(0,10);}
function wk(){const d=new Date();const day=d.getDay()||7;d.setDate(d.getDate()-day+1);return d.toISOString().slice(0,10);}
function mo(){return new Date().toISOString().slice(0,7);}
// 脙垄脗聰脗聙脙垄脗聰脗聙 脙漏脗芦脗聰脙楼脗聤脗聸脙楼脗赂脗赂脙娄脗聲脗赂 脙垄脗聰脗聙脙垄脗聰脗聙
const STAM_MAX_BASE=20;
const STAM_RECOVER_PER_HOUR=2;

function getStamMax(h){
  let max=STAM_MAX_BASE;
  const tier=getHeroTier(h);
  max+=(tier.dailyStam||0);
  // pet skill bonus
  const pet=(h.equipped||{}).pet;
  if(pet){
    if(pet.evolvedFrom==='p4'&&pet.isEvolved) max+=10;
    if(pet.petDefId==='p4'&&(pet.level||1)>=20) max+=10;
  }
  // stam_up equipment
  Object.values(h.equipped||{}).forEach(it=>{
    if(it&&it.stam_up) max+=it.stam_up;
  });
  return max;
}

function getStamNow(h){
  const max=getStamMax(h);
  const last=h.stam_last_time||Date.now();
  const stored=h.stam_stored||max;
  const elapsed=(Date.now()-last)/3600000; // hours
  let bonus=STAM_RECOVER_PER_HOUR;
  // hawk lv10 +1/hr, evolved hawk +2/hr
  const pet=(h.equipped||{}).pet;
  if(pet){
    const lv=pet.level||1;
    if(pet.petDefId==='p7'&&lv>=10)bonus+=1;
    if(pet.isEvolved&&pet.evolvedFrom==='p7')bonus+=2;
  }
  return Math.min(max, stored+elapsed*bonus);
}

function saveStam(h, newVal){
  h.stam_stored=newVal;
  h.stam_last_time=Date.now();
}

function getPetDef(pet){
  if(!pet)return null;
  if(pet.isEvolved)return PET_EVOLVED[pet.evoId]||null;
  return PET_DEF.find(p=>p.id===pet.petDefId)||null;
}

function getPetBonus(pet){
  if(!pet)return{};
  const pd=getPetDef(pet);if(!pd)return{};
  const lv=pet.level||1;
  const base=pd.bonus||{};
  let mult=1+(lv-1)*0.12;
  // milestone multipliers
  if(!pet.isEvolved){
    const pdef=PET_DEF.find(p=>p.id===pet.petDefId);
    if(pdef){
      if(pdef.rarity===1&&lv>=8)mult*=1.3;
      if(pdef.rarity===2&&lv>=15)mult*=1.5;
      if(pdef.rarity===3&&lv>=15)mult*=1.4;
      if(pdef.rarity===3&&lv>=20)mult*=2;
    }
  }
  const result={};
  Object.entries(base).forEach(([k,v])=>result[k]=Math.round(v*mult));
  return result;
}

function recalc(h){
  h.stat_hp=h.base_hp;h.stat_str=h.base_str;h.stat_def=h.base_def;h.stat_spd=h.base_spd;
  // 脙娄脗聶脗庐脙漏脗聙脗職脙篓脗拢脗聺脙楼脗聜脗聶脙楼脗聤脗聽脙娄脗聢脗聬
  Object.values(h.equipped||{}).forEach(it=>{
    if(!it)return;
    if(it.stat)h['stat_'+it.stat]=(h['stat_'+it.stat]||0)+it.val;
    // bonus_all (脙楼脗庐脗聡脙楼脗庐脗聶脙篓脗聝脗陆脙漏脗聡脗聫脙娄脗聽脗赂脙楼脗驴脗聝脙搂脗颅脗聣)
    if(it.bonus_all){h.stat_str+=it.bonus_all;h.stat_def+=it.bonus_all;h.stat_spd+=it.bonus_all;h.stat_hp+=it.bonus_all*3;}
  });
  // 脙娄脗聶脗聜脙篓脗拢脗聺脙楼脗卤脗卢脙娄脗聙脗搂脙楼脗聤脗聽脙娄脗聢脗聬
  const COSTUME_BONUSES={
    head: {spd:8},   // 脙漏脗聽脗颅脙漏脗拢脗戮+SPD
    body: {def:10},  // 脙篓脗隆脗拢脙篓脗拢脗聺+DEF
    back: {exp_pct:5,coins_pct:5}, // 脙篓脗聝脗聦脙漏脗拢脗戮+EXP+脙漏脗聡脗聭脙楼脗鹿脗拢%
  };
  const COSTUME_SPECIAL={
    '脙楼脗庐脗聡脙楼脗庐脗聶脙娄脗聢脗掳脙篓脗垄脗聧':    {spd:15,def:15},
    '脙搂脗楼脗聻脙楼脗聼脗聼脙娄脗聤脗芦脙漏脗垄脗篓':    {spd:20,coins_pct:10},
    '脙娄脗颅脗禄脙搂脗楼脗聻脙漏脗聺脗垄脙楼脗聟脗路':    {str:15,coins_pct:8},
    '脙楼脗陇脗陋脙漏脗聶脗陆脙搂脗楼脗聻脙楼脗聠脗聽':    {spd:12,exp_pct:10},
    '脙楼脗聜脗鲁脙篓脗陋脗陋脙搂脗聨脗聥脙楼脗聠脗聽':    {str:8,def:8},
    '脙搂脗楼脗聻脙漏脗戮脗聧脙娄脗聢脗掳脙搂脗聰脗虏':    {str:12,def:12},
    '脙娄脗聵脗聼脙楼脗隆脗碌脙篓脗聫脗炉脙娄脗聹脗聧':    {spd:10,coins_pct:8},
    '脙搂脗聧脗篓脙篓脗搂脗聮脙搂脗聧脗赂脙搂脗驴脗聟脙篓脗聠脗聙':  {hp:40,exp_pct:8},
    '脙娄脗聝脗隆脙漏脗颅脗聰脙楼脗楼脗聴脙篓脗拢脗聺':    {str:15},
    '脙楼脗陇脗漏脙陇脗陆脗驴脙搂脗驴脗聟脙篓脗聠脗聙':    {hp:30,exp_pct:10},
    '脙搂脗聝脗聢脙搂脗聞脗掳脙搂脗驴脗聟脙篓脗聠脗聙':    {str:10,spd:8},
    '脙娄脗聹脗聢脙搂脗楼脗聻脙娄脗鲁脗聲脙篓脗隆脗拢':    {spd:12,coins_pct:6},
  };
  ['head','body','back'].forEach(slot=>{
    const cos=(h.equipped||{})[slot];
    if(!cos)return;
    // 脙楼脗聼脗潞脙搂脗陇脗聨脙楼脗聤脗聽脙娄脗聢脗聬
    const base=COSTUME_BONUSES[slot]||{};
    Object.entries(base).forEach(([k,v])=>{
      if(k==='exp_pct'||k==='coins_pct'){h[k]=(h[k]||0)+v;}
      else h['stat_'+k]=(h['stat_'+k]||0)+v;
    });
    // 脙搂脗聣脗鹿脙娄脗庐脗聤脙楼脗聤脗聽脙娄脗聢脗聬
    const special=COSTUME_SPECIAL[cos.name]||{};
    Object.entries(special).forEach(([k,v])=>{
      if(k==='exp_pct'||k==='coins_pct'){h[k]=(h[k]||0)+v;}
      else h['stat_'+k]=(h['stat_'+k]||0)+v;
    });
  });
  // 脙楼脗炉脗碌脙搂脗聣脗漏脙楼脗聤脗聽脙娄脗聢脗聬
  const petSlot=(h.equipped||{}).pet;
  if(petSlot){
    const bonus=getPetBonus(petSlot);
    Object.entries(bonus).forEach(([k,v])=>h['stat_'+k]=(h['stat_'+k]||0)+v);
  }
  // 脙楼脗戮脗陆脙搂脗芦脗聽脙楼脗卤脗卢脙娄脗聙脗搂脙楼脗聤脗聽脙娄脗聢脗聬
  const badgeBonuses=getBadgeBonuses(h);
  h.stat_str+=badgeBonuses.str||0;
  h.stat_def+=badgeBonuses.def||0;
  h.stat_spd+=badgeBonuses.spd||0;
  h.stat_hp+=badgeBonuses.hp||0;
  h.badge_coins_pct=(h.coins_pct||0)+(badgeBonuses.coins_pct||0);
  h.badge_exp_pct=(h.exp_pct||0)+(badgeBonuses.exp_pct||0);
  // 脙搂脗篓脗卤脙篓脗聶脗聼脙楼脗卤脗卢脙娄脗聙脗搂脙楼脗聤脗聽脙娄脗聢脗聬脙炉脗录脗聢脙搂脗颅脗聣脙搂脗麓脗職脙搂脗篓脗卤脙篓脗聶脗聼脙炉脗录脗聣
  const titleBonus=getTitleBonus(h.level||1);
  h.stat_str+=(titleBonus.str||0);
  h.stat_def+=(titleBonus.def||0);
  h.stat_spd+=(titleBonus.spd||0);
  h.stat_hp+=(titleBonus.hp||0);
  h.badge_coins_pct+=(titleBonus.coins_pct||0);
  h.badge_exp_pct+=(titleBonus.exp_pct||0);
  // 脙娄脗聢脗聬脙楼脗掳脗卤脙搂脗篓脗卤脙篓脗聶脗聼脙楼脗聤脗聽脙娄脗聢脗聬
  getAchievementTitles(h).forEach(t=>{
    const b=t.bonus||{};
    h.stat_str+=(b.str||0);h.stat_def+=(b.def||0);
    h.stat_spd+=(b.spd||0);h.stat_hp+=(b.hp||0);
    h.badge_coins_pct+=(b.coins_pct||0);
    h.badge_exp_pct+=(b.exp_pct||0);
  });
  // 脙娄脗赂脗聟脙漏脗聶脗陇脙篓脗聡脗篓脙娄脗聶脗聜pct
  h.coins_pct=0; h.exp_pct=0;
  // 脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聙脗录脙炉脗录脗職base(脙篓脗聛脗路脙娄脗楼脗颅) + 脙篓脗拢脗聺脙楼脗聜脗聶脙楼脗聤脗聽脙娄脗聢脗聬 + 脙漏脗聛脗聯脙楼脗聟脗路脙搂脗麓脗炉脙搂脗漏脗聧
  const clsDef=CLASS_DEF[h.hero_class||'warrior'];
  h.stat_luk=(h.base_luk||clsDef.luk||10)+(h.luk_bonus||0);
  h.stat_luk=Math.min(100,h.stat_luk);
  // 脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聤脗聽脙娄脗聢脗聬脙娄脗漏脗聼脙搂脗聨脗聡 = 1%~5%脙炉脗录脗聢脙娄脗炉脗聫20脙漏脗禄脗聻脙楼脗鹿脗赂脙漏脗聛脗聥+1%脙炉脗录脗聣
  h.luk_pct=Math.min(5,Math.max(1,Math.floor(h.stat_luk/20)+1));
}
function updStamina(){
  if(!hero)return;
  const max=getStamMax(hero);
  const cur=getStamNow(hero);
  const pct=Math.min(100,(cur/max)*100);
  const curRound=Math.floor(cur);
  $('stam-fill').style.width=pct+'%';
  $('stam-txt').textContent=curRound+'/'+max;
  const minToNext=cur<max?Math.ceil((1-(cur%1))/STAM_RECOVER_PER_HOUR*60):0;
  $('stam-recover').textContent=cur>=max?'脙楼脗路脗虏脙娄脗禄脗驴':'脙娄脗聛脗垄脙楼脗戮脗漏脙陇脗赂脗颅 '+minToNext+'脙楼脗聢脗聠脙楼脗戮脗聦+1';
  $('stam-fill').style.background=cur/max>0.5?'linear-gradient(90deg,#16a085,#1abc9c)':cur/max>0.2?'linear-gradient(90deg,#e67e22,#f39c12)':'linear-gradient(90deg,#c0392b,#e74c3c)';
}
function consumeStam(n){
  const cur=getStamNow(hero);
  saveStam(hero, Math.max(0, cur-n));
  updStamina();
}
function gainStam(n){
  const cur=getStamNow(hero);
  const max=getStamMax(hero);
  saveStam(hero, Math.min(max, cur+n));
  updStamina();
}
// pet daily bonus (unicorn lv10+)
function applyDailyPetBonus(){
  const pet=(hero.equipped||{}).pet;
  if(!pet)return;
  const lv=pet.level||1;
  const lastBonus=hero.pet_daily_bonus_date;
  if(lastBonus===tod())return;
  hero.pet_daily_bonus_date=tod();
  // unicorn lv10+: +2 stamina
  if(!pet.isEvolved&&pet.petDefId==='p5'&&lv>=10){gainStam(2);toast('脙掳脗聼脗娄脗聞 脙搂脗聧脗篓脙篓脗搂脗聮脙搂脗聧脗赂脙搂脗聜脗潞脙陇脗陆脗聽脙娄脗聛脗垄脙楼脗戮脗漏脙陇脗潞脗聠2脙漏脗禄脗聻脙漏脗芦脗聰脙楼脗聤脗聸脙炉脗录脗聛');}
  if(pet.isEvolved&&pet.evolvedFrom==='p5'){gainStam(5);toast('脙掳脗聼脗聦脗聢 脙楼脗陆脗漏脙篓脗聶脗鹿脙搂脗聧脗篓脙篓脗搂脗聮脙搂脗聧脗赂脙娄脗聛脗垄脙楼脗戮脗漏5脙漏脗芦脗聰脙楼脗聤脗聸 +30脙掳脗聼脗陋脗聶脙炉脗录脗聛');hero.coins+=30;updCoins();}
  // unicorn lv5+: +10 coins
  if(!pet.isEvolved&&pet.petDefId==='p5'&&lv>=5){hero.coins+=10;updCoins();}
  save();
}
