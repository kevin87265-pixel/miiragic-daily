function getTitle(lv){
  const t=TITLES.filter(x=>x.req==='lv'&&lv>=x.lv);
  return t.length?t[t.length-1].t:'脙楼脗聢脗聺脙楼脗驴脗聝脙篓脗聙脗聟';
}
function getTitleObj(lv){
  const t=TITLES.filter(x=>x.req==='lv'&&lv>=x.lv);
  return t.length?t[t.length-1]:TITLES[0];
}
function getTitleBonus(lv){return getTitleObj(lv).bonus||{};}
function getAchievementTitles(h){
  return TITLES.filter(t=>{
    if(t.req==='lv') return false;
    if(t.req==='streak') return (h.streak||0)>=t.val;
    if(t.req==='steps')  return (h.total_steps||0)>=t.val;
    if(t.req==='dung')   return (h.dungeons_done||[]).length>=t.val;
    if(t.req==='task')   return (h.total_tasks_done||0)>=t.val;
    if(t.req==='badge')  return (h.badges_earned||[]).includes(t.val);
    if(t.req==='pet_evo')return (h.inventory||[]).some(x=>x.isEvolved);
    if(t.req==='gacha')  return (h.total_gacha||0)>=t.val;
    return false;
  });
}

