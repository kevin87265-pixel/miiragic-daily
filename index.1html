function gTab(n){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  $('sec-'+n).classList.add('active');
  const tabs=['hero','checkin','tasks','dungeon','shop','gacha','pet','perf','member','lottery','lb','notice'];
  document.querySelectorAll('.tab')[tabs.indexOf(n)]?.classList.add('active');
  if(n==='lb')loadLb();
  if(n==='pet')renderPets();
  if(n==='member')renderMember();
  if(n==='lottery'){_try(renderLottery);}
  if(n==='notice'){_try(renderNotices);}
}// 脙垄脗聲脗聬脙垄脗聲脗聬 ADMIN TOGGLE 脙垄脗聲脗聬脙垄脗聲脗聬
function openAdminPrompt(){
  const pw=prompt('脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙楼脗炉脗聠脙搂脗垄脗录脙炉脗录脗職');
  if(pw===ADMIN_PW||pw===ADMIN_SUPER_PW){
    isAdmin=true;
    const ap=$('admin-panel');
    ap.style.display=ap.style.display==='none'?'block':'none';
    if(ap.style.display==='block'){switchAdmin('dashboard');populatePerfHeroSel();}
  } else if(pw!==null){
    toast('脙楼脗炉脗聠脙搂脗垄脗录脙漏脗聦脗炉脙篓脗陋脗陇','fail');
  }
}
let holdT=null;
document.addEventListener('DOMContentLoaded',()=>{
  // 脙漏脗聲脗路脙娄脗聦脗聣脙娄脗篓脗聶脙漏脗隆脗聦 2 脙搂脗搂脗聮脙篓脗搂脗赂脙搂脗聶脗录
  const ttl=$('top-ttl');
  if(ttl){
    ttl.addEventListener('pointerdown',()=>{holdT=setTimeout(openAdminPrompt,2000);});
    ttl.addEventListener('pointerup',()=>clearTimeout(holdT));
    ttl.addEventListener('pointerleave',()=>clearTimeout(holdT));
    ttl.addEventListener('contextmenu',e=>{e.preventDefault();openAdminPrompt();});
  }
  // set default month
  const inp=$('perf-month-inp');if(inp)inp.value=mo();
  const jinp=$('mem-join-date-inp');if(jinp)jinp.value=tod();
});
// 脙垄脗聲脗聬脙垄脗聲脗聬 TEST ACCOUNT 脙垄脗聲脗聬脙垄脗聲脗聬
function ensureTest(){
  try{
    const uid='123';
    const pw=hsh('123'+uid+'hd2025');
    const base=CLASS_DEF['berserker']||{hp:70,str:38,def:5,spd:17};
    const testData={
      user_id:uid,username:'脙娄脗赂脗卢脙篓脗漏脗娄脙楼脗聥脗聡脙篓脗聙脗聟K',password_hash:pw,avatar:'脙掳脗聼脗聬脗聣',hero_class:'berserker',
      level:3,exp:50,coins:2000,
      stat_hp:base.hp,stat_str:base.str,stat_def:base.def,stat_spd:base.spd,
      base_hp:base.hp,base_str:base.str,base_def:base.def,base_spd:base.spd,
      streak:5,total_steps:18000,total_perf:0,
      week_days:[true,true,true,false,false,false,false],
      inventory:[
        {id:'pet_p1_test',petDefId:'p1',name:'脙漏脗聺脗聢脙篓脗虏脗聯',icon:'脙掳脗聼脗聬脗卤',level:5,exp:20,slot:'pet',uid:'pet_p1_test'},
        {id:'pet_p1_test2',petDefId:'p1',name:'脙漏脗聺脗聢脙篓脗虏脗聯',icon:'脙掳脗聼脗聬脗卤',level:10,exp:0,slot:'pet',uid:'pet_p1_test2'},
      ],
      equipped:{
        pet:{id:'pet_p1_test',petDefId:'p1',name:'脙漏脗聺脗聢脙篓脗虏脗聯',icon:'脙掳脗聼脗聬脗卤',level:5,exp:20,slot:'pet',uid:'pet_p1_test'},
      },
