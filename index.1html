<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<script>
// 脙楼脗聟脗篓脙楼脗聼脗聼脙漏脗聦脗炉脙篓脗陋脗陇脙娄脗聰脗聰脙娄脗聢脗陋 脙垄脗聙脗聰 脙漏脗隆脗炉脙搂脗陇脗潞脙楼脗聹脗篓脙搂脗聲脗芦脙漏脗聺脗垄脙陇脗赂脗聤脙娄脗聳脗鹿脙陇脗戮脗驴脙漏脗聶脗陇脙漏脗聦脗炉
window.onerror=function(msg,src,line,col,err){
  const d=document.createElement('div');
  d.style.cssText='position:fixed;top:0;left:0;right:0;background:#e74c3c;color:#fff;padding:8px 12px;font-size:12px;z-index:99999;word-break:break-all';
  d.textContent='脙垄脗聺脗聦 JS脙漏脗聦脗炉脙篓脗陋脗陇 line'+line+': '+msg;
  document.body?.appendChild(d);
  return false;
};
</script>
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>MIIRAGIC DAILY</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Cinzel:wght@700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --gold:#c9a227;--gold2:#f0d060;--dark:#1a1410;--panel:#231e18;
  --panel2:#2e2720;--border:rgba(201,162,39,0.3);--text:#f0e8d0;--muted:#9a8e7a;
  --green:#2ecc71;--red:#e74c3c;--purple:#d4a0ff;--blue:#70b8ff;--teal:#1abc9c;--orange:#e67e22;
}
html,body{background:var(--dark);color:var(--text);font-family:'Noto Sans TC',sans-serif;font-size:14px;min-height:100vh;}
#app{max-width:480px;margin:0 auto;padding-bottom:20px;}

/* AUTH */
#auth{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:20px;}
#auth h1{font-family:'Cinzel',serif;font-size:26px;color:var(--gold);letter-spacing:3px;margin-bottom:4px;}
#auth p{font-size:12px;color:var(--muted);margin-bottom:24px;}
.abox{width:100%;max-width:360px;background:var(--panel2);border:1px solid var(--border);border-radius:16px;padding:20px;}
.atabs{display:flex;margin-bottom:16px;border-bottom:1px solid var(--border);}
.atab{flex:1;padding:8px;text-align:center;font-size:13px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;}
.atab.active{color:var(--gold);border-bottom-color:var(--gold);}
.fg{margin-bottom:12px;}
.fg label{font-size:11px;color:var(--muted);display:block;margin-bottom:4px;}
.fg input,.fg select{width:100%;background:#111;border:1px solid var(--border);color:var(--text);padding:9px 11px;border-radius:8px;font-size:14px;font-family:inherit;outline:none;}
.fg input:focus{border-color:var(--gold);}
.av-grid{display:flex;gap:7px;flex-wrap:wrap;margin-top:4px;}
.av-o{width:40px;height:40px;border-radius:50%;border:2px solid var(--border);background:#111;display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;}
.av-o.sel{border-color:var(--gold);background:rgba(201,162,39,.15);}
.cls-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:4px;}
.cls-o{background:#111;border:1px solid var(--border);border-radius:8px;padding:8px;cursor:pointer;text-align:center;}
.cls-o.sel{border-color:var(--gold);background:rgba(201,162,39,.1);}
.cls-o .ci{font-size:18px;}
.cls-o .cn{font-size:11px;font-weight:700;color:var(--gold2);margin:2px 0;}
.cls-o .cd{font-size:9px;color:var(--muted);line-height:1.3;}
.btn-g{width:100%;padding:12px;background:linear-gradient(90deg,#c9a227,#f0d060);color:#1a1410;font-size:14px;font-weight:700;border:none;border-radius:10px;cursor:pointer;font-family:inherit;margin-top:4px;}
.aerr{font-size:12px;color:var(--red);text-align:center;margin-top:6px;min-height:16px;}
.test-hint{margin-top:9px;padding:7px 10px;background:#111;border-radius:8px;font-size:11px;color:var(--muted);}

/* TOPBAR */
.topbar{background:var(--panel);border-bottom:1px solid var(--border);padding:8px 13px;display:flex;flex-direction:column;gap:5px;position:sticky;top:0;z-index:100;}
.topbar h1{font-family:'Cinzel',serif;font-size:13px;color:var(--gold);letter-spacing:2px;}
.coin-badge{display:flex;align-items:center;gap:4px;background:var(--panel2);border:1px solid var(--border);border-radius:20px;padding:3px 9px;font-weight:700;color:var(--gold2);font-size:13px;}
.logout{background:transparent;border:1px solid var(--border);color:var(--muted);padding:3px 7px;border-radius:6px;cursor:pointer;font-size:11px;font-family:inherit;}

/* TABS */
.tabs{display:flex;background:var(--panel);border-bottom:1px solid var(--border);position:sticky;top:63px;z-index:99;overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex-shrink:0;padding:7px 6px;text-align:center;font-size:9px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;min-width:48px;}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab span{display:block;font-size:14px;}

.sec{display:none;padding:13px;padding-bottom:24px;}
.sec.active{display:block;}
.card{background:var(--panel2);border:1px solid var(--border);border-radius:12px;padding:12px;margin-bottom:10px;}
.card h3{font-size:13px;color:var(--gold);margin-bottom:8px;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 SVG CHARACTER DISPLAY 脙垄脗聲脗聬脙垄脗聲脗聬 */
.char-stage{display:flex;gap:16px;align-items:flex-start;margin-bottom:12px;}
.char-canvas{position:relative;width:120px;height:150px;flex-shrink:0;background:linear-gradient(180deg,#1e1a12 0%,#2e2518 100%);border-radius:12px;border:1px solid var(--border);overflow:hidden;display:flex;align-items:center;justify-content:center;}
#svg-char{width:120px;height:150px;}
.char-info{flex:1;}
.char-info h2{font-size:16px;font-weight:700;color:var(--gold2);}
.hero-title-txt{font-size:11px;color:var(--purple);margin-top:2px;}
.hero-cls-txt{font-size:10px;color:var(--muted);margin-top:1px;}
.badges{display:flex;gap:4px;flex-wrap:wrap;margin-top:5px;}
.badge{font-size:9px;padding:2px 6px;border-radius:8px;border:1px solid;}
.badge.gold{border-color:var(--gold);color:var(--gold);background:rgba(201,162,39,.1);}
.badge.purple{border-color:var(--purple);color:var(--purple);background:rgba(212,160,255,.1);}
.badge.green{border-color:var(--green);color:var(--green);background:rgba(46,204,113,.1);}
.badge.blue{border-color:var(--blue);color:var(--blue);background:rgba(112,184,255,.1);}
.badge.red{border-color:var(--red);color:var(--red);background:rgba(231,76,60,.1);}
.badge.orange{border-color:var(--orange);color:var(--orange);background:rgba(230,126,34,.1);}

/* pet on character */
.pet-on-char{position:absolute;bottom:4px;right:4px;font-size:20px;filter:drop-shadow(0 0 4px rgba(0,0,0,.8));}

/* stats */
.bar-bg{background:#111;border-radius:4px;height:6px;overflow:hidden;}
.bar-fill{height:100%;border-radius:4px;transition:width .5s;}
.b-gold{background:linear-gradient(90deg,#c9a227,#f0d060);}
.b-red{background:linear-gradient(90deg,#c0392b,#e74c3c);}
.b-orange{background:linear-gradient(90deg,#e67e22,#f39c12);}
.b-green{background:linear-gradient(90deg,#27ae60,#2ecc71);}
.b-blue{background:linear-gradient(90deg,#2980b9,#3498db);}
.b-purple{background:linear-gradient(90deg,#8e44ad,#9b59b6);}
.b-teal{background:linear-gradient(90deg,#16a085,#1abc9c);}
.stats-g{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:10px 0;}
.si{background:var(--panel2);border-radius:8px;padding:7px 8px;}
.si .sl{font-size:10px;color:var(--muted);margin-bottom:3px;}
.si .sv{font-size:14px;font-weight:700;color:var(--gold2);}
.si .sh{font-size:9px;color:var(--muted);margin-top:2px;}

/* equip slots */
.eq-row{display:flex;gap:5px;margin-top:8px;}
.eq-s{flex:1;background:var(--panel2);border:1px dashed var(--border);border-radius:7px;padding:5px 2px;text-align:center;cursor:pointer;min-width:0;}
.eq-s.filled{border-style:solid;border-color:var(--gold);}
.eq-s.cos-slot{border-color:rgba(212,160,255,.4);}
.eq-s.cos-slot.filled{border-color:var(--purple);}
.eq-s.pet-slot{border-color:rgba(26,188,156,.4);}
.eq-s.pet-slot.filled{border-color:var(--teal);}
.eq-s .ei{font-size:16px;}
.eq-s .el{font-size:8px;color:var(--muted);margin-top:1px;}

.upg-btn{width:100%;margin-top:10px;padding:9px;background:transparent;border:1px solid var(--gold);color:var(--gold);font-size:12px;font-weight:700;border-radius:8px;cursor:pointer;font-family:inherit;transition:all .2s;}
.upg-btn:hover{background:var(--gold);color:#1a1410;}

/* stat explanation */
.stat-explain{font-size:10px;color:var(--muted);background:#111;border-radius:8px;padding:8px 10px;margin-top:6px;line-height:1.7;}
.stat-explain span{color:var(--text);}

/* inv tabs */
.itabs{display:flex;gap:6px;margin-bottom:8px;}
.itab{flex:1;padding:5px;text-align:center;font-size:11px;background:#111;border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);}
.itab.active{border-color:var(--gold);color:var(--gold);}
.inv-item{display:flex;align-items:center;gap:7px;padding:6px 0;border-bottom:1px solid rgba(201,162,39,.1);}
.inv-item:last-child{border:none;}

/* CHECKIN */
.streak-big{text-align:center;padding:10px 0;}
.streak-big .snum{font-size:38px;font-weight:700;color:var(--gold2);line-height:1;}
.streak-big p{font-size:11px;color:var(--muted);margin-top:3px;}
.wrow{display:flex;gap:4px;margin-top:6px;}
.dd{flex:1;aspect-ratio:1;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);}
.dd.done{background:var(--gold);border-color:var(--gold);color:#1a1410;font-size:11px;}
.dd.today{border-color:var(--gold);color:var(--gold);}
.checkin-btn{width:100%;padding:12px;background:linear-gradient(90deg,#c9a227,#f0d060);color:#1a1410;font-size:14px;font-weight:700;border:none;border-radius:10px;cursor:pointer;font-family:inherit;margin-top:10px;}
.checkin-btn:disabled{opacity:.4;cursor:default;}
.steps-row{display:flex;gap:7px;margin-top:7px;}
.steps-row input{flex:1;background:#111;border:1px solid var(--border);color:var(--text);padding:8px 10px;border-radius:8px;font-size:14px;font-family:inherit;outline:none;}
.steps-row input:focus{border-color:var(--gold);}
.file-up{display:block;width:100%;margin-top:6px;padding:8px;background:#111;border:1px dashed var(--border);border-radius:8px;text-align:center;font-size:11px;color:var(--muted);cursor:pointer;}
.file-up input{display:none;}
.prev-img{width:100%;border-radius:8px;margin-top:6px;max-height:140px;object-fit:cover;border:1px solid var(--border);}
.tier-row{display:flex;gap:5px;margin-top:8px;}
.tier{flex:1;background:#111;border-radius:7px;padding:6px 2px;text-align:center;border:1px solid transparent;}
.tier .ts{font-size:9px;color:var(--muted);}
.tier .tc{font-size:10px;color:var(--gold);font-weight:700;margin-top:1px;}
.tier.reached{background:rgba(201,162,39,.15);border-color:var(--gold);}
.sub-btn{width:100%;padding:9px;background:transparent;border:1px solid var(--gold);color:var(--gold);font-size:12px;font-weight:700;border-radius:8px;cursor:pointer;font-family:inherit;margin-top:8px;transition:all .2s;}
.sub-btn:hover:not(:disabled){background:var(--gold);color:#1a1410;}
.sub-btn:disabled{opacity:.35;cursor:default;}

/* TASKS */
.task-section-title{font-size:11px;color:var(--muted);margin:10px 0 6px;display:flex;align-items:center;gap:6px;}
.task-section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.titem{background:var(--panel2);border:1px solid var(--border);border-radius:9px;padding:9px 11px;margin-bottom:7px;display:flex;align-items:center;gap:9px;}
.titem .tico{font-size:18px;flex-shrink:0;}
.titem .tinfo{flex:1;}
.titem .tn{font-size:12px;font-weight:500;}
.titem .td{font-size:10px;color:var(--muted);margin-top:1px;}
.titem .tr{font-size:10px;color:var(--gold);font-weight:700;margin-top:2px;}
.task-prog{font-size:10px;color:var(--teal);margin-top:2px;}
.tbtn{background:transparent;border:1px solid var(--gold);color:var(--gold);font-size:10px;padding:4px 8px;border-radius:6px;cursor:pointer;font-family:inherit;flex-shrink:0;}
.tbtn:disabled{opacity:.3;cursor:default;border-color:#3a3a3a;color:#3a3a3a;}

/* DUNGEON */
.ditem{background:var(--panel2);border:1px solid var(--border);border-radius:11px;padding:11px;margin-bottom:10px;position:relative;overflow:hidden;}
.ditem::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.ditem.d1::before{background:var(--green);}
.ditem.d2::before{background:var(--blue);}
.ditem.d3::before{background:var(--gold);}
.ditem.d4::before{background:var(--purple);}
.ditem.d5::before{background:var(--red);}
.ditem h3{font-size:13px;color:var(--gold2);margin-top:3px;}
.ditem .dsub{font-size:10px;color:var(--muted);margin-top:2px;margin-bottom:8px;}
.dmeta{display:flex;align-items:center;gap:5px;margin-bottom:7px;flex-wrap:wrap;}
.dbadge{font-size:9px;padding:2px 7px;border-radius:8px;font-weight:700;}
.db1{background:rgba(46,204,113,.15);color:var(--green);border:1px solid rgba(46,204,113,.4);}
.db2{background:rgba(112,184,255,.15);color:var(--blue);border:1px solid rgba(112,184,255,.4);}
.db3{background:rgba(201,162,39,.15);color:var(--gold);border:1px solid rgba(201,162,39,.4);}
.db4{background:rgba(212,160,255,.15);color:var(--purple);border:1px solid rgba(212,160,255,.4);}
.db5{background:rgba(231,76,60,.15);color:var(--red);border:1px solid rgba(231,76,60,.4);}
.wr-wrap{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.wr-bar{flex:1;height:5px;background:#111;border-radius:3px;overflow:hidden;}
.wr-fill{height:100%;border-radius:3px;transition:width .4s;}
.wr-lbl{font-size:10px;white-space:nowrap;}
.dfooter{display:flex;align-items:center;justify-content:space-between;gap:7px;}
.fight-btn{padding:7px 14px;background:transparent;border:1px solid var(--gold);color:var(--gold);border-radius:7px;cursor:pointer;font-size:11px;font-family:inherit;font-weight:700;transition:all .2s;}
.fight-btn:hover:not(:disabled){background:var(--gold);color:#1a1410;}
.fight-btn:disabled{opacity:.3;cursor:default;}
.dreward{font-size:10px;color:var(--muted);}
.blog{margin-top:8px;padding:7px 9px;background:#111;border-radius:7px;font-size:11px;color:var(--muted);border-left:2px solid var(--gold);display:none;}
.blog.show{display:block;}
.blog.fail{border-left-color:var(--red);}
.penalty-txt{color:var(--red);}
.cooldown-txt{color:var(--orange);font-size:10px;margin-top:4px;}

/* SHOP */
.stabs{display:flex;gap:6px;margin-bottom:10px;}
.stab{flex:1;padding:6px;text-align:center;font-size:11px;background:#111;border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);}
.stab.active{border-color:var(--gold);color:var(--gold);background:rgba(201,162,39,.08);}
.shop-g{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.sitem{background:var(--panel2);border:1px solid var(--border);border-radius:9px;padding:8px;text-align:center;display:flex;flex-direction:column;}
.sitem .sico{font-size:22px;line-height:1.2;}
.sitem .sn{font-size:11px;font-weight:600;margin-top:3px;line-height:1.3;}
.sitem .sd{font-size:9px;color:var(--muted);margin-top:2px;line-height:1.4;flex:1;}
.sitem .sp{font-size:11px;font-weight:700;margin-top:3px;}
.sp.gp{color:var(--gold);}
.sp.pp{color:var(--purple);}
.sp.tp{color:var(--teal);}
.bbtn{width:100%;margin-top:6px;padding:5px;background:transparent;border:1px solid var(--gold);color:var(--gold);border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit;transition:all .2s;}
.bbtn:hover:not(:disabled){background:var(--gold);color:#1a1410;}
.bbtn.pb{border-color:var(--purple);color:var(--purple);}
.bbtn.pb:hover:not(:disabled){background:var(--purple);color:#1a1410;}
.bbtn.tb{border-color:var(--teal);color:var(--teal);}
.bbtn.tb:hover:not(:disabled){background:var(--teal);color:#1a1410;}
.bbtn:disabled{opacity:.35;cursor:default;}

/* GACHA */
.ptabs{display:flex;gap:6px;margin-bottom:10px;}
.ptab{flex:1;padding:6px 3px;text-align:center;font-size:10px;background:#111;border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);}
.ptab.active{border-color:var(--purple);color:var(--purple);background:rgba(212,160,255,.08);}
.gbanner{border-radius:11px;padding:14px;margin-bottom:10px;}
.gbanner.pw{background:linear-gradient(135deg,#1e2830,#1a1410);border:1px solid rgba(112,184,255,.5);}
.gbanner.pc{background:linear-gradient(135deg,#2e1e38,#1a1410);border:1px solid rgba(212,160,255,.5);}
.gbanner.pp{background:linear-gradient(135deg,#0e2520,#1a1410);border:1px solid rgba(26,188,156,.5);}
.gbanner.pm{background:linear-gradient(135deg,#2e2518,#1a1410);border:1px solid rgba(201,162,39,.5);}
.gbanner h2{font-family:'Cinzel',serif;font-size:15px;}
.rate-section{margin-bottom:8px;}
.rate-sec-head{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.rate-items-wrap{display:flex;flex-wrap:wrap;gap:4px;}
.rcard{display:flex;align-items:center;gap:3px;background:#111;border-radius:5px;padding:2px 7px;font-size:10px;}
.pity-wrap{margin:8px 0;}
.pity-lbl{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:3px;}
.gbns{display:flex;gap:8px;margin-bottom:12px;}
.gbns button{flex:1;padding:10px 3px;border:none;border-radius:9px;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;line-height:1.7;}
.g1{background:linear-gradient(90deg,#5a3f8a,#7a5ab0);color:#fff;}
.g10{background:linear-gradient(90deg,#8a5a00,#c9a227);color:#1a1410;}
.res-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;margin-top:8px;}
.rcard2{background:#111;border-radius:7px;padding:6px 2px;text-align:center;border:1px solid #333;position:relative;}
.rcard2 .ri{font-size:20px;}
.rcard2 .rn{font-size:8px;color:var(--muted);margin-top:2px;}
.rcard2.s3{border-color:#f0d060;background:rgba(240,208,96,.12);}
.rcard2.s2{border-color:var(--purple);background:rgba(212,160,255,.12);}
.rcard2.s1{border-color:var(--blue);background:rgba(112,184,255,.1);}
.rcard2.s4{border-color:#ff6b9d;background:rgba(255,107,157,.15);box-shadow:0 0 8px rgba(255,107,157,.3);animation:s4glow 1.5s ease-in-out infinite alternate;}
@keyframes s4glow{from{box-shadow:0 0 5px rgba(255,107,157,.3);}to{box-shadow:0 0 12px rgba(255,107,157,.6);}}
.rcard2.s4{border-color:#ff6b9d;background:rgba(255,107,157,.15);box-shadow:0 0 8px rgba(255,107,157,.3);animation:s4glow 1.5s ease-in-out infinite alternate;}
@keyframes s4glow{from{box-shadow:0 0 5px rgba(255,107,157,.3);}to{box-shadow:0 0 14px rgba(255,107,157,.6);}}
.rcard2.snew::after{content:'NEW';position:absolute;top:1px;right:1px;background:var(--red);color:#fff;font-size:6px;font-weight:700;padding:1px 3px;border-radius:3px;}

/* PET */
.pet-card{background:var(--panel2);border:1px solid rgba(26,188,156,.3);border-radius:11px;padding:12px;margin-bottom:10px;}
.pet-top{display:flex;align-items:center;gap:11px;}
.pet-ava{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#0e2520,#1a1410);border:2px solid var(--teal);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;}
.pet-info h4{font-size:14px;font-weight:700;color:var(--teal);}
.pet-info .ptype{font-size:10px;color:var(--muted);margin-top:2px;}
.pet-lv-badge{display:inline-block;background:var(--teal);color:#111;font-size:9px;font-weight:700;padding:1px 6px;border-radius:7px;margin-top:3px;}
.pet-bonus{font-size:10px;color:var(--text);margin-top:4px;}
.pet-exp-wrap{margin-top:8px;}
.pet-feed-btn{width:100%;margin-top:7px;padding:8px;background:transparent;border:1px solid var(--teal);color:var(--teal);border-radius:7px;cursor:pointer;font-size:11px;font-family:inherit;font-weight:700;transition:all .2s;}
.pet-feed-btn:hover{background:var(--teal);color:#111;}
.no-pet{text-align:center;padding:20px;color:var(--muted);font-size:12px;}

/* PERFORMANCE / MONTHLY */
.perf-banner{background:linear-gradient(135deg,#2e2518,#1a1410);border:1px solid var(--border);border-radius:11px;padding:14px;margin-bottom:10px;}
.perf-banner h3{font-size:15px;color:var(--gold2);margin-bottom:4px;}
.perf-banner p{font-size:11px;color:var(--muted);}
.perf-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:10px;}
.perf-stat{background:#111;border-radius:8px;padding:9px 10px;text-align:center;}
.perf-stat .ps-lbl{font-size:10px;color:var(--muted);margin-bottom:3px;}
.perf-stat .ps-val{font-size:18px;font-weight:700;color:var(--gold2);}
.prog-bar-wrap{margin-top:10px;}
.prog-lbl{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:3px;}
.milestone-row{display:flex;gap:6px;margin-top:8px;overflow-x:auto;padding-bottom:3px;}
.milestone{flex-shrink:0;background:#111;border:1px solid var(--border);border-radius:8px;padding:6px 10px;text-align:center;}
.milestone.reached{border-color:var(--gold);background:rgba(201,162,39,.1);}
.milestone .ms-amt{font-size:10px;color:var(--muted);}
.milestone .ms-rew{font-size:11px;color:var(--gold);font-weight:700;}
.history-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(201,162,39,.1);}
.history-item:last-child{border:none;}

/* LB */
.lbtabs{display:flex;gap:6px;margin-bottom:10px;}
.lbtab{flex:1;padding:6px;text-align:center;font-size:10px;background:#111;border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);}
.lbtab.active{border-color:var(--gold);color:var(--gold);}
.lb-row{display:flex;align-items:center;gap:8px;padding:9px 10px;background:var(--panel2);border:1px solid var(--border);border-radius:9px;margin-bottom:6px;}
.lbrank{font-size:14px;font-weight:700;min-width:24px;text-align:center;color:var(--muted);}
.lbrank.r1{color:#f0d060;}.lbrank.r2{color:#c0c0c0;}.lbrank.r3{color:#cd7f32;}
.lbava{font-size:18px;width:28px;text-align:center;}
.lbinfo{flex:1;}
.lbinfo .ln{font-size:12px;font-weight:500;}
.lbinfo .ls{font-size:9px;color:var(--muted);margin-top:1px;}
.lbval{font-size:13px;font-weight:700;color:var(--gold2);}
.lb-me{border-color:var(--gold) !important;background:rgba(201,162,39,.07);}
.lb-diamond{border-color:rgba(176,79,255,.4) !important;background:rgba(176,79,255,.05);}

/* ADMIN */
.admin-panel{padding:13px;}
.admin-tabs{display:flex;gap:6px;margin-bottom:10px;}
.admin-tab{flex:1;padding:6px;text-align:center;font-size:11px;background:#111;border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);}
.admin-tab.active{border-color:var(--red);color:var(--red);}
.pitem{background:var(--panel2);border:1px solid var(--border);border-radius:9px;padding:10px;margin-bottom:8px;}
.pbtns{display:flex;gap:6px;margin-top:7px;}
.abtn-ok{flex:1;padding:6px;background:var(--green);color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:inherit;font-size:11px;font-weight:700;}
.abtn-no{flex:1;padding:6px;background:var(--red);color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:inherit;font-size:11px;font-weight:700;}
.perf-input-form{background:var(--panel2);border:1px solid var(--border);border-radius:9px;padding:12px;margin-bottom:10px;}
.perf-input-form h4{font-size:13px;color:var(--gold);margin-bottom:10px;}
.hero-select{width:100%;background:#111;border:1px solid var(--border);color:var(--text);padding:8px;border-radius:7px;font-family:inherit;font-size:13px;margin-bottom:8px;}
.perf-note{font-size:10px;color:var(--muted);margin-top:6px;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 STAMINA BAR 脙垄脗聲脗聬脙垄脗聲脗聬 */
.stam-bar-wrap{background:var(--panel);border-bottom:1px solid var(--border);padding:5px 13px;display:flex;align-items:center;gap:8px;}
.stam-icon{font-size:14px;flex-shrink:0;}
.stam-bg{flex:1;height:8px;background:#111;border-radius:4px;overflow:hidden;}
.stam-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#16a085,#1abc9c);transition:width .4s;}
.stam-txt{font-size:11px;font-weight:700;color:var(--teal);min-width:44px;text-align:right;}
.stam-recover{font-size:9px;color:var(--muted);}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 PET EVOLVED 脙垄脗聲脗聬脙垄脗聲脗聬 */
.pet-card.evolved{border-color:rgba(240,208,96,.5);background:linear-gradient(135deg,var(--panel2),#2e2518);}
.pet-card.evolved-r2{border-color:rgba(212,160,255,.5);background:linear-gradient(135deg,var(--panel2),#2e1e38);}
.pet-card.evolved-r3{border-color:rgba(240,208,96,.7);background:linear-gradient(135deg,#2e2518,#1e1a12);box-shadow:0 0 12px rgba(240,208,96,.15);}
.pet-skill{margin-top:7px;padding:6px 9px;background:#111;border-radius:7px;border-left:2px solid var(--teal);}
.pet-skill.s2{border-left-color:var(--purple);}
.pet-skill.s3{border-left-color:#f0d060;}
.pet-skill .sk-name{font-size:11px;font-weight:700;color:var(--teal);}
.pet-skill.s2 .sk-name{color:var(--purple);}
.pet-skill.s3 .sk-name{color:#f0d060;}
.pet-skill .sk-desc{font-size:10px;color:var(--muted);margin-top:2px;}
.evolve-btn{width:100%;margin-top:7px;padding:8px;background:linear-gradient(90deg,#8e44ad,#d4a0ff);color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:11px;font-weight:700;font-family:inherit;}
.evolve-btn:disabled{opacity:.35;cursor:default;background:#333;}
.merge-hint{font-size:10px;color:var(--muted);text-align:center;margin-top:5px;}
.lv-milestone{margin-top:6px;display:flex;gap:5px;overflow-x:auto;padding-bottom:2px;}
.lv-ms{flex-shrink:0;background:#111;border:1px solid var(--border);border-radius:6px;padding:4px 8px;text-align:center;}
.lv-ms.reached{border-color:var(--teal);background:rgba(26,188,156,.1);}
.lv-ms.s2{border-color:var(--purple);}
.lv-ms.s3{border-color:#f0d060;}
.lv-ms .ms-lv{font-size:9px;color:var(--muted);}
.lv-ms .ms-reward{font-size:10px;font-weight:700;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 脙楼脗鹿脗赂脙漏脗聛脗聥脙楼脗聙脗录 脙垄脗聲脗聬脙垄脗聲脗聬 */
.b-pink{background:linear-gradient(90deg,#c0392b,#ff6b9d);}
.luk-bar{display:flex;align-items:center;gap:7px;padding:5px 8px;background:rgba(255,107,157,.08);border:1px solid rgba(255,107,157,.25);border-radius:8px;margin-top:6px;}
.luk-icon{font-size:13px;}
.luk-val{font-size:13px;font-weight:700;color:#ff6b9d;min-width:28px;}
.luk-bg{flex:1;height:5px;background:#111;border-radius:3px;overflow:hidden;}
.luk-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#c0392b,#ff6b9d);}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 脙楼脗聟脗卢脙楼脗聭脗聤脙娄脗卢脗聞 脙垄脗聲脗聬脙垄脗聲脗聬 */
.notice-card{background:linear-gradient(135deg,#1e1a12,#2e2518);border:1px solid rgba(201,162,39,.4);border-radius:12px;padding:13px;margin-bottom:10px;}
.notice-card.pinned{border-color:var(--gold);background:linear-gradient(135deg,#2e2518,#1a1410);}
.notice-pin{display:inline-block;background:var(--gold);color:#1a1410;font-size:8px;font-weight:700;padding:1px 6px;border-radius:6px;margin-bottom:5px;}
.notice-title{font-size:14px;font-weight:700;color:var(--gold2);margin-bottom:5px;}
.notice-body{font-size:12px;color:var(--text);line-height:1.8;white-space:pre-wrap;}
.notice-date{font-size:10px;color:var(--muted);margin-top:7px;}
.notice-read-btn{width:100%;margin-top:8px;padding:7px;background:transparent;border:1px solid var(--gold);color:var(--gold);border-radius:7px;cursor:pointer;font-size:11px;font-family:inherit;font-weight:700;}
.notice-read-btn.done{border-color:var(--green);color:var(--green);opacity:.6;cursor:default;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 脙楼脗炉脗漏脙娄脗聽脗赂脙搂脗颅脗聣脙楼脗戮脗聟脙娄脗聫脗聬脙搂脗陇脗潞 脙垄脗聲脗聬脙垄脗聲脗聬 */
.pending-badge{display:inline-block;background:rgba(230,126,34,.2);border:1px solid var(--orange);color:var(--orange);font-size:9px;padding:1px 6px;border-radius:6px;margin-left:5px;}
.mem-banner{border-radius:14px;padding:18px;margin-bottom:12px;text-align:center;}
.mem-banner.none{background:var(--panel2);border:1px solid var(--border);}
.mem-banner.bronze{background:linear-gradient(135deg,#2d1f0f,#1a1410);border:2px solid #cd7f32;}
.mem-banner.silver{background:linear-gradient(135deg,#1e2430,#1a1410);border:2px solid #c0c0c0;}
.mem-banner.gold{background:linear-gradient(135deg,#2e2518,#1a1410);border:2px solid #f0d060;box-shadow:0 0 20px rgba(240,208,96,.12);}
.mem-banner.diamond{background:linear-gradient(135deg,#1e1438,#1a1410);border:2px solid #b04fff;box-shadow:0 0 24px rgba(176,79,255,.18);}
.mem-icon{font-size:40px;margin-bottom:6px;}
.mem-name{font-family:'Cinzel',serif;font-size:19px;font-weight:700;margin-bottom:3px;}
.mem-name.bronze{color:#cd7f32;}.mem-name.silver{color:#c0c0c0;}.mem-name.gold{color:#f0d060;}.mem-name.diamond{color:#d4a0ff;}.mem-name.none{color:var(--muted);}
.mem-price{font-size:11px;color:var(--muted);margin-bottom:10px;}
.mem-perks{display:flex;flex-direction:column;gap:5px;text-align:left;}
.mem-perk{display:flex;align-items:flex-start;gap:8px;font-size:11px;padding:5px 8px;background:rgba(0,0,0,.3);border-radius:7px;}
.mem-perk .pk-ico{flex-shrink:0;font-size:13px;}
.mem-perk .pk-txt{color:var(--text);line-height:1.5;}
.mem-expire{margin-top:10px;font-size:10px;color:var(--muted);border-top:1px solid rgba(255,255,255,.08);padding-top:8px;}
.tier-compare{display:flex;flex-direction:column;gap:6px;}
.tier-row-item{display:flex;align-items:center;gap:10px;padding:8px 10px;background:var(--panel2);border-radius:9px;border:1px solid var(--border);}
.tier-row-item.cur{border-color:var(--gold);}
.tier-row-item .ti-ico{font-size:20px;width:26px;flex-shrink:0;}
.tier-row-item .ti-info{flex:1;}
.tier-row-item .ti-name{font-size:12px;font-weight:700;}
.tier-row-item .ti-perks{font-size:10px;color:var(--muted);margin-top:2px;line-height:1.6;}
.tier-row-item .ti-price{font-size:11px;font-weight:700;flex-shrink:0;}
.mem-tag{display:inline-block;padding:1px 6px;border-radius:10px;font-size:9px;font-weight:700;margin-left:3px;vertical-align:middle;}
.mem-tag.bronze{background:#cd7f3222;color:#cd7f32;border:1px solid #cd7f3266;}
.mem-tag.silver{background:#c0c0c022;color:#c0c0c0;border:1px solid #c0c0c066;}
.mem-tag.gold{background:#f0d06022;color:#f0d060;border:1px solid #f0d06066;}
.mem-tag.diamond{background:#d4a0ff22;color:#d4a0ff;border:1px solid #d4a0ff66;}
.mem-admin-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(201,162,39,.1);font-size:12px;}
.mem-admin-row:last-child{border:none;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 TOAST SYSTEM 脙垄脗聲脗聬脙垄脗聲脗聬 */
.toast{position:fixed;bottom:25px;left:50%;transform:translateX(-50%) translateY(0);background:var(--gold);color:#1a1410;padding:9px 18px;border-radius:20px;font-weight:700;font-size:13px;opacity:0;transition:opacity .3s,transform .3s;pointer-events:none;z-index:9999;white-space:nowrap;max-width:92%;display:flex;align-items:center;gap:7px;box-shadow:0 4px 20px rgba(0,0,0,.5);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(-4px);}
.toast.t-fail{background:#c0392b;color:#fff;}
.toast.t-warn{background:#e67e22;color:#fff;}
.toast.t-info{background:#2980b9;color:#fff;}
.toast.t-level{background:linear-gradient(90deg,#8e44ad,#d4a0ff);color:#fff;font-size:14px;padding:11px 22px;border-radius:24px;box-shadow:0 0 25px rgba(212,160,255,.4);}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 LEVEL UP MODAL 脙垄脗聲脗聬脙垄脗聲脗聬 */
.lvup-modal{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:10000;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .3s;pointer-events:none;}
.lvup-modal.show{opacity:1;pointer-events:auto;}
.lvup-box{background:linear-gradient(135deg,#2e1e38,#1a1410);border:2px solid #d4a0ff;border-radius:20px;padding:28px 24px;text-align:center;max-width:300px;width:90%;box-shadow:0 0 40px rgba(212,160,255,.3);transform:scale(.85);transition:transform .3s;}
.lvup-modal.show .lvup-box{transform:scale(1);}
.lvup-stars{font-size:32px;animation:lvStars 1s ease-out infinite alternate;}
@keyframes lvStars{from{text-shadow:0 0 10px #f0d060;}to{text-shadow:0 0 30px #f0d060,0 0 60px #f0d060;}}
.lvup-num{font-family:'Cinzel',serif;font-size:42px;font-weight:700;background:linear-gradient(90deg,#c9a227,#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1;}
.lvup-title-txt{font-size:16px;color:#d4a0ff;margin:4px 0 8px;font-weight:700;}
.lvup-bonus{font-size:12px;color:var(--muted);background:rgba(0,0,0,.4);border-radius:8px;padding:8px 12px;margin-top:10px;line-height:1.8;}
.lvup-close{margin-top:14px;padding:9px 28px;background:linear-gradient(90deg,#c9a227,#f0d060);color:#1a1410;border:none;border-radius:12px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 TASK BADGE 脙垄脗聲脗聬脙垄脗聲脗聬 */
.tab-badge{position:absolute;top:3px;right:3px;min-width:14px;height:14px;background:var(--red);color:#fff;font-size:8px;font-weight:700;border-radius:7px;display:flex;align-items:center;justify-content:center;padding:0 3px;}
.tab{position:relative;}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 LB 脙楼脗聧脗聡脙搂脗麓脗職脙篓脗娄脗聳脙篓脗娄脗潞 脙垄脗聲脗聬脙垄脗聲脗聬 */
.lb-row{display:flex;align-items:center;gap:8px;padding:10px 12px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;margin-bottom:7px;position:relative;overflow:hidden;}
.lb-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--border);}
.lb-row.r1-row::before{background:linear-gradient(180deg,#f0d060,#c9a227);}
.lb-row.r2-row::before{background:linear-gradient(180deg,#c0c0c0,#a0a0a0);}
.lb-row.r3-row::before{background:linear-gradient(180deg,#cd7f32,#a05a22);}
.lb-me::before{background:linear-gradient(180deg,var(--gold),#8a6010) !important;}
.lb-stat-bar{margin-top:3px;height:3px;background:#111;border-radius:2px;overflow:hidden;width:80px;}
.lb-stat-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold),#f0d060);}

/* 脙垄脗聲脗聬脙垄脗聲脗聬 ADMIN DASHBOARD 脙垄脗聲脗聬脙垄脗聲脗聬 */
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
.dash-card{background:#111;border:1px solid var(--border);border-radius:10px;padding:11px;text-align:center;}
.dash-card .dc-val{font-size:24px;font-weight:700;color:var(--gold2);}
.dash-card .dc-lbl{font-size:10px;color:var(--muted);margin-top:3px;}
.dash-card.dc-alert{border-color:var(--red);background:rgba(231,76,60,.06);}
.dash-card.dc-alert .dc-val{color:var(--red);}
.hero-summary-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(201,162,39,.08);}
.hero-summary-row:last-child{border:none;}
.hsr-bar{flex:1;height:4px;background:#111;border-radius:2px;overflow:hidden;}
.hsr-fill{height:100%;border-radius:2px;}
.lov{position:fixed;inset:0;background:rgba(26,20,16,.88);display:flex;align-items:center;justify-content:center;z-index:9998;flex-direction:column;gap:10px;}
.spin{width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:sp .8s linear infinite;}
@keyframes sp{to{transform:rotate(360deg);}}
.empty{text-align:center;padding:16px;font-size:12px;color:var(--muted);}
.locked-item{opacity:.7;border-style:dashed!important;}
/* LOTTERY */
.lottery-banner{background:linear-gradient(135deg,#2e1e10,#1a1410);border:1px solid rgba(240,208,96,.5);border-radius:12px;padding:16px;margin-bottom:10px;text-align:center;}
.lb-month-title{font-family:'Cinzel',serif;font-size:17px;color:var(--gold2);margin-bottom:4px;}
.lb-sponsor{font-size:12px;color:var(--muted);}
.ticket-bar{margin-bottom:10px;}
.prize-item{display:flex;align-items:center;gap:12px;padding:10px;background:#111;border-radius:10px;margin-bottom:8px;border:1px solid var(--border);}
.prize-item.won{border-color:var(--gold);background:rgba(201,162,39,.08);}
.prize-ico{font-size:30px;flex-shrink:0;}
.prize-info{flex:1;}
.prize-name{font-size:13px;font-weight:700;color:var(--text);}
.prize-sponsor{font-size:10px;color:var(--muted);margin-top:2px;}
.prize-qty{font-size:11px;color:var(--teal);margin-top:2px;}
.prize-won-badge{font-size:10px;padding:2px 8px;border-radius:8px;background:rgba(201,162,39,.2);border:1px solid var(--gold);color:var(--gold);font-weight:700;flex-shrink:0;}
.draw-btn{width:100%;padding:14px;background:linear-gradient(90deg,#8a5a00,#c9a227);color:#1a1410;font-size:15px;font-weight:700;border:none;border-radius:10px;cursor:pointer;font-family:inherit;transition:opacity .2s;}
.draw-btn:disabled{opacity:.4;cursor:default;}
.draw-result-card{background:#111;border-radius:12px;padding:16px;text-align:center;border:2px solid var(--gold);}
.draw-result-card.no-prize{border-color:#3a3a3a;}
.draw-prize-ico{font-size:48px;margin-bottom:8px;}
.draw-prize-name{font-size:16px;font-weight:700;color:var(--gold2);}
.draw-prize-sub{font-size:11px;color:var(--muted);margin-top:4px;}
.winner-row{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid rgba(201,162,39,.1);}
.winner-row:last-child{border:none;}
.winner-ava{font-size:18px;}
.winner-name{font-size:12px;font-weight:500;flex:1;}
.winner-prize{font-size:11px;color:var(--gold);}
.winner-date{font-size:10px;color:var(--muted);}
.ticket-src-row{display:flex;justify-content:space-between;padding:3px 0;}
.ticket-src-row .src-label{color:var(--muted);}
.ticket-src-row .src-val{color:var(--gold2);font-weight:700;}
</style>
</head>
<body>
<div id="app">

<!-- AUTH -->
<div id="auth">
  <h1>脙垄脗聹脗篓 MIIRAGIC DAILY</h1>
