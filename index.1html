// 脙垄脗聲脗聬脙垄脗聲脗聬 ADMIN ACCOUNT 脙垄脗聲脗聬脙垄脗聲脗聬
function ensureAdmin(){
  try{
    const uid='admin';
    const pw=hsh(ADMIN_SUPER_PW+uid+'hd2025');
    if(LS.one('heroes','user_id',uid)) return; // 脙楼脗路脗虏脙楼脗颅脗聵脙楼脗聹脗篓脙楼脗聣脗聡脙篓脗路脗鲁脙漏脗聛脗聨
    const base=CLASS_DEF['prophet'];
    LS.ins('heroes',{
      user_id:uid,username:'MIIRAGIC脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆',password_hash:pw,
      avatar:'脙垄脗職脗聶脙炉脗赂脗聫',hero_class:'prophet',gender:'male',
      level:20,exp:0,coins:99999,
      stat_hp:base.hp,stat_str:base.str,stat_def:base.def,stat_spd:base.spd,
      base_hp:base.hp,base_str:base.str,base_def:base.def,base_spd:base.spd,
      base_luk:base.luk||20,luk_bonus:0,
      streak:0,total_steps:0,total_perf:0,
      week_days:[false,false,false,false,false,false,false],
      inventory:[],equipped:{},
      tasks_done:[],dungeons_done:[],weekly_tasks_done:[],
      pity:{weapon:0,costume:0,pet:0,mixed:0},
      monk_att:{},member_tier:'none',
      week_data:{week:wk(),daily_count:0,dungeon_count:0,steps:0,buy_count:0},
      approved:true,
      id:'admin_fixed',
    });
  }catch(e){console.warn('ensureAdmin error:',e);}
}
ensureAdmin();

function resetAllData(){
  if(!confirm('脙垄脗職脗聽脙炉脗赂脗聫 脙搂脗垄脗潞脙楼脗庐脗職脙娄脗赂脗聟脙漏脗聶脗陇脙娄脗聣脗聙脙娄脗聹脗聣脙娄脗聹脗卢脙楼脗聹脗掳脙篓脗鲁脗聡脙娄脗聳脗聶脙漏脗聡脗聧脙娄脗聳脗掳脙漏脗聳脗聥脙楼脗搂脗聥脙炉脗录脗聼')) return;
  Object.keys(localStorage).filter(k=>k.startsWith('hd4_')).forEach(k=>localStorage.removeItem(k));
  ensureTest();
  ensureAdmin();
  location.reload();
}
// stamina ticker 脙垄脗聙脗聰 updates every 60 seconds
setInterval(()=>{if(hero){_try(updStamina);_try(checkMidnightReset);}},60000);

// 脙垄脗聲脗聬脙垄脗聲脗聬 00:00 脙楼脗聣脗炉脙娄脗聹脗卢脙漏脗聡脗聧脙搂脗陆脗庐 脙垄脗聲脗聬脙垄脗聲脗聬
function checkMidnightReset(){
  if(!hero) return;
  const today=tod();
  if(hero.last_dung_reset===today) return; // 脙陇脗禄脗聤脙楼脗陇脗漏脙楼脗路脗虏脙漏脗聡脗聧脙搂脗陆脗庐脙漏脗聛脗聨
  hero.last_dung_reset=today;
  // 脙楼脗聫脗陋脙漏脗聡脗聧脙搂脗陆脗庐脙漏脗聺脗聻脙漏脗聡脗聧脙篓脗陇脗聡脙漏脗聴脗聹脙楼脗聧脗隆脙搂脗職脗聞脙漏脗聙脗職脙漏脗聴脗聹脙搂脗麓脗聙脙漏脗聦脗聞脙炉脗录脗聢repeat:true 脙搂脗職脗聞脙娄脗聳脗掳脙娄脗聣脗聥脙漏脗聴脗聹脙楼脗聧脗隆脙陇脗赂脗聧脙漏脗聡脗聧脙搂脗陆脗庐脙炉脗录脗聣
  const repeatIds=new Set(DUNGEONS.filter(d=>d.repeat).map(d=>d.id));
  hero.dungeons_done=(hero.dungeons_done||[]).filter(id=>repeatIds.has(id));
  // 脙漏脗聡脗聧脙搂脗陆脗庐脙陇脗禄脗聤脙娄脗聴脗楼脙漏脗聙脗職脙漏脗聴脗聹脙篓脗篓脗聢脙娄脗聲脗赂
  hero.today_dungeon_clear=0;
  hero.today_dungeon_clear_date=today;
  save();
  _try(renderDungeons);
  toast('脙掳脗聼脗聦脗聶 脙楼脗聧脗聢脙楼脗陇脗聹脙漏脗聡脗聧脙搂脗陆脗庐脙炉脗录脗聛脙楼脗聣脗炉脙娄脗聹脗卢脙楼脗路脗虏脙楼脗聢脗路脙娄脗聳脗掳');
}

// 脙漏脗聽脗聛脙漏脗聺脗垄脙篓脗录脗聣脙楼脗聟脗楼脙娄脗聶脗聜脙娄脗赂脗聟脙漏脗聶脗陇脙陇脗禄脗禄脙陇脗陆脗聲脙娄脗庐脗聵脙搂脗聲脗聶 overlay
document.addEventListener('DOMContentLoaded',()=>{
  const o=document.getElementById('lov-el');if(o)o.remove();
  // 脙搂脗垄脗潞脙陇脗驴脗聺脙搂脗聶脗禄脙楼脗聟脗楼脙漏脗聽脗聛脙漏脗隆脗炉脙搂脗陇脗潞脙娄脗颅脗拢脙搂脗垄脗潞
  if(!hero){
    const auth=document.getElementById('auth');
    const main=document.getElementById('main');
    if(auth) auth.style.display='flex';
    if(main) main.style.display='none';
  }
});

</script>
