<script>
// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬
// SUPABASE CONFIG
// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬
const SB_URL='https://plgrsxtlaznajzqgcuqr.supabase.co';
const SB_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsZ3JzeHRsYXpuYWp6cWdjdXFyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5Njg1MDIsImV4cCI6MjA5MDU0NDUwMn0.XyZ0wQbZQ-CInglRpv-MHMuMvkviRovm-o-On_FeyGs';
// 脙垄脗職脗聽脙炉脗赂脗聫 脙篓脗芦脗聥脙楼脗聢脗掳 Supabase > Settings > API 脙篓脗陇脗聡脙篓脗拢脗陆 anon public key 脙篓脗虏脗录脙楼脗聹脗篓脙陇脗赂脗聤脙娄脗聳脗鹿 placeholder 脙陇脗陆脗聧脙搂脗陆脗庐

const sbFetch=async(path,opts={})=>{
  try{
    const r=await fetch(SB_URL+'/rest/v1/'+path,{
      headers:{'apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY,'Content-Type':'application/json','Prefer':'return=representation',...(opts.headers||{})},
      ...opts
    });
    if(!r.ok){const e=await r.text();console.warn('SB err:',r.status,e);return null;}
    const txt=await r.text();return txt?JSON.parse(txt):null;
  }catch(e){console.warn('SB fetch err:',e);return null;}
};

// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬
// LOCALDB脙炉脗录脗聢localStorage 脙楼脗驴脗芦脙楼脗聫脗聳 + Supabase 脙篓脗聝脗聦脙娄脗聶脗炉 sync脙炉脗录脗聣
// 脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬脙垄脗聲脗聬
const LS={
  g(t){try{return JSON.parse(localStorage.getItem('hd4_'+t)||'[]');}catch(e){return[];}},
  s(t,d){localStorage.setItem('hd4_'+t,JSON.stringify(d));},
  one(t,f,v){return LS.g(t).find(r=>r[f]===v)||null;},
  ins(t,row){
    const rows=LS.g(t);
    if(t==='heroes'&&rows.some(r=>r.user_id===row.user_id))return{error:{code:'23505'}};
    row.id=row.id||('id'+Date.now()+Math.random().toString(36).slice(2));
    rows.push(row);LS.s(t,rows);
    // Supabase sync
    if(t==='heroes') sbSyncHero(row);
    else sbSyncGameData(t,row.id,row);
    return{data:row,error:null};
  },
  upd(t,f,v,u){
    const rows=LS.g(t);const i=rows.findIndex(r=>r[f]===v);
    if(i>=0){rows[i]={...rows[i],...u};LS.s(t,rows);
      // Supabase sync
      if(t==='heroes') sbSyncHero(rows[i]);
      else sbSyncGameData(t,rows[i].id||v,rows[i]);
      return rows[i];}return null;
  },
  qry(t,fil={},ord=null,lim=50){
    let rows=LS.g(t);
    Object.entries(fil).forEach(([k,v])=>{rows=rows.filter(r=>r[k]===v);});
    if(ord)rows.sort((a,b)=>(b[ord]||0)-(a[ord]||0));
    return rows.slice(0,lim);
  },
};

// 脙垄脗聰脗聙脙垄脗聰脗聙 Supabase sync 脙楼脗聡脗陆脙娄脗聲脗赂 脙垄脗聰脗聙脙垄脗聰脗聙
async function sbSyncHero(h){
  if(!h?.user_id)return;
  await sbFetch('heroes',{
    method:'POST',
    headers:{'Prefer':'resolution=merge-duplicates'},
    body:JSON.stringify({id:h.id||h.user_id,user_id:h.user_id,data:h,updated_at:new Date().toISOString()})
  });
}
async function sbSyncGameData(table,key,row){
  if(!key)return;
  await sbFetch('game_data',{
    method:'POST',
    headers:{'Prefer':'resolution=merge-duplicates'},
    body:JSON.stringify({table_name:table,row_key:String(key),data:row,updated_at:new Date().toISOString()})
  });
}

// 脙垄脗聰脗聙脙垄脗聰脗聙 脙楼脗戮脗聻 Supabase 脙娄脗聥脗聣脙楼脗聫脗聳脙娄脗聹脗聙脙娄脗聳脗掳脙篓脗鲁脗聡脙娄脗聳脗聶脙炉脗录脗聢脙搂脗聶脗禄脙楼脗聟脗楼脙娄脗聶脗聜脙楼脗聭脗录脙楼脗聫脗芦脙炉脗录脗聣脙垄脗聰脗聙脙垄脗聰脗聙
async function sbPullHero(user_id){
  const rows=await sbFetch('heroes?user_id=eq.'+encodeURIComponent(user_id)+'&select=data');
  if(rows&&rows.length>0){
    const remote=rows[0].data;
    // 脙楼脗聬脗聢脙陇脗陆脗碌脙炉脗录脗職脙陇脗禄脗楼 Supabase 脙搂脗聜脗潞脙陇脗赂脗禄脙炉脗录脗聢updated_at 脙篓脗录脗聝脙娄脗聳脗掳脙炉脗录脗聣
    const local=LS.one('heroes','user_id',user_id);
    if(!local||(remote.updated_at&&(!local.updated_at||remote.updated_at>local.updated_at))){
      const all=LS.g('heroes').filter(r=>r.user_id!==user_id);
      all.push(remote);LS.s('heroes',all);
      return remote;
    }
  }
  return LS.one('heroes','user_id',user_id);
}

// 脙垄脗聰脗聙脙垄脗聰脗聙 脙楼脗聟脗篓脙漏脗聡脗聫脙楼脗戮脗聻 Supabase 脙楼脗聬脗聦脙娄脗颅脗楼脙娄脗聣脗聙脙娄脗聹脗聣 heroes脙炉脗录脗聢脙搂脗庐脗隆脙搂脗聬脗聠脙楼脗聯脗隆脙楼脗戮脗聦脙楼脗聫脗掳脙搂脗聰脗篓脙炉脗录脗聣脙垄脗聰脗聙脙垄脗聰脗聙
async function sbPullAllHeroes(){
  const rows=await sbFetch('heroes?select=data&order=updated_at.desc&limit=200');
  if(rows&&rows.length>0){
    const remoteHeroes=rows.map(r=>r.data).filter(Boolean);
    const localIds=new Set(LS.g('heroes').map(h=>h.user_id));
    let merged=LS.g('heroes');
    remoteHeroes.forEach(rh=>{
      const i=merged.findIndex(lh=>lh.user_id===rh.user_id);
      if(i>=0){if(rh.updated_at&&(!merged[i].updated_at||rh.updated_at>merged[i].updated_at))merged[i]=rh;}
      else merged.push(rh);
    });
    LS.s('heroes',merged);
  }
}

// 脙垄脗聰脗聙脙垄脗聰脗聙 脙娄脗聨脗篓脙漏脗聙脗聛脙娄脗聣脗聙脙娄脗聹脗聣 game_data 脙篓脗鲁脗聡脙娄脗聳脗聶脙篓脗隆脗篓 脙垄脗聰脗聙脙垄脗聰脗聙
async function sbPushAllGameData(){
  const tables=['step_submissions','task_reviews','perf_records','perf_ms_reviews',
    'lottery_prizes','lottery_winners','lottery_config','lottery_draws',
    'custom_daily_tasks','notices'];
  for(const t of tables){
    const rows=LS.g(t);
    for(const row of rows){
      await sbSyncGameData(t,row.id||row.month||row.user_id,row);
    }
  }
}

// 脙垄脗聰脗聙脙垄脗聰脗聙 脙楼脗戮脗聻 Supabase 脙娄脗聥脗聣脙楼脗聫脗聳脙娄脗聣脗聙脙娄脗聹脗聣 game_data 脙垄脗聰脗聙脙垄脗聰脗聙
async function sbPullGameData(table){
  const rows=await sbFetch('game_data?table_name=eq.'+encodeURIComponent(table)+'&select=data&order=updated_at.desc&limit=500');
  if(rows&&rows.length>0){
    const data=rows.map(r=>r.data).filter(Boolean);
    LS.s(table,data);
    return data;
  }
  return LS.g(table);
