function getDailyTasks(){
  const custom=LS.g('custom_daily_tasks').filter(t=>!t.deleted);
  const base=DAILY_TASKS_BASE.map((t,i)=>{
    if(t.type==='review'||t.type==='dungeon_clear') return t;
    return {...t,drop:{chance:0.01+((i*3)%3)*0.01,item:getTodayDrop(i)}};
  });
  return [...base,...custom];
}
